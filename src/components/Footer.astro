---
const footerNav = {
  systems: [
    { label: "System Overview", href: "/system-overview/" },
    { label: "Lumina Slate", href: "/lumina-slate/" },
    { label: "Storm Guard", href: "/storm-guard/" },
  ],
  company: [
    { label: "Projects", href: "/projects/" },
    { label: "Resources", href: "/resources/" },
    { label: "About", href: "/about/" },
  ],
};

const socialLinks = [
  // Add social links here if needed in the future
  // { label: "LinkedIn", href: "#" },
];
---

<footer class="bg-charcoal text-white/80 pt-20 pb-12">
  <div class="container max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div
      class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 lg:gap-8 mb-16"
    >
      <div class="md:col-span-2 lg:col-span-1">
        <a href="/" class="flex items-center mb-5">
          <img
            src="/sunlit-logo.png"
            alt="Sunlit — Integrated Solar Solutions"
            class="h-8 w-auto brightness-0 invert"
            loading="lazy"
          />
        </a>
        <p class="text-base text-slate leading-relaxed">
          Complete BIPV systems for distributors, installers, and project
          developers.
        </p>
      </div>

      <div>
        <h4
          class="font-heading font-bold mb-5 text-base text-white tracking-tight"
        >
          Systems
        </h4>
        <ul class="space-y-3 text-base text-slate">
          {
            footerNav.systems.map((item) => (
              <li>
                <a href={item.href} class="hover:text-amber transition-colors"
                  >{item.label}</a
                >
              </li>
            ))
          }
        </ul>
      </div>

      <div>
        <h4
          class="font-heading font-bold mb-5 text-base text-white tracking-tight"
        >
          Company
        </h4>
        <ul class="space-y-3 text-base text-slate">
          {
            footerNav.company.map((item) => (
              <li>
                <a href={item.href} class="hover:text-amber transition-colors"
                  >{item.label}</a
                >
              </li>
            ))
          }
        </ul>
      </div>

      <div>
        <h4
          class="font-heading font-bold mb-5 text-base text-white tracking-tight"
        >
          Get in Touch
        </h4>
        <div class="space-y-4">
          <p class="text-base text-slate">
            <a href="mailto:info@sunlitsolarroof.com" class="hover:text-amber transition-colors"
              >info@sunlitsolarroof.com</a
            >
          </p>
          <p class="text-base text-slate/70">Changzhou, Jiangsu, China</p>
          <a href="/contact/" class="sunlit-btn-primary text-sm mt-2">
            Request a Quote
          </a>
        </div>
      </div>
    </div>

    <div
      class="border-t border-white/10 pt-8 flex flex-col sm:flex-row items-center justify-between text-base text-slate/70 gap-6"
    >
      <p>&copy; {new Date().getFullYear()} Sunlit. All rights reserved.</p>
      <div class="flex items-center gap-6">
        {
          socialLinks.length > 0 && (
            <div class="flex items-center gap-4">
              {socialLinks.map((link) => (
                <a href={link.href} class="hover:text-amber transition-colors">
                  {link.label}
                </a>
              ))}
            </div>
          )
        }
        <a href="/privacy-policy/" class="hover:text-amber transition-colors"
          >Privacy Policy</a
        >
      </div>
    </div>
  </div>
</footer>
