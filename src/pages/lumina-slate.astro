---

<Layout title="Lumina Slate — Premium Glass Solar Roof Tiles | Sunlit Solar Roof" description="Lumina Slate premium slate-look glass solar roof tiles. Active + inactive integrated system for architecture-led villas and high-end residential projects.">

  <!-- HERO -->
  <section class="bg-light-gray pt-10 pb-0 overflow-hidden">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-[1fr_1.2fr] gap-8 items-start">
        <div class="pb-10 lg:pb-16 pt-4">
          <p class="sunlit-overline mb-4">Premium Slate-Look Solar Roof System</p>
          <h1 class="font-heading font-bold text-4xl md:text-5xl lg:text-6xl text-charcoal leading-tight mb-5">
            Lumina Slate<br>Glass Solar<br>Roof Tiles
          </h1>
          <p class="text-slate text-lg leading-relaxed mb-8 max-w-md">
            Premium slate-look glass solar roof tiles that deliver clean energy with timeless beauty. Designed for architecture-led and high-end residential projects.
          </p>
          <div class="flex flex-wrap gap-3 mb-10">
            <a href="/contact/" class="sunlit-btn-primary">Request Product Details →</a>
            <a href="/projects/" class="sunlit-btn-secondary">View Project References →</a>
          </div>
          <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
            <div class="flex items-start gap-2">
              <svg class="flex-shrink-0 text-deep-green mt-0.5" width="18" height="18" viewBox="0 0 18 18" fill="none"><circle cx="9" cy="9" r="7" stroke="currentColor" stroke-width="1.4" fill="none"/><path d="M5.5 9 L8 11.5 L12.5 6.5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
              <div><p class="font-heading font-bold text-charcoal text-xs leading-tight">25-Year</p><p class="text-slate text-xs">Product & Power Warranty</p></div>
            </div>
            <div class="flex items-start gap-2">
              <svg class="flex-shrink-0 text-deep-green mt-0.5" width="18" height="18" viewBox="0 0 18 18" fill="none"><rect x="2" y="5" width="14" height="9" rx="1.5" stroke="currentColor" stroke-width="1.4" fill="none"/><line x1="2" y1="8" x2="16" y2="8" stroke="currentColor" stroke-width="1"/><line x1="2" y1="11" x2="16" y2="11" stroke="currentColor" stroke-width="1"/><line x1="6" y1="5" x2="6" y2="14" stroke="currentColor" stroke-width="1"/><line x1="12" y1="5" x2="12" y2="14" stroke="currentColor" stroke-width="1"/></svg>
              <div><p class="font-heading font-bold text-charcoal text-xs leading-tight">Premium</p><p class="text-slate text-xs">Slate Aesthetic Finish</p></div>
            </div>
            <div class="flex items-start gap-2">
              <svg class="flex-shrink-0 text-deep-green mt-0.5" width="18" height="18" viewBox="0 0 18 18" fill="none"><circle cx="9" cy="7" r="3" stroke="currentColor" stroke-width="1.4" fill="none"/><line x1="9" y1="10" x2="9" y2="16" stroke="currentColor" stroke-width="1.4"/><line x1="6" y1="7" x2="3" y2="5" stroke="currentColor" stroke-width="1.2"/><line x1="12" y1="7" x2="15" y2="5" stroke="currentColor" stroke-width="1.2"/></svg>
              <div><p class="font-heading font-bold text-charcoal text-xs leading-tight">High Efficiency</p><p class="text-slate text-xs">Up to 21.5% Module Efficiency</p></div>
            </div>
            <div class="flex items-start gap-2">
              <svg class="flex-shrink-0 text-deep-green mt-0.5" width="18" height="18" viewBox="0 0 18 18" fill="none"><rect x="2" y="6" width="14" height="9" rx="1.5" stroke="currentColor" stroke-width="1.4" fill="none"/><path d="M5 6V5a4 4 0 0 1 8 0v1" stroke="currentColor" stroke-width="1.4" fill="none"/></svg>
              <div><p class="font-heading font-bold text-charcoal text-xs leading-tight">Complete System</p><p class="text-slate text-xs">Tiles, fixings & Accessories</p></div>
            </div>
          </div>
        </div>
        <div class="grid grid-cols-2 gap-3 h-full min-h-[420px]">
          <div class="col-span-1 row-span-2 rounded-2xl overflow-hidden">
            <img src="/images/projects/hangzhou-xianghu-arcadia-villa/sunlit-bipv-roof-scenic-harmony-xianghu-mountains.webp" alt="Lumina Slate installed on villa roof" class="w-full h-full object-cover"/>
          </div>
          <div class="rounded-2xl overflow-hidden">
            <img src="/images/projects/hangzhou-xianghu-arcadia-villa/sunlit-solar-slate-installed-texture-close-up.webp" alt="Lumina Slate close-up texture" class="w-full h-full object-cover"/>
          </div>
          <div class="rounded-2xl overflow-hidden">
            <img src="/images/projects/nanjing-nanshan-lake/sunlit-solar-roof-yellow-resort-villa-aerial.webp" alt="Lumina Slate aerial view" class="w-full h-full object-cover"/>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FEATURE BAR -->
  <section class="py-8 bg-white border-y border-border">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 md:grid-cols-5 gap-6">
        {features.map((f) => (
          <div class="flex items-start gap-3">
            <div class="flex-shrink-0 w-10 h-10 rounded-xl bg-soft-green flex items-center justify-center text-deep-green" set:html={f.icon} />
            <div>
              <p class="font-heading font-bold text-charcoal text-sm leading-tight">{f.title}</p>
              <p class="text-slate text-xs mt-0.5 leading-snug">{f.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- COMPONENT LIBRARY -->
  <section class="py-16 md:py-20 bg-light-gray">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-end justify-between mb-8">
        <div>
          <h2 class="font-heading font-bold text-2xl md:text-3xl text-charcoal">Component Library</h2>
          <p class="text-slate mt-1 text-sm">Complete system components engineered for performance, durability and easy installation.</p>
        </div>
        <p class="text-slate text-sm hidden md:block">Detailed specifications available on request.</p>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-4">
        {components.map((c) => (
          <div class="sunlit-card p-4 flex flex-col">
            <div class="h-24 bg-soft-green rounded-xl mb-3 flex items-center justify-center" set:html={c.svgIcon} />
            <h4 class="font-heading font-bold text-charcoal text-sm mb-3 leading-tight">{c.name}</h4>
            <div class="mt-auto space-y-1.5">
              {c.specs.map((s) => (
                <div class="flex justify-between gap-1">
                  <span class="text-slate text-xs">{s.label}</span>
                  <span class="font-heading font-semibold text-charcoal text-xs text-right">{s.value}</span>
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- BUILT PROJECTS -->
  <section class="py-16 md:py-20 bg-white">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="mb-8">
        <h2 class="font-heading font-bold text-2xl md:text-3xl text-charcoal">Built Projects with Lumina Slate</h2>
        <p class="text-slate mt-1 text-sm">Real projects around the world showcasing the elegance and performance of our slate-look solar roof system.</p>
      </div>
      <div class="grid lg:grid-cols-2 gap-6 items-start">
        <div class="grid grid-cols-2 gap-3">
          <div class="col-span-2 rounded-2xl overflow-hidden h-52">
            <img src="/images/projects/nanjing-nanshan-lake/sunlit-solar-roof-yellow-resort-villa-aerial.webp" alt="Project aerial" class="w-full h-full object-cover"/>
          </div>
          <div class="rounded-2xl overflow-hidden h-40">
            <img src="/images/projects/hangzhou-xianghu-arcadia-villa/sunlit-solar-slate-roof-tiles-xianghu-details.webp" alt="Roof detail" class="w-full h-full object-cover"/>
          </div>
          <div class="rounded-2xl overflow-hidden h-40">
            <img src="/images/projects/beijing-new-world-lizun/sunlit-bipv-roof-villa-construction-site.webp" alt="Construction" class="w-full h-full object-cover"/>
          </div>
          <div class="rounded-2xl overflow-hidden h-40">
            <img src="/images/projects/hangzhou-xianghu-arcadia-villa/sunlit-solar-slate-installed-texture-close-up.webp" alt="Texture close-up" class="w-full h-full object-cover"/>
          </div>
          <div class="rounded-2xl overflow-hidden h-40">
            <img src="/images/projects/beijing-new-world-lizun/sunlit-invisible-solar-roof-waterproof-surface.webp" alt="Sleek surface" class="w-full h-full object-cover"/>
          </div>
        </div>
        <div class="space-y-3">
          {luminaProjects.map((p: any) => (
            <a href={`/projects/${p.slug}/`} class="sunlit-card p-5 flex gap-4 items-start hover:border-deep-green/40 transition-colors group block">
              <div class="flex-shrink-0 w-20 h-16 rounded-xl overflow-hidden">
                <img src={p.images[0]} alt={p.name} class="w-full h-full object-cover"/>
              </div>
              <div class="flex-1 min-w-0">
                <h4 class="font-heading font-bold text-charcoal text-sm leading-tight mb-1 group-hover:text-deep-green transition-colors">{p.name}</h4>
                <p class="text-slate text-xs mb-2">📍 {p.location} · {p.application}</p>
                <div class="flex gap-4 text-xs">
                  <div><span class="text-slate">Roof Area</span><br><span class="font-heading font-semibold text-charcoal">{p.roofArea}</span></div>
                  <div><span class="text-slate">System Capacity</span><br><span class="font-heading font-semibold text-charcoal">{p.capacity}</span></div>
                </div>
              </div>
              <span class="text-deep-green text-sm font-heading font-bold flex-shrink-0 group-hover:translate-x-1 transition-transform">View →</span>
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- IS LUMINA SLATE RIGHT? -->
  <section class="py-16 md:py-20 bg-light-gray">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="font-heading font-bold text-2xl md:text-3xl text-charcoal mb-6">Is Lumina Slate Right for Your Project?</h2>
      <div class="grid lg:grid-cols-2 gap-5">
        <div class="sunlit-card p-6 flex gap-5">
          <div class="flex-shrink-0 w-28 h-28 rounded-xl overflow-hidden">
            <img src="/images/projects/hangzhou-xianghu-arcadia-villa/sunlit-bipv-roof-scenic-harmony-xianghu-mountains.webp" alt="Best fit" class="w-full h-full object-cover"/>
          </div>
          <div>
            <div class="flex items-center gap-2 mb-3">
              <div class="w-5 h-5 rounded-full bg-deep-green flex items-center justify-center">
                <svg width="10" height="10" viewBox="0 0 10 10" fill="none"><path d="M2 5 L4 7 L8 3" stroke="white" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </div>
              <h3 class="font-heading font-bold text-charcoal">Best For</h3>
            </div>
            <ul class="space-y-2">
              {goodFit.map((item) => (
                <li class="flex items-start gap-2 text-sm text-slate">
                  <span class="text-deep-green mt-0.5 flex-shrink-0">•</span>{item}
                </li>
              ))}
            </ul>
          </div>
        </div>
        <div class="sunlit-card p-6 flex gap-5">
          <div class="flex-shrink-0 w-28 h-28 rounded-xl overflow-hidden">
            <img src="/images/projects/hangzhou-xianghu-arcadia-villa/sunlit-solar-slate-roof-tiles-xianghu-details.webp" alt="Considerations" class="w-full h-full object-cover"/>
          </div>
          <div>
            <div class="flex items-center gap-2 mb-3">
              <div class="w-5 h-5 rounded-full bg-amber flex items-center justify-center">
                <svg width="10" height="10" viewBox="0 0 10 10" fill="none"><path d="M5 3 L5 6" stroke="#1a1a1a" stroke-width="1.4" stroke-linecap="round"/><circle cx="5" cy="8" r="0.6" fill="#1a1a1a"/></svg>
              </div>
              <h3 class="font-heading font-bold text-charcoal">Consider Before Choosing</h3>
            </div>
            <ul class="space-y-2">
              {considerations.map((item) => (
                <li class="flex items-start gap-2 text-sm text-slate">
                  <span class="text-slate mt-0.5 flex-shrink-0">•</span>{item}
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- MODELS & KEY PARAMETERS -->
  <section class="py-16 md:py-20 bg-white">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-end justify-between mb-8">
        <h2 class="font-heading font-bold text-2xl md:text-3xl text-charcoal">Models & Key Parameters</h2>
        <p class="text-slate text-sm hidden md:block">Multiple options to match different project needs.</p>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5">
        {modelSpecs.map((m) => (
          <div class="sunlit-card p-5">
            <div class="flex items-center justify-between mb-3">
              <h4 class="font-heading font-bold text-charcoal text-sm">{m.name}</h4>
              <span class={`text-xs font-heading font-bold px-2 py-0.5 rounded-full ${m.badgeColor}`}>{m.badge}</span>
            </div>
            <div class="h-28 rounded-xl overflow-hidden mb-4">
              <img src={m.image} alt={m.name} class="w-full h-full object-cover"/>
            </div>
            <div class="space-y-1.5">
              {m.specs.map((s) => (
                <div class="flex justify-between">
                  <span class="text-slate text-xs">{s.label}</span>
                  <span class="font-heading font-semibold text-charcoal text-xs">{s.value}</span>
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- SAMPLES, DATASHEETS & QUOTATION SUPPORT -->
  <section class="py-16 md:py-20 bg-light-gray border-y border-border">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="mb-8">
        <h2 class="font-heading font-bold text-2xl md:text-3xl text-charcoal">Samples, Datasheets & Quotation Support</h2>
        <p class="text-slate mt-1 text-sm">We support your evaluation and project planning every step of the way.</p>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-4">
        {docSupport.map((d) => (
          <div class="sunlit-card p-5 flex flex-col items-start gap-3">
            <div class="w-10 h-10 rounded-xl bg-soft-green flex items-center justify-center text-deep-green" set:html={d.icon} />
            <div>
              <h4 class="font-heading font-bold text-charcoal text-sm leading-tight">{d.title}</h4>
              <p class="text-slate text-xs mt-1 leading-snug">{d.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA BANNER -->
  <section class="py-16 md:py-20 dark-green-gradient text-white relative overflow-hidden">
    <div class="absolute inset-0 opacity-20">
      <img src="/images/projects/hangzhou-xianghu-arcadia-villa/sunlit-solar-slate-installed-texture-close-up.webp" alt="" class="w-full h-full object-cover"/>
    </div>
    <div class="relative container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-[1fr_auto] gap-8 items-center">
        <div>
          <p class="text-white/60 text-xs font-heading font-bold uppercase tracking-widest mb-3">Ready to Start</p>
          <h2 class="font-heading font-bold text-3xl md:text-4xl text-white mb-3">Discuss Your Lumina Slate Project</h2>
          <p class="text-white/75 text-sm leading-relaxed max-w-xl">Tell us about your project and our team will help you find the right solution. Share a roof photo, estimated area or drawings — no pressure, just expert advice.</p>
        </div>
        <div class="flex flex-col sm:flex-row lg:flex-col gap-3">
          <a href="/contact/" class="sunlit-btn-primary whitespace-nowrap">Request Product Details →</a>
          <a href="/contact/" class="border border-white/40 text-white rounded-full px-6 py-3 font-heading font-bold text-sm hover:bg-white/10 transition-colors text-center whitespace-nowrap">Send Us a Message →</a>
        </div>
      </div>
      <div class="mt-10 pt-8 border-t border-white/20 grid grid-cols-2 md:grid-cols-4 gap-4">
        {trustItems.map((t) => (
          <div class="flex items-center gap-2 text-white/80">
            <span class="text-white/60" set:html={t.icon} />
            <span class="text-xs font-heading font-semibold">{t.label}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

</Layout>
