---
import Layout from '../layouts/Layout.astro';
import { getComponentsBySystem } from '../data/systemComponents';
import { productFAQs, generalFAQs } from '../data/faqs';

const components = getComponentsBySystem('Lumina Slate');
const displayFaqs = [...productFAQs, ...generalFAQs].slice(0, 5);
const heroImage = "https://d2xsxph8kpxj0f.cloudfront.net/310519663705242844/mtvS4X69r9pvLdqcQTXPeQ/lumina-slate-hero-dFoW7mbWnUAgHmoQ6n9iPk.webp";

const specs = [
  ["Factory Role", "China manufacturer and export supplier"],
  ["Product Line", "Premium slate-look glass solar roof tiles"],
  ["Active Element", "AG-etched frameless double-glass PV roof tiles"],
  ["Inactive Element", "Matching glass inactive roof tiles"],
  ["Best Fit", "Villas, premium residential roofs, architectural projects"],
  ["Documents", "Datasheets and warranty documents available upon request"],
];

const applications = ["Premium villas", "High-end residential roofs", "Architectural projects", "Distributors and project buyers"];
---

<Layout title="Lumina Slate Solar Roof Tiles - China Manufacturer">
  <section class="border-b border-[var(--border)] bg-white">
    <div class="container mx-auto px-4 py-4 text-sm text-[var(--slate)]">
      <a href="/" class="hover:text-[var(--deep-green)]">Home</a>
      <span class="mx-2">/</span>
      <a href="/system-overview/" class="hover:text-[var(--deep-green)]">Solar Roof Supply Scope</a>
      <span class="mx-2">/</span>
      <span class="font-bold text-[var(--charcoal)]">Lumina Slate</span>
    </div>
  </section>

  <section class="bg-[#f8faf8] py-14 md:py-20">
    <div class="container mx-auto px-4">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div>
          <p class="sunlit-overline mb-4">China Manufacturer · Premium Glass Solar Roof Tiles</p>
          <h1 class="sunlit-section-title text-4xl md:text-6xl mb-6">Lumina Slate Glass Solar Roof Tiles for Overseas Projects</h1>
          <p class="text-lg md:text-xl text-[var(--slate)] leading-relaxed mb-8">
            Factory supply of AG-etched frameless double-glass PV roof tiles, matching glass inactive tiles, flashing, fixings and accessories for premium villas, residential developments and architectural projects.
          </p>
          <div class="flex flex-col sm:flex-row gap-3 mb-8">
            <a href="/contact/" class="sunlit-btn-primary">Get Factory Quote <span>→</span></a>
            <a href="/resources/" class="sunlit-btn-secondary">Request Datasheet</a>
          </div>
          <div class="grid grid-cols-3 gap-3">
            <div class="stat-pill p-4"><div class="font-extrabold text-[var(--deep-green)]">China Factory</div><div class="text-xs text-[var(--slate)]">Export supply</div></div>
            <div class="stat-pill p-4"><div class="font-extrabold text-[var(--deep-green)]">Active + Inactive</div><div class="text-xs text-[var(--slate)]">Package scope</div></div>
            <div class="stat-pill p-4"><div class="font-extrabold text-[var(--deep-green)]">Premium Glass</div><div class="text-xs text-[var(--slate)]">Slate-like finish</div></div>
          </div>
        </div>
        <div class="sunlit-card overflow-hidden p-3">
          <img src={heroImage} alt="Lumina Slate glass solar roof tiles from China manufacturer" class="w-full h-[420px] object-cover rounded-2xl" />
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 md:py-24 bg-white">
    <div class="container mx-auto px-4">
      <div class="grid lg:grid-cols-3 gap-10 items-start">
        <div>
          <p class="sunlit-overline mb-3">What We Supply</p>
          <h2 class="sunlit-section-title text-3xl md:text-4xl mb-4">Premium Glass Solar Roof Tile Supply, Not a Vague Turnkey Claim</h2>
          <p class="text-[var(--slate)] leading-relaxed">
            Lumina Slate is presented as a factory-supplied product package. Sunlit supplies the active and inactive roof elements and related accessories. Local roof and electrical work should be handled by qualified local professionals.
          </p>
        </div>
        <div class="lg:col-span-2 grid sm:grid-cols-2 gap-5">
          <div class="sunlit-card p-6">
            <div class="h-32 image-placeholder rounded-2xl mb-5"></div>
            <h3 class="font-extrabold text-xl mb-2">Active PV Roof Tile</h3>
            <p class="text-[var(--slate)] leading-relaxed">AG-etched frameless double-glass PV roof tiles provide solar generation while keeping a slate-like roof appearance.</p>
          </div>
          <div class="sunlit-card p-6">
            <div class="h-32 image-placeholder rounded-2xl mb-5"></div>
            <h3 class="font-extrabold text-xl mb-2">Matching Inactive Tile</h3>
            <p class="text-[var(--slate)] leading-relaxed">Matching glass inactive tiles cover non-generating roof areas and help the full roof keep a consistent appearance.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 md:py-24 bg-[#f8faf8]">
    <div class="container mx-auto px-4">
      <div class="text-center max-w-3xl mx-auto mb-12">
        <p class="sunlit-overline mb-3">Factory Supply Package</p>
        <h2 class="sunlit-section-title text-3xl md:text-5xl mb-4">What the Lumina Slate Package May Include</h2>
        <p class="text-[var(--slate)]">Component details are evaluated by project. The following structure helps overseas buyers understand the factory supply scope before requesting a quotation.</p>
      </div>
      <div class="grid md:grid-cols-2 lg:grid-cols-5 gap-5">
        {components.map((component, index) => (
          <div class="sunlit-card p-5">
            <div class="text-xs font-extrabold text-[var(--deep-green)] mb-3">0{index + 1}</div>
            <h3 class="font-extrabold text-[var(--charcoal)] mb-2">{component.name}</h3>
            <p class="text-sm text-[var(--slate)] leading-relaxed">{component.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16 md:py-24 bg-white">
    <div class="container mx-auto px-4">
      <div class="grid lg:grid-cols-2 gap-10">
        <div>
          <p class="sunlit-overline mb-3">Early Evaluation</p>
          <h2 class="sunlit-section-title text-3xl md:text-4xl mb-4">Key Information for Factory Quotation</h2>
          <p class="text-[var(--slate)] mb-6">Final specifications depend on roof layout, active and inactive coverage, selected components and destination. Detailed datasheets are available upon request.</p>
          <a href="/contact/" class="sunlit-btn-green">Send Roof Drawing <span>→</span></a>
        </div>
        <div class="sunlit-card overflow-hidden">
          {specs.map(([label, value]) => (
            <div class="grid grid-cols-3 gap-4 p-4 border-b border-[var(--border)] last:border-b-0">
              <div class="font-extrabold text-[var(--charcoal)]">{label}</div>
              <div class="col-span-2 text-[var(--slate)]">{value}</div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 bg-[#f8faf8]">
    <div class="container mx-auto px-4">
      <p class="sunlit-overline text-center mb-3">Suitable Projects</p>
      <div class="grid md:grid-cols-4 gap-4">
        {applications.map((app) => (
          <div class="sunlit-card-soft p-6 text-center font-extrabold text-[var(--charcoal)]">{app}</div>
        ))}
      </div>
    </div>
  </section>

  <section id="faq" class="py-16 md:py-24 bg-white">
    <div class="container mx-auto px-4 max-w-4xl">
      <h2 class="sunlit-section-title text-3xl md:text-5xl mb-10 text-center">Lumina Slate FAQ</h2>
      <div class="space-y-4">
        {displayFaqs.map((faq) => (
          <div class="border border-[var(--border)] rounded-2xl p-6">
            <h3 class="font-extrabold text-[var(--charcoal)] mb-2">{faq.question}</h3>
            <p class="text-[var(--slate)] leading-relaxed">{faq.answer}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16 md:py-20 dark-green-gradient text-white">
    <div class="container mx-auto px-4 text-center">
      <h2 class="text-3xl md:text-5xl font-extrabold mb-5">Evaluate Lumina Slate for Your Project</h2>
      <p class="text-lg text-white/75 max-w-2xl mx-auto mb-8">Send your roof drawing, country and estimated roof area. We will help discuss active and inactive coverage, accessory scope and factory quotation direction.</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/contact/" class="sunlit-btn-primary">Get Lumina Factory Quote <span>→</span></a>
        <a href="/projects/" class="border border-white/60 text-white rounded-full px-6 py-3 font-extrabold hover:bg-white/10">View Projects</a>
      </div>
    </div>
  </section>
</Layout>
