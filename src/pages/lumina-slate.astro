---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import { activeTileSpecs, sharedActiveTilePerformance } from '../data/productSpecs';
import { luminaSlateComponents, sharedComponents } from '../data/componentAssets';
import { projects } from '../data/projects';

const spec = activeTileSpecs.luminaSlate;

const luminaProjects = projects.filter((p: any) => p.system === 'Lumina Slate');
const heroProject = projects.find((p: any) => p.slug === 'hangzhou-xianghu-arcadia-villa');
const nanshan = projects.find((p: any) => p.slug === 'nanjing-nanshan-lake');
const beijing = projects.find((p: any) => p.slug === 'beijing-new-world-lizun');

const coreComponents = luminaSlateComponents.filter((c: any) => c.group === 'core');
const trimComponents = luminaSlateComponents.filter((c: any) => c.group === 'trim-flashing');
const accessoryComponents = luminaSlateComponents.filter((c: any) => c.group === 'accessory');
---

<Layout title="Lumina Slate — Premium Glass Solar Roof Tiles | Sunlit Solar Roof" description="Lumina Slate is a premium double-glass BIPV solar roof tile line for high-end villas and architectural projects. 70W per tile, IP68, Grade A fire rating. Factory direct from China.">
  <Navigation />

  <!-- HERO -->
  <section class="relative h-[90vh] min-h-[600px] overflow-hidden">
    <img
      src="/images/projects/hangzhou-xianghu-arcadia-villa/sunlit-bipv-solar-roof-aerial-view-hangzhou-xianghu.webp"
      alt="Lumina Slate solar roof tiles installed on Hangzhou Xianghu Arcadia Villa"
      class="absolute inset-0 w-full h-full object-cover"
    />
    <div class="absolute inset-0 bg-gradient-to-r from-black/75 via-black/40 to-transparent"></div>
    <div class="relative z-10 h-full flex items-end pb-16 md:pb-24">
      <div class="max-w-7xl mx-auto px-6 w-full">
        <div class="max-w-2xl">
          <p class="text-amber-400 text-sm font-semibold tracking-widest uppercase mb-4">Premium Glass Solar Roof Tile</p>
          <h1 class="text-white text-5xl md:text-6xl font-bold leading-tight mb-6">Lumina Slate</h1>
          <p class="text-white/80 text-xl mb-8 leading-relaxed">
            A double-glass BIPV tile line engineered for high-end villas, heritage-sensitive roofs and architecture-led projects where aesthetics and performance must coexist.
          </p>
          <div class="flex flex-wrap gap-6 mb-10">
            <div class="text-white">
              <div class="text-3xl font-bold text-amber-400">{spec.powerPmax}</div>
              <div class="text-sm text-white/60 mt-1">Per Active Tile</div>
            </div>
            <div class="w-px bg-white/20 self-stretch"></div>
            <div class="text-white">
              <div class="text-3xl font-bold text-amber-400">IP68</div>
              <div class="text-sm text-white/60 mt-1">Waterproof Rating</div>
            </div>
            <div class="w-px bg-white/20 self-stretch"></div>
            <div class="text-white">
              <div class="text-3xl font-bold text-amber-400">Grade A</div>
              <div class="text-sm text-white/60 mt-1">Fire Rating</div>
            </div>
            <div class="w-px bg-white/20 self-stretch"></div>
            <div class="text-white">
              <div class="text-3xl font-bold text-amber-400">16+</div>
              <div class="text-sm text-white/60 mt-1">Completed Projects</div>
            </div>
          </div>
          <div class="flex flex-wrap gap-4">
            <a href="/contact/" class="inline-flex items-center gap-2 bg-amber-500 hover:bg-amber-400 text-black font-semibold px-7 py-3.5 rounded-lg transition-colors">
              Request Sample or Quote
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
            </a>
            <a href="#component-library" class="inline-flex items-center gap-2 border border-white/40 hover:border-white text-white font-medium px-7 py-3.5 rounded-lg transition-colors">
              View Components
            </a>
          </div>
        </div>
      </div>
    </div>
    <div class="absolute bottom-4 right-6 text-white/40 text-xs">Hangzhou Xianghu Arcadia Villa · Lumina Slate Installation</div>
  </section>

  <!-- TRUST BAR -->
  <section class="bg-[#1a2e1a] border-b border-white/10">
    <div class="max-w-7xl mx-auto px-6 py-5">
      <div class="grid grid-cols-2 md:grid-cols-5 gap-4 text-center">
        {[
          { icon: '⚡', label: '70W per tile', sub: 'Monocrystalline PERC' },
          { icon: '💧', label: 'IP68 rated', sub: 'Structural waterproof' },
          { icon: '🔥', label: 'Grade A fire', sub: '≥5400Pa mechanical load' },
          { icon: '🌪️', label: '35mm hail', sub: 'Typhoon-level wind resist.' },
          { icon: '🏗️', label: '16+ projects', sub: 'Factory direct, B2B' },
        ].map(item => (
          <div class="flex flex-col items-center gap-1 py-2">
            <span class="text-xl">{item.icon}</span>
            <span class="text-white font-semibold text-sm">{item.label}</span>
            <span class="text-white/50 text-xs">{item.sub}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ACTIVE + INACTIVE SYSTEM -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-6">
      <div class="text-center mb-14">
        <p class="text-[#2d5a27] text-sm font-semibold tracking-widest uppercase mb-3">How the System Works</p>
        <h2 class="text-4xl font-bold text-gray-900 mb-4">Active Tiles + Inactive Tiles</h2>
        <p class="text-gray-500 max-w-2xl mx-auto">Every Lumina Slate roof uses a mix of power-generating active tiles and matching non-generating inactive tiles. This is what makes the roof look uniform while generating electricity.</p>
      </div>
      <div class="grid md:grid-cols-2 gap-8">
        <div class="bg-gray-50 rounded-2xl overflow-hidden">
          <div class="aspect-[4/3] bg-gray-100 flex items-center justify-center p-10">
            <img src="/images/components/lumina-slate/active-solar-tile.webp" alt="Lumina Slate Active Solar Tile" class="w-full h-full object-contain" />
          </div>
          <div class="p-8">
            <div class="flex items-center gap-3 mb-4">
              <span class="bg-[#2d5a27] text-white text-xs font-bold px-3 py-1 rounded-full">GENERATES POWER</span>
            </div>
            <h3 class="text-2xl font-bold text-gray-900 mb-3">Active Solar Tile</h3>
            <p class="text-gray-500 mb-6 leading-relaxed">{luminaSlateComponents.find((c: any) => c.id === 'lumina-active-solar-tile')?.shortDescription}</p>
            <div class="grid grid-cols-2 gap-3">
              {luminaSlateComponents.find((c: any) => c.id === 'lumina-active-solar-tile')?.keySpecs?.map((s: any) => (
                <div class="bg-white rounded-lg p-3 border border-gray-100">
                  <div class="text-xs text-gray-400 mb-1">{s.label}</div>
                  <div class="font-semibold text-gray-900 text-sm">{s.value}</div>
                </div>
              ))}
              <div class="bg-white rounded-lg p-3 border border-gray-100">
                <div class="text-xs text-gray-400 mb-1">Encapsulation</div>
                <div class="font-semibold text-gray-900 text-sm">{spec.encapsulation}</div>
              </div>
              <div class="bg-white rounded-lg p-3 border border-gray-100">
                <div class="text-xs text-gray-400 mb-1">Module Efficiency</div>
                <div class="font-semibold text-gray-900 text-sm">{spec.moduleEfficiency}</div>
              </div>
            </div>
          </div>
        </div>

        <div class="bg-gray-50 rounded-2xl overflow-hidden">
          <div class="aspect-[4/3] bg-gray-100 grid grid-cols-3 gap-3 p-6">
            {['lumina-inactive-half-tile-uncuttable', 'lumina-inactive-half-tile-cuttable', 'lumina-inactive-quarter-tile'].map((id: string) => {
              const comp = luminaSlateComponents.find((c: any) => c.id === id);
              return comp ? (
                <div class="bg-white rounded-xl flex items-center justify-center p-3">
                  <img src={comp.image} alt={comp.name} class="w-full h-full object-contain" />
                </div>
              ) : null;
            })}
          </div>
          <div class="p-8">
            <div class="flex items-center gap-3 mb-4">
              <span class="bg-gray-400 text-white text-xs font-bold px-3 py-1 rounded-full">MATCHING APPEARANCE</span>
            </div>
            <h3 class="text-2xl font-bold text-gray-900 mb-3">Inactive Tiles (3 Sizes)</h3>
            <p class="text-gray-500 mb-6 leading-relaxed">Three sizes of non-generating glass tiles — half (uncuttable), half (cuttable), and quarter — allow any roof geometry to be completed with a uniform appearance. No visible difference from the active tiles.</p>
            <div class="space-y-3">
              {['lumina-inactive-half-tile-uncuttable', 'lumina-inactive-half-tile-cuttable', 'lumina-inactive-quarter-tile'].map((id: string) => {
                const comp = luminaSlateComponents.find((c: any) => c.id === id);
                return comp ? (
                  <div class="flex items-start gap-3">
                    <div class="w-2 h-2 rounded-full bg-[#2d5a27] mt-2 flex-shrink-0"></div>
                    <div>
                      <span class="font-semibold text-gray-800 text-sm">{comp.name}</span>
                      <span class="text-gray-400 text-sm"> — {comp.shortDescription}</span>
                    </div>
                  </div>
                ) : null;
              })}
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- COMPONENT LIBRARY -->
  <section id="component-library" class="py-20 bg-[#f7f9f7]">
    <div class="max-w-7xl mx-auto px-6">
      <div class="text-center mb-14">
        <p class="text-[#2d5a27] text-sm font-semibold tracking-widest uppercase mb-3">Complete System</p>
        <h2 class="text-4xl font-bold text-gray-900 mb-4">Component Library</h2>
        <p class="text-gray-500 max-w-2xl mx-auto">Every component in the Lumina Slate system is factory-produced and supplied together. No sourcing gaps, no compatibility surprises on site.</p>
      </div>

      <div class="mb-10">
        <h3 class="text-xs font-bold text-gray-400 tracking-widest uppercase mb-5 border-b border-gray-200 pb-3">Core Tiles</h3>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
          {coreComponents.map((comp: any) => (
            <div class="bg-white rounded-xl overflow-hidden border border-gray-100 hover:shadow-md transition-shadow">
              <div class="aspect-square bg-gray-50 flex items-center justify-center p-6">
                <img src={comp.image} alt={comp.name} class="w-full h-full object-contain" />
              </div>
              <div class="p-4">
                <div class="font-semibold text-gray-900 text-sm mb-1">{comp.name}</div>
                {comp.chineseName && <div class="text-gray-400 text-xs mb-2">{comp.chineseName}</div>}
                <p class="text-gray-500 text-xs leading-relaxed">{comp.shortDescription}</p>
                {comp.keySpecs && comp.keySpecs.length > 0 && (
                  <div class="mt-3 pt-3 border-t border-gray-100 space-y-1">
                    {comp.keySpecs.map((s: any) => (
                      <div class="flex justify-between text-xs">
                        <span class="text-gray-400">{s.label}</span>
                        <span class="font-medium text-gray-700">{s.value}</span>
                      </div>
                    ))}
                  </div>
                )}
              </div>
            </div>
          ))}
        </div>
      </div>

      <div class="mb-10">
        <h3 class="text-xs font-bold text-gray-400 tracking-widest uppercase mb-5 border-b border-gray-200 pb-3">Trim & Flashing</h3>
        <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-5 gap-4">
          {trimComponents.map((comp: any) => (
            <div class="bg-white rounded-xl overflow-hidden border border-gray-100 hover:shadow-md transition-shadow">
              <div class="aspect-square bg-gray-50 flex items-center justify-center p-5">
                <img src={comp.image} alt={comp.name} class="w-full h-full object-contain" />
              </div>
              <div class="p-4">
                <div class="font-semibold text-gray-900 text-sm mb-1">{comp.name}</div>
                {comp.chineseName && <div class="text-gray-400 text-xs mb-2">{comp.chineseName}</div>}
                <p class="text-gray-500 text-xs leading-relaxed">{comp.shortDescription}</p>
              </div>
            </div>
          ))}
        </div>
      </div>

      <div>
        <h3 class="text-xs font-bold text-gray-400 tracking-widest uppercase mb-5 border-b border-gray-200 pb-3">Accessories & Base Layer</h3>
        <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-5 gap-4">
          {[...accessoryComponents, ...sharedComponents].map((comp: any) => (
            <div class="bg-white rounded-xl overflow-hidden border border-gray-100 hover:shadow-md transition-shadow">
              <div class="aspect-square bg-gray-50 flex items-center justify-center p-5">
                <img src={comp.image} alt={comp.name} class="w-full h-full object-contain" />
              </div>
              <div class="p-4">
                <div class="font-semibold text-gray-900 text-sm mb-1">{comp.name}</div>
                {comp.chineseName && <div class="text-gray-400 text-xs mb-2">{comp.chineseName}</div>}
                <p class="text-gray-500 text-xs leading-relaxed">{comp.shortDescription}</p>
                {comp.keySpecs && comp.keySpecs.length > 0 && (
                  <div class="mt-3 pt-3 border-t border-gray-100 space-y-1">
                    {comp.keySpecs.map((s: any) => (
                      <div class="flex justify-between text-xs">
                        <span class="text-gray-400">{s.label}</span>
                        <span class="font-medium text-gray-700">{s.value}</span>
                      </div>
                    ))}
                  </div>
                )}
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- REAL PROJECT PROOF -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-6">
      <div class="text-center mb-14">
        <p class="text-[#2d5a27] text-sm font-semibold tracking-widest uppercase mb-3">Proven in the Field</p>
        <h2 class="text-4xl font-bold text-gray-900 mb-4">Real Project Evidence</h2>
        <p class="text-gray-500 max-w-2xl mx-auto">These are completed, installed projects — not renders. Every image is from an actual Lumina Slate installation.</p>
      </div>

      {heroProject && (
        <div class="mb-8 rounded-2xl overflow-hidden group">
          <div class="grid md:grid-cols-3 h-[480px]">
            <div class="md:col-span-2 overflow-hidden">
              <img
                src="/images/projects/hangzhou-xianghu-arcadia-villa/sunlit-completed-solar-tile-roof-xianghu-villa.webp"
                alt={heroProject.title}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
              />
            </div>
            <div class="bg-[#1a2e1a] p-10 flex flex-col justify-between">
              <div>
                <span class="text-amber-400 text-xs font-bold tracking-widest uppercase">Lumina Slate</span>
                <h3 class="text-white text-2xl font-bold mt-3 mb-4 leading-snug">{heroProject.title}</h3>
                <p class="text-white/60 text-sm leading-relaxed mb-6">{heroProject.overview}</p>
                <div class="grid grid-cols-2 gap-3">
                  {heroProject.roofArea && (
                    <div class="bg-white/10 rounded-lg p-3">
                      <div class="text-white/40 text-xs mb-1">Roof Area</div>
                      <div class="text-white font-semibold text-sm">{heroProject.roofArea}</div>
                    </div>
                  )}
                  {heroProject.capacity && (
                    <div class="bg-white/10 rounded-lg p-3">
                      <div class="text-white/40 text-xs mb-1">Capacity</div>
                      <div class="text-white font-semibold text-sm">{heroProject.capacity}</div>
                    </div>
                  )}
                </div>
              </div>
              <a href={`/projects/${heroProject.slug}/`} class="inline-flex items-center gap-2 text-amber-400 hover:text-amber-300 font-medium text-sm transition-colors mt-6">
                View Full Project
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
              </a>
            </div>
          </div>
        </div>
      )}

      <div class="grid md:grid-cols-2 gap-8 mb-10">
        {[nanshan, beijing].filter(Boolean).map((proj: any) => proj && (
          <div class="rounded-2xl overflow-hidden bg-gray-50 group">
            <div class="h-64 overflow-hidden">
              <img src={proj.images[0]} alt={proj.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" />
            </div>
            <div class="p-7">
              <span class="text-[#2d5a27] text-xs font-bold tracking-widest uppercase">Lumina Slate</span>
              <h3 class="text-gray-900 text-xl font-bold mt-2 mb-3">{proj.title}</h3>
              <p class="text-gray-500 text-sm leading-relaxed mb-5">{proj.overview}</p>
              <div class="flex gap-4 mb-5">
                {proj.roofArea && (
                  <div>
                    <div class="text-gray-400 text-xs">Roof Area</div>
                    <div class="font-semibold text-gray-800 text-sm">{proj.roofArea}</div>
                  </div>
                )}
                {proj.capacity && (
                  <div>
                    <div class="text-gray-400 text-xs">Capacity</div>
                    <div class="font-semibold text-gray-800 text-sm">{proj.capacity}</div>
                  </div>
                )}
              </div>
              <a href={`/projects/${proj.slug}/`} class="inline-flex items-center gap-2 text-[#2d5a27] hover:text-[#1a4d16] font-medium text-sm transition-colors">View Full Project →</a>
            </div>
          </div>
        ))}
      </div>

      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        {luminaProjects.filter((p: any) => !['hangzhou-xianghu-arcadia-villa', 'nanjing-nanshan-lake', 'beijing-new-world-lizun'].includes(p.slug)).slice(0, 4).map((proj: any) => (
          <a href={`/projects/${proj.slug}/`} class="group relative rounded-xl overflow-hidden aspect-[4/3]">
            <img src={proj.images[0]} alt={proj.title} class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" />
            <div class="absolute inset-0 bg-gradient-to-t from-black/70 to-transparent"></div>
            <div class="absolute bottom-0 left-0 right-0 p-4">
              <div class="text-white font-semibold text-sm leading-tight">{proj.title}</div>
              {proj.location && <div class="text-white/60 text-xs mt-1">{proj.location}</div>}
            </div>
          </a>
        ))}
      </div>

      <div class="text-center mt-10">
        <a href="/projects/" class="inline-flex items-center gap-2 border border-[#2d5a27] text-[#2d5a27] hover:bg-[#2d5a27] hover:text-white font-medium px-8 py-3.5 rounded-lg transition-colors">
          View All Lumina Slate Projects →
        </a>
      </div>
    </div>
  </section>

  <!-- INSTALLATION PROOF -->
  <section class="py-20 bg-[#f7f9f7]">
    <div class="max-w-7xl mx-auto px-6">
      <div class="text-center mb-14">
        <p class="text-[#2d5a27] text-sm font-semibold tracking-widest uppercase mb-3">Installation Evidence</p>
        <h2 class="text-4xl font-bold text-gray-900 mb-4">How It Goes On the Roof</h2>
        <p class="text-gray-500 max-w-2xl mx-auto">Three-phase installation process documented from real project sites. These are not animations — they are actual installation footage.</p>
      </div>
      <div class="grid md:grid-cols-3 gap-6">
        {[
          { step: '01', title: 'Roof Base Preparation', desc: 'Waterproof breathable membrane, foil radiant barrier and treated wood battens are laid before any tile is placed.', poster: '/videos/installation/lumina-slate/01_Roof_base-poster.webp', video: '/videos/installation/lumina-slate/01_Roof_base.mp4' },
          { step: '02', title: 'Tile Installation', desc: 'Active and inactive tiles are laid in an overlapping staggered pattern. Wind uplift clips anchor each tile without drilling.', poster: '/videos/installation/lumina-slate/02_Installing _Tiles-poster.webp', video: '/videos/installation/lumina-slate/02_Installing _Tiles.mp4' },
          { step: '03', title: 'Solar Wiring', desc: 'MC4 connectors link tiles in series. All wiring runs under the tile layer — invisible from the exterior.', poster: '/videos/installation/lumina-slate/03_Solar_Tiles_Wiring-poster.webp', video: '/videos/installation/lumina-slate/03_Solar_Tiles_Wiring.mp4' },
        ].map(item => (
          <div class="bg-white rounded-2xl overflow-hidden shadow-sm">
            <div class="relative aspect-video bg-gray-900 cursor-pointer group" onclick="const v=this.nextElementSibling;v.style.display='block';this.style.display='none';v.play();">
              <img src={item.poster} alt={item.title} class="w-full h-full object-cover opacity-90" />
              <div class="absolute inset-0 flex items-center justify-center">
                <div class="w-16 h-16 bg-white/90 rounded-full flex items-center justify-center shadow-lg group-hover:scale-110 transition-transform">
                  <svg class="w-6 h-6 text-[#2d5a27] ml-1" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
                </div>
              </div>
              <div class="absolute top-4 left-4 bg-[#2d5a27] text-white text-xs font-bold px-3 py-1 rounded-full">{item.step}</div>
            </div>
            <video controls class="w-full aspect-video hidden" poster={item.poster}>
              <source src={item.video} type="video/mp4" />
            </video>
            <div class="p-6">
              <h3 class="font-bold text-gray-900 text-lg mb-2">{item.title}</h3>
              <p class="text-gray-500 text-sm leading-relaxed">{item.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- TESTING PROOF -->
  <section class="py-20 bg-[#1a2e1a]">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid md:grid-cols-2 gap-16 items-center">
        <div>
          <p class="text-amber-400 text-sm font-semibold tracking-widest uppercase mb-4">Quality Evidence</p>
          <h2 class="text-white text-4xl font-bold mb-6 leading-tight">Impact Resistance<br/>Tested on Camera</h2>
          <p class="text-white/60 text-lg mb-8 leading-relaxed">The Lumina Slate active tile is tested to resist 35mm hailstone impact. Watch the actual test footage — not a spec sheet claim.</p>
          <div class="grid grid-cols-2 gap-4 mb-8">
            {sharedActiveTilePerformance.map((item: any) => (
              <div class="bg-white/10 rounded-xl p-4">
                <div class="text-white/50 text-xs mb-1">{item.label}</div>
                <div class="text-white font-semibold">{item.value}</div>
              </div>
            ))}
          </div>
          <a href="/contact/" class="inline-flex items-center gap-2 bg-amber-500 hover:bg-amber-400 text-black font-semibold px-7 py-3.5 rounded-lg transition-colors">Request Datasheet</a>
        </div>
        <div class="relative">
          <div class="rounded-2xl overflow-hidden bg-black aspect-video relative cursor-pointer group" onclick="const v=this.querySelector('video');const o=this.querySelector('.play-overlay');v.style.display='block';o.style.display='none';v.play();">
            <img src="/videos/testing/Lumina slate 抗冲击-poster.webp" alt="Lumina Slate impact resistance test" class="w-full h-full object-cover" />
            <div class="play-overlay absolute inset-0 flex items-center justify-center">
