---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Thank You - Sunlit Solar Roof" description="Your inquiry has been received. We will respond shortly.">
  <section class="bg-soft-green py-20 md:py-32">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 text-center max-w-2xl">
      <div class="w-20 h-20 rounded-full bg-white text-deep-green flex items-center justify-center mx-auto mb-6">
        <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
      </div>
      <h1 class="sunlit-section-title text-4xl md:text-5xl text-charcoal mb-4">Thank You for Your Inquiry</h1>
      <p class="text-lg text-slate leading-relaxed mb-8">
        We have received your message and will respond within 1-2 business days. For urgent matters, please email <a href="mailto:info@sunlitsolarroof.com" class="text-deep-green font-bold hover:text-amber">info@sunlitsolarroof.com</a>.
      </p>
      <a href="/" class="sunlit-btn-primary">Return to Homepage</a>
    </div>
  </section>
</Layout>
