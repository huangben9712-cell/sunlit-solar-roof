---
import Layout from '../layouts/Layout.astro';
import { projects } from '../data/projects';
import { generalFAQs } from '../data/faqs';
const faqs = generalFAQs.slice(0, 5);

const ASSETS = {
  luminaSlateHero: "https://d2xsxph8kpxj0f.cloudfront.net/310519663705242844/mtvS4X69r9pvLdqcQTXPeQ/lumina-slate-hero-dFoW7mbWnUAgHmoQ6n9iPk.webp",
  stormGuardHero: "https://d2xsxph8kpxj0f.cloudfront.net/310519663705242844/mtvS4X69r9pvLdqcQTXPeQ/storm-guard-hero-Rv3C82SNHYaBM2TVgU4t7W.webp",
};

// Proof Behind the Product — icon cards
const proofCards = [
  {
    label: 'Factory',
    title: 'In-House Production',
    desc: 'Active PV tiles and metal sheets manufactured in our own factory. Direct supply, no middlemen.',
    href: '/system-overview/',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 48 48" stroke="currentColor" stroke-width="1.5" class="w-10 h-10"><rect x="6" y="20" width="36" height="22" rx="2" /><path d="M6 20l8-12h20l8 12" /><rect x="18" y="28" width="12" height="14" rx="1" /><path d="M14 28v14M34 28v14" /></svg>`,
  },
  {
    label: 'Components',
    title: 'Complete Package',
    desc: 'Every component from active tiles to ridge pieces, flashing and fixings — one factory, one shipment.',
    href: '/system-overview/',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 48 48" stroke="currentColor" stroke-width="1.5" class="w-10 h-10"><rect x="6" y="26" width="16" height="16" rx="2" /><rect x="26" y="26" width="16" height="16" rx="2" /><rect x="16" y="6" width="16" height="16" rx="2" /><path d="M14 26l10-4 10 4" /></svg>`,
  },
  {
    label: 'Projects',
    title: 'Delivered on Site',
    desc: 'Residential villas, commercial complexes and overseas projects — real installations, real results.',
    href: '/projects/',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 48 48" stroke="currentColor" stroke-width="1.5" class="w-10 h-10"><path d="M6 42V22l18-16 18 16v20" /><rect x="18" y="28" width="12" height="14" rx="1" /><path d="M6 22h36" /></svg>`,
  },
  {
    label: 'Testing',
    title: 'Verified Performance',
    desc: 'IP68 waterproofing, 35mm hail resistance, Grade A fire rating and typhoon-level wind load — tested and certified.',
    href: '/lumina-slate/',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 48 48" stroke="currentColor" stroke-width="1.5" class="w-10 h-10"><path d="M24 6l4 8 9 1.3-6.5 6.3 1.5 9L24 26l-8 4.6 1.5-9L11 15.3l9-1.3z" /><path d="M16 34l-8 8M32 34l8 8M24 30v6" /></svg>`,
  },
];

const audiences = [
  {
    title: "For Distributors",
    desc: "Source differentiated solar roof products with factory pricing and sample support.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 40 40" stroke="currentColor" stroke-width="1.5" class="w-8 h-8"><circle cx="20" cy="20" r="14" /><circle cx="20" cy="20" r="5" /><path d="M20 6v9M20 25v9M6 20h9M25 20h9" /></svg>`,
  },
  {
    title: "For Solar Installers",
    desc: "Offer integrated solar roof products when clients reject standard panels.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 40 40" stroke="currentColor" stroke-width="1.5" class="w-8 h-8"><path d="M8 32L20 8l12 24" /><path d="M12 24h16" /><path d="M20 8v4" /><circle cx="20" cy="6" r="2" /></svg>`,
  },
  {
    title: "For Roofing Contractors",
    desc: "Discuss roof-side product packages with active and inactive coverage.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 40 40" stroke="currentColor" stroke-width="1.5" class="w-8 h-8"><path d="M4 34V18l16-12 16 12v16" /><rect x="14" y="22" width="12" height="12" rx="1" /><path d="M4 18h32" /></svg>`,
  },
  {
    title: "For Developers",
    desc: "Evaluate solar roof packages for residential, commercial and premium projects.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 40 40" stroke="currentColor" stroke-width="1.5" class="w-8 h-8"><rect x="4" y="10" width="32" height="24" rx="2" /><path d="M4 18h32M14 10v24M4 26h10" /><path d="M20 22l4 4-4 4" /></svg>`,
  },
];
---
<Layout title="China Solar Roof Tile Manufacturer - Sunlit Solar Roof">

  <!-- ===== HERO ===== -->
  <section class="relative min-h-[90vh] flex items-end overflow-hidden">
    <div class="absolute inset-0">
      <video
        autoplay
        muted
        loop
        playsinline
        class="w-full h-full object-cover"
        poster="/images/projects/xuzhou-luxury-villa-the-ultimate-bipv-vs-bapv-contrast/sunlit-bipv-vs-bapv-solar-roof-comparison.webp"
      >
        <source src="/videos/hero/homepage-hero.mp4" type="video/mp4" />
        <img src="/images/projects/xuzhou-luxury-villa-the-ultimate-bipv-vs-bapv-contrast/sunlit-bipv-vs-bapv-solar-roof-comparison.webp" alt="Sunlit solar roof tiles installed on villa" class="w-full h-full object-cover" />
      </video>
      <div class="absolute inset-0 bg-gradient-to-r from-black/85 via-black/55 to-transparent"></div>
    </div>
    <div class="relative z-10 w-full pb-20 md:pb-28">
      <div class="max-w-7xl mx-auto px-6">
        <div class="max-w-2xl">
          <p class="text-amber text-sm font-semibold tracking-widest uppercase mb-5">China Solar Roof Tile Manufacturer</p>
          <h1 class="text-white text-5xl md:text-6xl lg:text-7xl font-bold leading-tight mb-6">
            Factory Supply for Complete Solar Roof Packages
          </h1>
          <p class="text-white/80 text-xl leading-relaxed mb-4 max-w-xl">
            Glass solar roof tiles + metal solar roof sheets. Active elements, inactive coverage, trim, flashing and fixings — factory direct, B2B.
          </p>
          <p class="text-white/55 text-base leading-relaxed mb-10 max-w-xl">
            Sunlit is a China-based manufacturer supplying distributors, installers, contractors and project developers in overseas markets.
          </p>
          <div class="flex flex-wrap gap-4">
            <a href="/contact/" class="inline-flex items-center gap-2 bg-amber hover:bg-amber-dark text-gray-900 font-bold px-8 py-4 rounded-lg transition-colors text-lg">
              Get Factory Pricing →
            </a>
            <a href="/system-overview/" class="inline-flex items-center gap-2 border border-white/40 hover:border-white text-white font-medium px-8 py-4 rounded-lg transition-colors text-lg">
              See Supply Scope
            </a>
          </div>
        </div>
      </div>
    </div>
    <!-- Hero stat strip -->
    <div class="absolute bottom-0 right-0 hidden lg:flex gap-0">
      {[
        { value: '2', unit: 'Product Lines', sub: 'Glass + Metal' },
        { value: '20+', unit: 'Delivered Projects', sub: 'China & Overseas' },
        { value: 'IP68', unit: 'Waterproof Rating', sub: 'Tested & Certified' },
      ].map(stat => (
        <div class="bg-black/50 backdrop-blur-sm border-l border-white/10 px-8 py-5 text-white">
          <div class="text-2xl font-bold">{stat.value}</div>
          <div class="text-xs font-semibold text-white/70 tracking-wide">{stat.unit}</div>
          <div class="text-xs text-white/40">{stat.sub}</div>
        </div>
      ))}
    </div>
  </section>

  <!-- ===== PROOF BEHIND THE PRODUCT ===== -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-6">
      <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-4 mb-12">
        <div>
          <p class="text-[#2d5a27] text-sm font-semibold tracking-widest uppercase mb-3">Proof Behind the Product</p>
          <h2 class="text-4xl font-bold text-gray-900">Factory, Components, Projects, Testing</h2>
        </div>
        <a href="/system-overview/" class="text-[#2d5a27] font-medium hover:underline whitespace-nowrap text-sm">See full supply scope →</a>
      </div>
      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-5">
        {proofCards.map(card => (
          <a href={card.href} class="group sunlit-card p-6 text-center hover:-translate-y-1 transition-transform block">
            <div class="w-14 h-14 rounded-2xl bg-soft-green text-deep-green flex items-center justify-center mx-auto mb-5" set:html={card.icon} />
            <p class="text-xs text-[#2d5a27] font-bold uppercase tracking-wider mb-2">{card.label}</p>
            <h3 class="text-gray-900 font-bold text-base mb-2">{card.title}</h3>
            <p class="text-gray-500 text-sm leading-relaxed">{card.desc}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== TWO PRODUCT LINES — STRONG VISUAL ENTRY ===== -->
  <section class="py-20 bg-gray-50">
    <div class="max-w-7xl mx-auto px-6">
      <div class="text-center max-w-3xl mx-auto mb-14">
        <p class="text-[#2d5a27] text-sm font-semibold tracking-widest uppercase mb-3">Two Product Lines, One Factory</p>
        <h2 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4">Choose the Product Line That Fits the Project</h2>
        <p class="text-gray-500 leading-relaxed">Premium glass appearance or practical metal coverage — both lines are factory-supplied as complete packages with active elements, inactive coverage and accessories.</p>
      </div>
      <div class="grid lg:grid-cols-2 gap-6 max-w-6xl mx-auto">
        <!-- Lumina Slate -->
        <a href="/lumina-slate/" class="group rounded-2xl overflow-hidden bg-white border border-gray-100 shadow-sm hover:shadow-lg transition-shadow block">
          <div class="relative h-80 overflow-hidden">
            <img src="/images/projects/hangzhou-xianghu-arcadia-villa/sunlit-bipv-solar-roof-aerial-view-hangzhou-xianghu.webp" alt="Lumina Slate glass solar roof tiles" class="w-full h-full object-cover group-hover:scale-[1.03] transition-transform duration-700" />
            <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/20 to-transparent"></div>
            <div class="absolute top-5 left-5">
              <span class="bg-white text-[#2d5a27] text-xs font-bold px-3 py-1.5 rounded-full">Premium Glass Tile Line</span>
            </div>
            <div class="absolute bottom-5 left-5 right-5">
              <h3 class="text-white text-2xl font-bold mb-1">Lumina Slate</h3>
              <p class="text-white/70 text-sm">Glass solar roof tiles · 70W per tile · Mono PERC · Double glass</p>
            </div>
          </div>
          <div class="p-7">
            <p class="text-gray-500 text-sm leading-relaxed mb-5">Premium glass slate-look solar roof tiles with matching inactive glass tiles and accessories. Built for villas and architectural projects where appearance is part of the value.</p>
            <div class="flex items-center justify-between">
              <div class="flex gap-4">
                <div class="text-center"><div class="text-lg font-bold text-gray-900">70W</div><div class="text-xs text-gray-400">Per Tile</div></div>
                <div class="text-center"><div class="text-lg font-bold text-gray-900">IP68</div><div class="text-xs text-gray-400">Waterproof</div></div>
                <div class="text-center"><div class="text-lg font-bold text-gray-900">14.46%</div><div class="text-xs text-gray-400">Efficiency</div></div>
              </div>
              <span class="font-bold text-[#2d5a27] group-hover:text-amber transition-colors flex items-center gap-1 text-sm">
                Explore →
              </span>
            </div>
          </div>
        </a>
        <!-- Storm Guard -->
        <a href="/storm-guard/" class="group rounded-2xl overflow-hidden bg-white border border-gray-100 shadow-sm hover:shadow-lg transition-shadow block">
          <div class="relative h-80 overflow-hidden">
            <img src="/images/projects/urban-low-slope-extension/storm-guard-urban-flat-roof-solar-integration.webp" alt="Storm Guard metal solar roof sheets" class="w-full h-full object-cover group-hover:scale-[1.03] transition-transform duration-700" />
            <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/20 to-transparent"></div>
            <div class="absolute top-5 left-5">
              <span class="bg-amber text-gray-900 text-xs font-bold px-3 py-1.5 rounded-full">Modern Metal Sheet Line</span>
            </div>
            <div class="absolute bottom-5 left-5 right-5">
              <h3 class="text-white text-2xl font-bold mb-1">Storm Guard</h3>
              <p class="text-white/70 text-sm">Metal solar roof sheets · 135W per sheet · Mono TOPCON · IP68</p>
            </div>
          </div>
          <div class="p-7">
            <p class="text-gray-500 text-sm leading-relaxed mb-5">Modern metal roof sheets with matching inactive metal elements and accessories. Built for residential, commercial, public and large-area roof projects.</p>
            <div class="flex items-center justify-between">
              <div class="flex gap-4">
                <div class="text-center"><div class="text-lg font-bold text-gray-900">135W</div><div class="text-xs text-gray-400">Per Sheet</div></div>
                <div class="text-center"><div class="text-lg font-bold text-gray-900">IP68</div><div class="text-xs text-gray-400">Waterproof</div></div>
                <div class="text-center"><div class="text-lg font-bold text-gray-900">16.67%</div><div class="text-xs text-gray-400">Efficiency</div></div>
              </div>
              <span class="font-bold text-[#2d5a27] group-hover:text-amber transition-colors flex items-center gap-1 text-sm">
                Explore →
              </span>
            </div>
          </div>
        </a>
      </div>
      <div class="text-center mt-8">
        <a href="/system-overview/" class="inline-flex items-center gap-2 border border-[#2d5a27] text-[#2d5a27] hover:bg-[#2d5a27] hover:text-white font-medium px-7 py-3 rounded-lg transition-colors text-sm">
          Compare Both Lines →
        </a>
      </div>
    </div>
  </section>

  <!-- ===== WHO WE WORK WITH ===== -->
  <section class="py-16 bg-[#f4f7f0] border-y border-[#2d5a27]/10">
    <div class="max-w-7xl mx-auto px-6">
      <div class="text-center mb-10">
        <p class="text-[#2d5a27] text-sm font-semibold tracking-widest uppercase mb-3">Who We Work With</p>
        <h2 class="text-3xl font-bold text-gray-900">B2B Solar Roof Supply for Overseas Markets</h2>
      </div>
      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-5">
        {audiences.map(item => (
          <div class="sunlit-card p-6 flex gap-4 items-start">
            <div class="w-12 h-12 rounded-2xl bg-soft-green text-deep-green flex items-center justify-center shrink-0" set:html={item.icon} />
            <div>
              <h3 class="font-heading font-bold text-lg text-charcoal mb-2">{item.title}</h3>
              <p class="text-sm text-slate leading-relaxed">{item.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== PROJECT REFERENCES ===== -->
  <section class="py-20 bg-gray-50 border-y border-gray-100">
    <div class="max-w-7xl mx-auto px-6">
      <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-4 mb-12">
        <div>
          <p class="text-[#2d5a27] text-sm font-semibold tracking-widest uppercase mb-3">Project References</p>
          <h2 class="text-4xl font-bold text-gray-900">Factory-Supplied Project References</h2>
        </div>
        <a href="/projects/" class="inline-flex items-center gap-2 border border-[#2d5a27] text-[#2d5a27] hover:bg-[#2d5a27] hover:text-white font-medium px-5 py-2.5 rounded-lg transition-colors text-sm whitespace-nowrap">View All Projects →</a>
      </div>
      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-5">
        {projects.slice(0, 4).map((project: any) => (
          <a href={`/projects/${project.slug}/`} class="group rounded-2xl overflow-hidden bg-white border border-gray-100 shadow-sm hover:shadow-md transition-shadow block">
            {project.images?.[0] ? (
              <div class="relative h-48 overflow-hidden">
                <img src={project.images[0]} alt={project.name} class="w-full h-full object-cover group-hover:scale-[1.04] transition-transform duration-500" />
              </div>
            ) : (
              <div class="h-48 bg-gray-100"></div>
            )}
            <div class="p-5">
              <h3 class="font-bold text-gray-900 text-sm mb-1.5 line-clamp-2">{project.name}</h3>
              <p class="text-xs text-gray-400 mb-3">{project.location}</p>
              <div class="flex flex-wrap gap-1.5">
                <span class="text-xs px-2.5 py-1 rounded-full bg-[#2d5a27]/10 text-[#2d5a27] font-medium">{project.system}</span>
                <span class="text-xs px-2.5 py-1 rounded-full bg-gray-100 text-gray-500">{project.application}</span>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== FAQ ===== -->
  <section id="faq" class="py-20 bg-white">
    <div class="max-w-5xl mx-auto px-6">
      <div class="text-center mb-12">
        <p class="text-[#2d5a27] text-sm font-semibold tracking-widest uppercase mb-3">FAQ</p>
        <h2 class="text-4xl font-bold text-gray-900">Factory Supply Questions</h2>
      </div>
      <div class="grid md:grid-cols-2 gap-4">
        {faqs.map((faq: any) => (
          <details class="bg-gray-50 rounded-2xl border border-gray-100 group cursor-pointer">
            <summary class="p-5 font-bold text-gray-900 flex items-center justify-between list-none gap-4">
              {faq.question}
              <span class="text-[#2d5a27] text-xl flex-shrink-0">⌄</span>
            </summary>
            <div class="px-5 pb-5 text-gray-500 text-sm leading-relaxed">{faq.answer}</div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== CONTENT FUNNEL DIVERSION ===== -->
  <section class="py-20 bg-[#f4f7f0]">
    <div class="max-w-7xl mx-auto px-6">
      <div class="text-center mb-12">
        <p class="text-[#2d5a27] text-sm font-bold tracking-widest uppercase mb-3">Learn More</p>
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">Not Sure Where to Start?</h2>
        <p class="text-lg text-gray-600 max-w-2xl mx-auto">Whether you're new to solar roofs or ready to source — find the right starting point below.</p>
      </div>
      <div class="grid md:grid-cols-3 gap-6">
        <a href="/resources/knowledge-base/what-is-solar-roof/" class="group rounded-2xl bg-white border border-gray-100 overflow-hidden shadow-sm hover:shadow-md transition-shadow">
          <div class="overflow-hidden h-44">
            <img src="/images/projects/hangzhou-xianghu-arcadia-villa/sunlit-bipv-solar-roof-aerial-view-hangzhou-xianghu.webp" alt="What is a solar roof" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
          </div>
          <div class="p-6">
            <p class="text-xs text-[#2d5a27] font-bold uppercase tracking-wider mb-2">Explainer</p>
            <h3 class="font-bold text-gray-800 group-hover:text-[#2d5a27] transition-colors mb-2 text-lg">What Is a Solar Roof?</h3>
            <p class="text-sm text-gray-600 leading-relaxed mb-4">How it works, what components it includes, and how it differs from conventional roofing.</p>
            <span class="text-[#2d5a27] text-sm font-semibold">Read the guide →</span>
          </div>
        </a>
        <a href="/solar-roof-vs-solar-panels/" class="group rounded-2xl bg-white border border-gray-100 overflow-hidden shadow-sm hover:shadow-md transition-shadow">
          <div class="overflow-hidden h-44">
            <img src="/images/projects/xuzhou-luxury-villa-the-ultimate-bipv-vs-bapv-contrast/sunlit-bipv-vs-bapv-solar-roof-comparison.webp" alt="Solar roof vs solar panels comparison" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
          </div>
          <div class="p-6">
            <p class="text-xs text-[#2d5a27] font-bold uppercase tracking-wider mb-2">Comparison</p>
            <h3 class="font-bold text-gray-800 group-hover:text-[#2d5a27] transition-colors mb-2 text-lg">Solar Roof vs Solar Panels</h3>
            <p class="text-sm text-gray-600 leading-relaxed mb-4">Cost, efficiency, aesthetics, application range — full data comparison side by side.</p>
            <span class="text-[#2d5a27] text-sm font-semibold">See comparison →</span>
          </div>
        </a>
        <a href="/system-overview/" class="group rounded-2xl bg-white border border-gray-100 overflow-hidden shadow-sm hover:shadow-md transition-shadow">
          <div class="overflow-hidden h-44">
            <img src="/images/shipping/a1e77cb3c75b8df9e4aede91087a4efd.webp" alt="Import solar roof from China factory" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
          </div>
          <div class="p-6">
            <p class="text-xs text-[#2d5a27] font-bold uppercase tracking-wider mb-2">Factory Supply</p>
            <h3 class="font-bold text-gray-800 group-hover:text-[#2d5a27] transition-colors mb-2 text-lg">Sourcing from a China Factory</h3>
            <p class="text-sm text-gray-600 leading-relaxed mb-4">What Sunlit supplies, how the package is structured, and what to expect from factory-direct B2B supply.</p>
            <span class="text-[#2d5a27] text-sm font-semibold">See supply scope →</span>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- ===== CTA ===== -->
  <section class="py-24 bg-[#0f1f0f] relative overflow-hidden">
    <div class="absolute inset-0 opacity-20">
      <img src="/images/projects/large-scale-commercial-complex/storm-guard-large-scale-bipv-integration-aerial-scaled.webp" alt="" class="w-full h-full object-cover" />
    </div>
    <div class="relative z-10 max-w-7xl mx-auto px-6">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div>
          <p class="text-amber text-sm font-semibold tracking-widest uppercase mb-4">Start with what you have</p>
          <h2 class="text-white text-4xl md:text-5xl font-bold mb-5 leading-tight">Ask About Factory Pricing or Product Fit</h2>
          <p class="text-white/65 text-lg leading-relaxed mb-8">A roof drawing helps, but it is not required for the first message. Send your country, estimated roof area, photos, product interest or buyer role — we will suggest the right next step.</p>
          <div class="flex flex-wrap gap-4">
            <a href="/contact/" class="inline-flex items-center gap-2 bg-amber hover:bg-amber-dark text-gray-900 font-bold px-8 py-4 rounded-lg transition-colors">Get Factory Pricing →</a>
            <a href="/contact/" class="inline-flex items-center gap-2 border border-white/40 hover:border-white text-white font-medium px-8 py-4 rounded-lg transition-colors">Ask a Question</a>
          </div>
        </div>
        <div class="grid sm:grid-cols-2 gap-4">
          {[
            { title: 'Direct Factory', desc: 'Better value and clearer product scope.' },
            { title: 'Project-Based Quote', desc: 'Quoted according to roof layout and supply package.' },
            { title: 'Export Support', desc: 'Packaging, shipping document and delivery communication.' },
            { title: 'Long-Term Cooperation', desc: 'For distributors, installers and project buyers.' },
          ].map(item => (
            <div class="bg-white/10 border border-white/20 rounded-2xl p-5">
