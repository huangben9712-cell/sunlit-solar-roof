---
import Layout from '../layouts/Layout.astro';
import { projects } from '../data/projects';
import { generalFAQs } from '../data/faqs';

const faqs = generalFAQs.slice(0, 5);

const ASSETS = {
  luminaSlateHero: "https://d2xsxph8kpxj0f.cloudfront.net/310519663705242844/mtvS4X69r9pvLdqcQTXPeQ/lumina-slate-hero-dFoW7mbWnUAgHmoQ6n9iPk.webp",
  stormGuardHero: "https://d2xsxph8kpxj0f.cloudfront.net/310519663705242844/mtvS4X69r9pvLdqcQTXPeQ/storm-guard-hero-Rv3C82SNHYaBM2TVgU4t7W.webp",
};

const trustItems = [
  { label: "China Manufacturer", desc: "Direct factory supply for overseas B2B solar roof projects." },
  { label: "Factory Pricing", desc: "Project-based quotation based on product scope and roof layout." },
  { label: "Active + Inactive Supply", desc: "Solar roof tiles or sheets plus matching non-PV roof elements." },
  { label: "Samples Available", desc: "Product samples and system details before project commitment." },
  { label: "Export Support", desc: "Packaging, shipping documents and overseas project communication." },
];

const components = [
  "Active PV Tiles / Sheets",
  "Matching Inactive Roof Elements",
  "Flashing",
  "Ridge and Edge Pieces",
  "Fixings",
  "Project Documents",
];

const audiences = [
  { title: "For Distributors", desc: "Source differentiated solar roof products from a China factory supplier." },
  { title: "For Solar Installers", desc: "Offer integrated solar roof products when clients do not want standard panels." },
  { title: "For Roofing Contractors", desc: "Plan active and inactive roof elements instead of isolated PV tiles." },
  { title: "For Developers", desc: "Evaluate factory-supplied solar roof packages for residential and commercial projects." },
];
---

<Layout title="China Solar Roof Tile Manufacturer - Sunlit Solar Roof">
  <section class="relative bg-soft-green overflow-hidden">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_90%_15%,rgba(212,160,86,0.1),transparent_30%),radial-gradient(circle_at_10%_80%,rgba(15,77,58,0.06),transparent_40%)]"></div>
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 py-24 md:py-32 relative">
      <div class="grid lg:grid-cols-2 gap-16 items-center">
        <div class="max-w-xl">
          <p class="sunlit-overline mb-5">China BIPV Manufacturer</p>
          <h1 class="sunlit-section-title text-4xl md:text-5xl lg:text-6xl mb-6">
            Factory-Direct Solar Roof Tiles and Metal Solar Roof Sheets.
          </h1>
          <p class="text-lg text-slate leading-relaxed mb-10">
            Sunlit is a China-based manufacturer supplying active solar roof tiles or sheets, matching inactive roof elements, flashing, fixings and accessories for overseas B2B projects.
          </p>

          <div class="flex flex-col sm:flex-row items-start gap-4">
            <a href="/contact/" class="sunlit-btn-primary whitespace-nowrap">
              Get Factory Pricing
              <span>→</span>
            </a>
            <a href="/system-overview/" class="sunlit-btn-secondary whitespace-nowrap">
              View Supply Scope
            </a>
          </div>
        </div>

        <div class="relative h-full hidden lg:block">
          <div class="relative w-full h-full aspect-[4/3] rounded-2xl overflow-hidden border border-border">
            <img
              src={ASSETS.luminaSlateHero}
              alt="Factory supplied solar roof tiles for overseas projects"
              class="w-full h-full object-cover"
              loading="eager"
            />
            <div class="absolute bottom-0 left-0 w-full p-6 bg-gradient-to-t from-black/50 to-transparent">
              <h3 class="font-heading font-bold text-white text-2xl">Factory Supply Scope</h3>
              <p class="text-white/80">Active elements, inactive coverage and roofing accessories quoted as one product package.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 bg-white">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-x-8 gap-y-10">
        {trustItems.map((item, index) => (
          <div class="text-center lg:text-left flex flex-col items-center lg:items-start">
            <div class="w-12 h-12 rounded-full bg-soft-green text-deep-green flex items-center justify-center mb-4 font-bold">
              0{index + 1}
            </div>
            <h3 class="font-heading font-bold text-charcoal text-lg mb-1">{item.label}</h3>
            <p class="text-base text-slate leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16 md:py-24 bg-white">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-3xl mx-auto mb-16">
        <p class="sunlit-overline mb-4">Two Product Lines, One Factory</p>
        <h2 class="sunlit-section-title text-4xl md:text-5xl">Solar Roof Products for Different Project Types</h2>
      </div>

      <div class="grid lg:grid-cols-2 gap-8 max-w-6xl mx-auto">
        <a href="/lumina-slate/" class="sunlit-card block group overflow-hidden">
          <img
            src={ASSETS.luminaSlateHero}
            alt="Lumina Slate glass solar roof tiles"
            class="w-full h-72 object-cover transition-transform duration-500 group-hover:scale-[1.02]"
          />
          <div class="p-8">
            <p class="sunlit-overline mb-3">Glass Solar Roof Tile Line</p>
            <h3 class="font-heading text-2xl font-bold mb-3 text-charcoal">Lumina Slate</h3>
            <p class="text-slate leading-relaxed mb-6">
              AG-etched frameless double-glass PV roof tiles with matching inactive glass tiles for premium villas and architectural projects.
            </p>
            <span class="font-bold text-deep-green group-hover:text-amber transition-colors flex items-center gap-2">Explore Lumina Slate →</span>
          </div>
        </a>

        <a href="/storm-guard/" class="sunlit-card block group overflow-hidden">
          <img
            src={ASSETS.stormGuardHero}
            alt="Storm Guard metal solar roof sheets"
            class="w-full h-72 object-cover transition-transform duration-500 group-hover:scale-[1.02]"
          />
          <div class="p-8">
            <p class="sunlit-overline mb-3">Metal Solar Roof Sheet Line</p>
            <h3 class="font-heading text-2xl font-bold mb-3 text-charcoal">Storm Guard</h3>
            <p class="text-slate leading-relaxed mb-6">
              Low-standing-seam Al-Mg-Mn metal solar roof sheets with matching inactive elements for modern residential, commercial and large-area roofs.
            </p>
            <span class="font-bold text-deep-green group-hover:text-amber transition-colors flex items-center gap-2">Explore Storm Guard →</span>
          </div>
        </a>
      </div>
    </div>
  </section>

  <section class="py-16 md:py-24 bg-light-gray border-y border-border">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-12 gap-8 items-center">
        <div class="lg:col-span-4">
          <p class="sunlit-overline mb-4">Factory Supply Scope</p>
          <h2 class="sunlit-section-title text-3xl md:text-4xl mb-4">What We Supply for a Solar Roof Project</h2>
          <p class="text-slate leading-relaxed">
            We supply the factory-side product package: active PV elements, matching inactive roof elements, flashing, fixings and roof accessories. Local roofing and electrical work should be handled by qualified local professionals.
          </p>
        </div>
        <div class="lg:col-span-8 grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {components.map((component) => (
            <div class="sunlit-card p-6 flex flex-col items-start gap-4">
              <div class="w-12 h-12 rounded-full bg-soft-green text-deep-green flex items-center justify-center font-bold">✓</div>
              <h3 class="font-heading font-bold text-charcoal text-lg">{component}</h3>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 md:py-24 bg-white">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-3xl mx-auto mb-16">
        <p class="sunlit-overline mb-4">Built for Professional B2B Buyers</p>
        <h2 class="sunlit-section-title text-4xl md:text-5xl">A Factory Supply Partner You Can Evaluate</h2>
      </div>
      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8 max-w-6xl mx-auto">
        {audiences.map((audience) => (
          <div class="bg-soft-green rounded-2xl p-8 text-center">
            <div class="w-16 h-16 rounded-full bg-white text-deep-green flex items-center justify-center mb-5 mx-auto font-bold">B2B</div>
            <h3 class="font-heading font-bold text-xl text-charcoal mb-3">{audience.title}</h3>
            <p class="text-slate leading-relaxed">{audience.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16 md:py-24 bg-light-gray border-y border-border">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-4 mb-12">
        <div>
          <p class="sunlit-overline mb-3">Recent Projects</p>
          <h2 class="sunlit-section-title text-4xl md:text-5xl">Factory-Supplied Project References</h2>
        </div>
        <a href="/projects/" class="sunlit-btn-secondary whitespace-nowrap w-fit">View Full Portfolio →</a>
      </div>
      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
        {projects.slice(0, 4).map((project) => (
          <a href={`/projects/${project.slug}/`} class="sunlit-card overflow-hidden block group">
            {project.images?.[0] ? (
              <img
                src={project.images[0]}
                alt={project.name}
                class="h-48 w-full object-cover transition-transform duration-500 group-hover:scale-[1.02]"
                loading="lazy"
              />
            ) : (
              <div class="h-48 image-placeholder"></div>
            )}
            <div class="p-6">
              <h3 class="font-heading font-bold text-charcoal mb-2 line-clamp-2">{project.name}</h3>
              <p class="text-sm text-slate mb-4">{project.location}</p>
              <div class="flex flex-wrap gap-2">
                <span class="text-xs px-3 py-1 rounded-full bg-soft-green text-deep-green">{project.system}</span>
                <span class="text-xs px-3 py-1 rounded-full bg-light-gray text-slate">{project.application}</span>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section id="faq" class="py-16 md:py-24 bg-white">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-4xl">
      <div class="text-center mb-14">
        <p class="sunlit-overline mb-3">FAQ</p>
        <h2 class="sunlit-section-title text-4xl md:text-5xl">Factory Supply Questions</h2>
      </div>
      <div class="space-y-4">
        {faqs.map((faq) => (
          <details class="sunlit-card group cursor-pointer">
            <summary class="p-6 font-heading font-bold text-charcoal text-lg flex items-center justify-between list-none">
              {faq.question}
              <span class="text-deep-green">+</span>
            </summary>
            <div class="px-6 pb-6 text-slate leading-relaxed">{faq.answer}</div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16 md:py-24 dark-green-gradient text-white">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 text-center max-w-3xl">
      <p class="sunlit-overline mb-4 text-white/70">Start with a Roof Drawing</p>
      <h2 class="font-heading text-3xl md:text-5xl font-bold mb-5">Get Factory Pricing for Your Solar Roof Project</h2>
      <p class="text-base md:text-lg text-white/70 leading-relaxed mb-8">
        Tell us your country, roof area and project drawings. We will define the factory supply scope, active and inactive coverage and project-based quotation direction.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/contact/" class="sunlit-btn-primary whitespace-nowrap">Get Factory Pricing →</a>
        <a href="/system-overview/" class="border border-white/40 text-white rounded-full px-6 py-3 font-bold hover:bg-white/10 transition-colors text-center">View Supply Scope</a>
      </div>
    </div>
  </section>
</Layout>
