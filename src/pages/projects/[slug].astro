---
import Layout from '../../layouts/Layout.astro';
import { projects } from '../../data/projects.ts';

export function getStaticPaths() {
  return projects.map((project) => ({ params: { slug: project.slug }, props: { project } }));
}

const { project } = Astro.props;

// Helper: skip placeholder values
const clean = (value?: string | null) =>
  value && value !== 'Available upon request' && value !== 'N/A' ? value : undefined;

// Extract Annual Estimated Output from technicalHighlights
const annualOutput = project.technicalHighlights
  ?.find(h => h.toLowerCase().includes('annual'))
  ?.replace(/^.*?:\s*/, '');

// Related projects: same system, different slug, max 3
const relatedProjects = projects
  .filter(p => p.system === project.system && p.slug !== project.slug)
  .slice(0, 3);

// Supply scope items for this project (based on system)
const supplyScope = project.system === 'Lumina Slate'
  ? [
      { label: 'Active PV Tiles\n(Lumina Slate)', icon: 'grid' },
      { label: 'Inactive Roof\nElements', icon: 'layers' },
      { label: 'Flashing &\nWaterproofing', icon: 'shield' },
      { label: 'Ridge & Edge\nPieces', icon: 'triangle' },
      { label: 'Fixings &\nAccessories', icon: 'tool' },
      { label: 'Project Documents\n& Drawings', icon: 'file' },
    ]
  : [
      { label: 'Active PV\nSheets', icon: 'grid' },
      { label: 'Inactive Roof\nElements', icon: 'layers' },
      { label: 'Flashing &\nWaterproofing', icon: 'shield' },
      { label: 'Ridge & Edge\nPieces', icon: 'triangle' },
      { label: 'Fixings &\nAccessories', icon: 'tool' },
      { label: 'Project Documents\n& Drawings', icon: 'file' },
    ];

// SVG icon map
const icons: Record<string, string> = {
  grid: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="14" rx="2"/><path d="M7 4v14M12 4v14M17 4v14M3 9h18M3 14h18"/></svg>`,
  layers: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 2 7 12 12 22 7 12 2"/><polyline points="2 17 12 22 22 17"/><polyline points="2 12 12 17 22 12"/></svg>`,
  shield: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>`,
  triangle: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 18L12 5l9 13H3z"/><path d="M3 18h18"/></svg>`,
  tool: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>`,
  file: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><polyline points="14 2 14 8 20 8"/><line x1="8" y1="13" x2="16" y2="13"/><line x1="8" y1="17" x2="12" y2="17"/></svg>`,
  location: `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>`,
  system: `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="14" rx="2"/><path d="M7 4v14M12 4v14M17 4v14M3 9h18M3 14h18"/></svg>`,
  home: `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>`,
  area: `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M3 15h18M9 3v18M15 3v18"/></svg>`,
  bolt: `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>`,
  sun: `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>`,
  overview: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><polyline points="14 2 14 8 20 8"/><line x1="8" y1="13" x2="16" y2="13"/><line x1="8" y1="17" x2="12" y2="17"/></svg>`,
  challenge: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>`,
  solution: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="2" x2="12" y2="6"/><line x1="12" y1="18" x2="12" y2="22"/><line x1="4.93" y1="4.93" x2="7.76" y2="7.76"/><line x1="16.24" y1="16.24" x2="19.07" y2="19.07"/><line x1="2" y1="12" x2="6" y2="12"/><line x1="18" y1="12" x2="22" y2="12"/><line x1="4.93" y1="19.07" x2="7.76" y2="16.24"/><line x1="16.24" y1="7.76" x2="19.07" y2="4.93"/><circle cx="12" cy="12" r="4"/></svg>`,
  visual: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>`,
};
---

<Layout
  title={`${project.name} — Sunlit Solar Roof`}
  description={project.overview ?? `${project.name} — a BIPV solar roof installation by Sunlit Solar Roof.`}
>

  <!-- ===== BREADCRUMB ===== -->
  <nav class="bg-white border-b border-border">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 py-3 text-sm text-slate flex items-center gap-1.5 flex-wrap">
      <a href="/" class="hover:text-deep-green transition-colors">Home</a>
      <span class="text-border">/</span>
      <a href="/projects/" class="hover:text-deep-green transition-colors">Projects</a>
      <span class="text-border">/</span>
      <span class="text-charcoal line-clamp-1">{project.name}</span>
    </div>
  </nav>

  <!-- ===== HERO + IMAGE BAND: single section with split bg ===== -->
  <!-- Upper 55% green, lower 45% white via inline style -->
  <section class="relative" style="background: linear-gradient(to bottom, #e8f2ec 55%, #ffffff 55%)">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 pt-16 pb-10">

      <!-- HERO TEXT -->
      <p class="sunlit-overline mb-4">Project Reference</p>
      <h1 class="font-heading font-bold text-4xl md:text-5xl lg:text-6xl text-charcoal leading-tight mb-6 max-w-4xl">
        {project.name}
      </h1>
      {project.overview && (
        <p class="text-slate text-base leading-relaxed max-w-2xl mb-7">
          {project.overview.length > 220 ? project.overview.slice(0, 220) + '…' : project.overview}
        </p>
      )}
      <!-- Tags -->
      <div class="flex gap-2 flex-wrap mb-10">
        <span class="inline-flex items-center gap-1.5 bg-soft-green border border-deep-green/20 text-deep-green text-sm font-heading font-semibold px-3.5 py-1.5 rounded-full">
          <Fragment set:html={icons.system} />
          {project.system}
        </span>
        <span class="inline-flex items-center gap-1.5 bg-white border border-border text-charcoal text-sm font-heading font-semibold px-3.5 py-1.5 rounded-full">
          <Fragment set:html={icons.home} />
          {project.application}
        </span>
        <span class="inline-flex items-center gap-1.5 bg-white border border-border text-slate text-sm font-heading px-3.5 py-1.5 rounded-full">
          <Fragment set:html={icons.location} />
          {project.location}
        </span>
      </div>

      <!-- TOP ROW: images + sidebar (cards straddle the green/white boundary) -->
      <div class="flex flex-col lg:flex-row gap-8 items-stretch mb-0">

        <!-- LEFT: images -->
        <div class="flex-1 min-w-0">

          <!-- Hero image -->
          <div class="rounded-2xl overflow-hidden mb-4 bg-gray-100">
            {project.images?.[0] ? (
              <img
                src={project.images[0]}
                alt={project.name}
                class="w-full h-[340px] md:h-[460px] object-cover"
              />
            ) : (
              <div class="w-full h-[340px] image-placeholder"></div>
            )}
          </div>

          <!-- Thumbnail row -->
          {project.images && project.images.length > 1 && (
            <div class="grid grid-cols-3 gap-3">
              {project.images.slice(1, 4).map((img, i) => (
                <div class="rounded-xl overflow-hidden">
                  <img
                    src={img}
                    alt={`${project.name} — photo ${i + 2}`}
                    class="w-full h-32 object-cover"
                    loading="lazy"
                  />
                </div>
              ))}
            </div>
          )}

        </div>

        <!-- RIGHT SIDEBAR: Project Facts -->
        <aside class="w-full lg:w-80 flex-shrink-0 flex flex-col">
          <div class="sunlit-card p-6 flex flex-col flex-1">
            <div class="flex items-center gap-2 mb-5">
              <div class="w-5 h-0.5 bg-deep-green"></div>
              <h3 class="font-heading font-bold text-charcoal text-base">Project Facts</h3>
            </div>
            <div class="space-y-4">

              <!-- Location -->
              <div class="flex items-start gap-3">
                <div class="w-8 h-8 rounded-lg bg-soft-green text-deep-green flex items-center justify-center flex-shrink-0">
                  <Fragment set:html={icons.location} />
                </div>
                <div>
                  <p class="text-xs text-slate mb-0.5">Location</p>
                  <p class="font-heading font-bold text-charcoal text-sm">{project.location}</p>
                </div>
              </div>

              <!-- System -->
              <div class="flex items-start gap-3">
                <div class="w-8 h-8 rounded-lg bg-soft-green text-deep-green flex items-center justify-center flex-shrink-0">
                  <Fragment set:html={icons.system} />
                </div>
                <div>
                  <p class="text-xs text-slate mb-0.5">System</p>
                  <p class="font-heading font-bold text-charcoal text-sm">{project.system}</p>
                </div>
              </div>

              <!-- Application -->
              <div class="flex items-start gap-3">
                <div class="w-8 h-8 rounded-lg bg-soft-green text-deep-green flex items-center justify-center flex-shrink-0">
                  <Fragment set:html={icons.home} />
                </div>
                <div>
                  <p class="text-xs text-slate mb-0.5">Application</p>
                  <p class="font-heading font-bold text-charcoal text-sm">{project.application}</p>
                </div>
              </div>

              <!-- Roof Area -->
              {clean(project.roofArea) && (
                <div class="flex items-start gap-3">
                  <div class="w-8 h-8 rounded-lg bg-soft-green text-deep-green flex items-center justify-center flex-shrink-0">
                    <Fragment set:html={icons.area} />
                  </div>
                  <div>
                    <p class="text-xs text-slate mb-0.5">Roof Area</p>
                    <p class="font-heading font-bold text-charcoal text-sm">{project.roofArea}</p>
                  </div>
                </div>
              )}

              <!-- Capacity -->
              {clean(project.capacity) && (
                <div class="flex items-start gap-3">
                  <div class="w-8 h-8 rounded-lg bg-soft-green text-deep-green flex items-center justify-center flex-shrink-0">
                    <Fragment set:html={icons.bolt} />
                  </div>
                  <div>
                    <p class="text-xs text-slate mb-0.5">Capacity</p>
                    <p class="font-heading font-bold text-charcoal text-sm">{project.capacity}</p>
                  </div>
                </div>
              )}

              <!-- Annual Output -->
              {annualOutput && (
                <div class="flex items-start gap-3">
                  <div class="w-8 h-8 rounded-lg bg-soft-green text-deep-green flex items-center justify-center flex-shrink-0">
                    <Fragment set:html={icons.sun} />
                  </div>
                  <div>
                    <p class="text-xs text-slate mb-0.5">Annual Estimated Output</p>
                    <p class="font-heading font-bold text-charcoal text-sm">{annualOutput}</p>
                  </div>
                </div>
              )}

            </div>

            <!-- CTA -->
            <a href="/contact/" class="sunlit-btn-primary w-full text-center block mt-auto pt-6 text-sm">
              Discuss Similar Project →
            </a>
          </div>
        </aside>

      </div>

    </div>
  </section>

  <!-- ===== FULL-WIDTH CONTENT SECTION ===== -->
  <section class="bg-white pt-10 pb-10">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div>

          <!-- 2-col content grid: Overview + Challenge, Solution + Visual Outcome -->
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">

            <!-- Project Overview -->
            {project.overview && (
              <div class="flex gap-4">
                <div class="flex-shrink-0 w-10 h-10 rounded-xl bg-soft-green text-deep-green flex items-center justify-center">
                  <Fragment set:html={icons.overview} />
                </div>
                <div>
                  <h2 class="font-heading font-bold text-charcoal text-lg mb-2">Project Overview</h2>
                  <p class="text-slate text-sm leading-relaxed">{project.overview}</p>
                </div>
              </div>
            )}

            <!-- Project Challenge -->
            {clean(project.challenge) && (
              <div class="flex gap-4">
                <div class="flex-shrink-0 w-10 h-10 rounded-xl bg-soft-green text-deep-green flex items-center justify-center">
                  <Fragment set:html={icons.challenge} />
                </div>
                <div>
                  <h2 class="font-heading font-bold text-charcoal text-lg mb-2">Project Challenge</h2>
                  <p class="text-slate text-sm leading-relaxed whitespace-pre-line">{project.challenge}</p>
                </div>
              </div>
            )}

            <!-- Sunlit Solution -->
            {clean(project.sunlitSolution) && (
              <div class="flex gap-4">
                <div class="flex-shrink-0 w-10 h-10 rounded-xl bg-soft-green text-deep-green flex items-center justify-center">
                  <Fragment set:html={icons.solution} />
                </div>
                <div>
                  <h2 class="font-heading font-bold text-charcoal text-lg mb-2">Sunlit Solution</h2>
                  <p class="text-slate text-sm leading-relaxed whitespace-pre-line">{project.sunlitSolution}</p>
                </div>
              </div>
            )}

            <!-- Visual Outcome (derived from solution context if no dedicated field) -->
            {clean(project.sunlitSolution) && (
              <div class="flex gap-4">
                <div class="flex-shrink-0 w-10 h-10 rounded-xl bg-soft-green text-deep-green flex items-center justify-center">
                  <Fragment set:html={icons.visual} />
                </div>
                <div>
                  <h2 class="font-heading font-bold text-charcoal text-lg mb-2">Visual Outcome</h2>
                  <p class="text-slate text-sm leading-relaxed">
                    The completed roof integrates seamlessly with the building's architecture. From the ground, the solar roof reads as a refined architectural finish — delivering clean energy without compromising curb appeal or the character of the property.
                  </p>
                </div>
              </div>
            )}
          </div>

          <!-- Technical Notes -->
          {project.technicalHighlights && project.technicalHighlights.length > 0 && (
            <div class="border border-border rounded-2xl p-6 mb-8 relative overflow-hidden">
              <div class="flex items-center gap-2 mb-5">
                <div class="w-6 h-0.5 bg-deep-green"></div>
                <h2 class="font-heading font-bold text-charcoal text-lg">Technical Notes</h2>
              </div>
              <div class="grid md:grid-cols-2 gap-x-8 gap-y-2.5 relative z-10">
                {project.technicalHighlights.map(item => (
                  <div class="flex items-start gap-2 text-sm text-slate">
                    <span class="mt-1.5 w-1.5 h-1.5 rounded-full bg-deep-green flex-shrink-0"></span>
                    {item}
                  </div>
                ))}
              </div>
              <!-- Decorative architectural roof line drawing -->
              <div class="absolute bottom-0 right-0 opacity-[0.07] pointer-events-none">
                <svg width="280" height="160" viewBox="0 0 280 160" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M10 150 L140 20 L270 150" stroke="#1a3a2a" stroke-width="2.5" fill="none" stroke-linecap="round"/>
                  <path d="M125 32 L140 20 L155 32" stroke="#1a3a2a" stroke-width="2" fill="none" stroke-linecap="round"/>
                  <path d="M30 150 L140 38" stroke="#1a3a2a" stroke-width="1.5" fill="none" stroke-dasharray="6 3"/>
                  <path d="M55 150 L140 56" stroke="#1a3a2a" stroke-width="1.5" fill="none" stroke-dasharray="6 3"/>
                  <path d="M80 150 L140 74" stroke="#1a3a2a" stroke-width="1.5" fill="none" stroke-dasharray="6 3"/>
                  <path d="M105 150 L140 92" stroke="#1a3a2a" stroke-width="1.5" fill="none" stroke-dasharray="6 3"/>
                  <path d="M250 150 L140 38" stroke="#1a3a2a" stroke-width="1.5" fill="none" stroke-dasharray="6 3"/>
                  <path d="M225 150 L140 56" stroke="#1a3a2a" stroke-width="1.5" fill="none" stroke-dasharray="6 3"/>
                  <path d="M200 150 L140 74" stroke="#1a3a2a" stroke-width="1.5" fill="none" stroke-dasharray="6 3"/>
                  <path d="M175 150 L140 92" stroke="#1a3a2a" stroke-width="1.5" fill="none" stroke-dasharray="6 3"/>
                  <path d="M10 150 L75 88" stroke="#1a3a2a" stroke-width="1" fill="none"/>
                  <path d="M10 150 L107 55" stroke="#1a3a2a" stroke-width="1" fill="none" opacity="0.6"/>
                  <path d="M270 150 L205 88" stroke="#1a3a2a" stroke-width="1" fill="none"/>
                  <path d="M270 150 L173 55" stroke="#1a3a2a" stroke-width="1" fill="none" opacity="0.6"/>
                  <path d="M5 150 L275 150" stroke="#1a3a2a" stroke-width="2" fill="none"/>
                  <rect x="38" y="108" width="30" height="18" rx="1" stroke="#1a3a2a" stroke-width="1" fill="none" transform="rotate(-35 38 108)"/>
                  <rect x="62" y="90" width="30" height="18" rx="1" stroke="#1a3a2a" stroke-width="1" fill="none" transform="rotate(-35 62 90)"/>
                  <rect x="188" y="108" width="30" height="18" rx="1" stroke="#1a3a2a" stroke-width="1" fill="none" transform="rotate(35 188 108)"/>
                  <rect x="164" y="90" width="30" height="18" rx="1" stroke="#1a3a2a" stroke-width="1" fill="none" transform="rotate(35 164 90)"/>
                </svg>
              </div>
            </div>
          )}

          <!-- Supply Scope -->
          <div class="mb-8">
            <div class="flex items-center gap-2 mb-5">
              <div class="w-6 h-0.5 bg-deep-green"></div>
              <h2 class="font-heading font-bold text-charcoal text-lg">Supply Scope Used in This Project</h2>
            </div>
            <div class="grid grid-cols-3 sm:grid-cols-6 gap-4">
              {supplyScope.map(item => (
                <div class="flex flex-col items-center text-center gap-2">
                  <div class="w-14 h-14 rounded-xl bg-soft-green text-deep-green flex items-center justify-center">
                    <Fragment set:html={icons[item.icon]} />
                  </div>
                  <span class="text-xs text-slate leading-snug whitespace-pre-line">{item.label}</span>
                </div>
              ))}
            </div>
          </div>

        </div>

      </div>
    </div>
  </section>

  <!-- ===== RELATED PROJECTS ===== -->
  {relatedProjects.length > 0 && (
    <section class="bg-soft-green py-12 border-t border-border">
      <div class="container mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center gap-2 mb-7">
          <div class="w-6 h-0.5 bg-deep-green"></div>
          <h2 class="font-heading font-bold text-charcoal text-xl">Related Projects</h2>
        </div>
        <div class="grid md:grid-cols-3 gap-5">
          {relatedProjects.map(rel => (
            <a href={`/projects/${rel.slug}/`} class="sunlit-card overflow-hidden block group">
              <div class="h-44 overflow-hidden">
                {rel.images?.[0] ? (
                  <img
                    src={rel.images[0]}
                    alt={rel.name}
                    class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                    loading="lazy"
                  />
                ) : (
                  <div class="h-44 bg-gradient-to-br from-soft-green to-border flex items-center justify-center">
                    <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="#1a3a2a" stroke-width="1" opacity="0.3"><rect x="3" y="4" width="18" height="14" rx="2"/><path d="M3 9h18M3 14h18M9 4v14M15 4v14"/></svg>
                  </div>
                )}
              </div>
              <div class="p-4">
                <h3 class="font-heading font-bold text-charcoal text-sm leading-snug mb-2 group-hover:text-deep-green transition-colors line-clamp-2">
                  {rel.name}
                </h3>
                <div class="flex items-center gap-2 text-xs text-slate">
                  <span>{rel.location}</span>
                  <span class="text-border">•</span>
                  <span class="text-deep-green font-heading font-semibold">{rel.system}</span>
                </div>
                <div class="mt-3 flex items-center justify-between">
                  <span class="text-xs text-slate">{rel.application}</span>
                  <svg class="text-amber group-hover:translate-x-1 transition-transform" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                </div>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

</Layout>
