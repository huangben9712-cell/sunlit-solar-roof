---
import Layout from '../../layouts/Layout.astro';
import { projects } from '../../data/projects.ts';

export function getStaticPaths() {
  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

interface Props {
  project: typeof projects[0];
}

const { project } = Astro.props;

if (!project) {
  return Astro.redirect('/projects/');
}

const relatedProjects = projects
  .filter((p) => p.system === project.system && p.id !== project.id)
  .slice(0, 3);
---

<Layout title={project.name}>
  <!-- Breadcrumb -->
  <section class="border-b border-gray-200">
    <div class="container mx-auto px-4 py-4">
      <div class="flex items-center gap-2 text-sm text-gray-600">
        <a href="/" class="hover:text-gray-900">Home</a>
        <span>/</span>
        <a href="/projects/" class="hover:text-gray-900">Projects</a>
        <span>/</span>
        <span class="text-gray-900 font-medium">{project.name}</span>
      </div>
    </div>
  </section>

  <!-- Hero -->
  <section class="py-12 md:py-16 bg-gradient-to-br from-green-50 to-transparent">
    <div class="container mx-auto px-4">
      <div class="max-w-3xl">
        <h1 class="text-4xl md:text-5xl font-bold mb-6 text-gray-900 leading-tight">
          {project.name}
        </h1>
        <div class="flex gap-4 flex-wrap">
          <span class="inline-block bg-blue-100 text-blue-700 text-sm font-semibold px-4 py-2 rounded-full">
            {project.system}
          </span>
          <span class="inline-block bg-green-100 text-green-700 text-sm font-semibold px-4 py-2 rounded-full">
            {project.application}
          </span>
          <span class="inline-block bg-gray-100 text-gray-700 text-sm font-semibold px-4 py-2 rounded-full">
            📍 {project.location}
          </span>
        </div>
      </div>
    </div>
  </section>

  <!-- Project Reference -->
  <section class="py-16 md:py-24 bg-white">
    <div class="container mx-auto px-4 max-w-4xl">
      <div class="grid md:grid-cols-3 gap-8">
        <!-- Main Content -->
        <div class="md:col-span-2">
          <div class="mb-8">
            <h2 class="text-2xl font-bold text-gray-900 mb-4">Project Reference</h2>
            <p class="text-gray-600 leading-relaxed">{project.summary}</p>
          </div>

          <div class="bg-blue-50 border border-blue-200 rounded-lg p-6">
            <p class="text-blue-900">
              <strong>This is a project reference.</strong> For detailed project information, technical specifications, or to discuss similar projects, please contact us.
            </p>
          </div>
        </div>

        <!-- Sidebar -->
        <div>
          <div class="bg-gray-50 rounded-lg p-6 sticky top-4">
            <h3 class="font-bold text-gray-900 mb-4">Project Details</h3>
            
            <div class="mb-4 pb-4 border-b border-gray-200">
              <p class="text-sm text-gray-600 mb-1">Location</p>
              <p class="font-semibold text-gray-900">{project.location}</p>
            </div>

            <div class="mb-4 pb-4 border-b border-gray-200">
              <p class="text-sm text-gray-600 mb-1">System</p>
              <p class="font-semibold text-gray-900">{project.system}</p>
            </div>

            <div class="mb-4">
              <p class="text-sm text-gray-600 mb-1">Application</p>
              <p class="font-semibold text-gray-900">{project.application}</p>
            </div>

            <a href="/contact/" class="w-full block text-center bg-green-700 hover:bg-green-800 text-white font-semibold py-3 rounded-lg transition mt-6">
              Discuss Similar Project →
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Related Projects -->
  {relatedProjects.length > 0 && (
    <section class="py-16 md:py-24 bg-gray-50">
      <div class="container mx-auto px-4">
        <h2 class="text-3xl font-bold text-gray-900 mb-12 text-center">Related Projects</h2>
        <div class="grid md:grid-cols-3 gap-6 max-w-4xl mx-auto">
          {relatedProjects.map((relatedProject) => (
            <a href={`/projects/${relatedProject.slug}/`} class="bg-white border border-gray-200 rounded-lg overflow-hidden hover:shadow-lg transition">
              <div class="h-40 bg-gradient-to-br from-gray-200 to-gray-300"></div>
              <div class="p-6">
                <h3 class="font-bold text-gray-900 mb-2 line-clamp-2 hover:text-green-700">{relatedProject.name}</h3>
                <p class="text-sm text-gray-600 mb-4 flex items-center gap-1">
                  📍 {relatedProject.location}
                </p>
                <div class="flex gap-2 flex-wrap">
                  <span class="inline-block bg-blue-100 text-blue-700 text-xs font-semibold px-3 py-1 rounded-full">
                    {relatedProject.system}
                  </span>
                  <span class="inline-block bg-green-100 text-green-700 text-xs font-semibold px-3 py-1 rounded-full">
                    {relatedProject.application}
                  </span>
                </div>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- CTA -->
  <section class="py-16 md:py-20 bg-green-700 text-white">
    <div class="container mx-auto px-4 text-center">
      <h2 class="text-3xl md:text-4xl font-bold mb-4">Interested in a Similar Project?</h2>
      <p class="text-lg mb-8 text-green-100 max-w-2xl mx-auto">
        Send your roof drawing and project details. We'll help you evaluate the right system.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/contact/" class="px-8 py-3 bg-white text-green-700 font-semibold rounded-lg hover:bg-gray-100 transition">
          Submit Project Inquiry →
        </a>
        <a href="/projects/" class="px-8 py-3 border-2 border-white text-white font-semibold rounded-lg hover:bg-white/10 transition">
          View All Projects
        </a>
      </div>
    </div>
  </section>
</Layout>
