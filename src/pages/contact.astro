---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Get Factory Pricing - Sunlit Solar Roof">
  <section class="py-16 bg-white">
    <div class="container mx-auto px-4 max-w-4xl">
      <p class="sunlit-overline mb-4">Factory Quote Request</p>
      <h1 class="text-4xl md:text-5xl font-bold mb-6">Get Factory Pricing for a Solar Roof Project</h1>
      <p class="text-lg text-gray-600 mb-8">
        Send your project country, roof area, buyer role, preferred product line and roof drawing if available. We will help define the factory supply scope, active and inactive coverage, accessories and quotation direction.
      </p>
      <div class="grid md:grid-cols-2 gap-8">
        <div>
          <h2 class="text-2xl font-bold mb-4">China Manufacturer Contact</h2>
          <p class="mb-2"><a href="mailto:info@sunlitsolarroof.com" class="text-green-700 font-semibold">info@sunlitsolarroof.com</a></p>
          <p class="text-gray-600 mb-6">Changzhou, Jiangsu, China</p>
          <div class="rounded-2xl bg-[#f8faf8] border border-[var(--border)] p-5 text-sm text-[var(--slate)] leading-relaxed">
            <p class="font-extrabold text-[var(--charcoal)] mb-2">What we quote</p>
            <p>Active solar roof tiles or sheets, matching inactive roof elements, flashing, fixings, roof accessories, packing and export delivery scope. Local installation and electrical work should be handled by qualified local professionals.</p>
          </div>
        </div>
        <form class="space-y-4" method="POST" action="/thank-you/">
          <input name="name" required placeholder="Full Name" class="w-full border rounded-lg px-4 py-3" />
          <input name="email" type="email" required placeholder="Email" class="w-full border rounded-lg px-4 py-3" />
          <input name="company" required placeholder="Company" class="w-full border rounded-lg px-4 py-3" />
          <input name="country" required placeholder="Project Country / Region" class="w-full border rounded-lg px-4 py-3" />
          <select name="buyerType" required class="w-full border rounded-lg px-4 py-3">
            <option value="">Buyer Type</option>
            <option value="distributor">Distributor / Importer</option>
            <option value="installer">Solar Installer</option>
            <option value="contractor">Roofing Contractor</option>
            <option value="developer">Developer</option>
            <option value="other">Other</option>
          </select>
          <textarea name="message" required placeholder="Project description, roof area, preferred system, delivery destination, roof drawing link if available" class="w-full border rounded-lg px-4 py-3 h-32"></textarea>
          <button type="submit" class="w-full bg-green-700 text-white font-semibold py-3 rounded-lg">Request Factory Quote</button>
        </form>
      </div>
    </div>
  </section>
</Layout>
