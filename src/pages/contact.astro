---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Get Factory Pricing — Sunlit Solar Roof" description="Start a factory pricing conversation for complete solar roof systems. Lumina Slate glass tiles, Storm Guard metal sheets, inactive elements and accessories.">

  <!-- Split layout: left info panel + right form -->
  <div class="min-h-screen grid md:grid-cols-2">

    <!-- Left: Info panel with dark background -->
    <div class="bg-charcoal relative overflow-hidden flex flex-col justify-between p-10 md:p-14 min-h-[50vh] md:min-h-screen">
      <!-- Background image -->
      <img
        src="/images/projects/pioneer-residential-retrofit/retrofitted-solar-roof-urban-villa.webp"
        alt="Completed solar roof project"
        class="absolute inset-0 w-full h-full object-cover opacity-20"
      />
      <div class="relative z-10 flex flex-col h-full justify-between">
        <!-- Top: Logo area -->
        <div>
          <a href="/" class="inline-flex items-center gap-2 mb-12">
            <span class="font-heading font-bold text-white text-lg">Sunlit</span>
          </a>
        </div>

        <!-- Middle: Headline -->
        <div class="flex-1 flex flex-col justify-center py-8">
          <p class="text-xs font-heading font-bold uppercase tracking-widest text-white/40 mb-4">Factory Direct</p>
          <h1 class="font-heading font-bold text-3xl md:text-4xl text-white leading-tight mb-6">
            Get Factory Pricing or Ask a Product Question
          </h1>
          <p class="text-white/60 leading-relaxed mb-10 max-w-sm">
            A roof drawing helps, but it is not required for the first message.
            Send your country, roof area, project type or any basic question.
          </p>

          <!-- Trust signals -->
          <div class="space-y-4">
            {[
              { icon: 'M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z', text: 'info@sunlitsolarroof.com' },
              { icon: 'M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z', text: 'Changzhou, Jiangsu, China' },
              { icon: 'M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z', text: 'Typically reply within 1 business day' },
            ].map((item) => (
              <div class="flex items-center gap-3">
                <div class="w-8 h-8 rounded-full bg-white/10 flex items-center justify-center shrink-0">
                  <svg class="w-4 h-4 text-white/60" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={item.icon} />
                  </svg>
                </div>
                <span class="text-sm text-white/60">{item.text}</span>
              </div>
            ))}
          </div>
        </div>

        <!-- Bottom: What we can discuss -->
        <div class="border-t border-white/10 pt-6 mt-6">
          <p class="text-xs font-heading font-bold uppercase tracking-widest text-white/30 mb-3">What we can discuss</p>
          <p class="text-sm text-white/50 leading-relaxed">
            Product fit, rough budget, active and inactive roof elements, matching accessories, samples, packing, shipping terms and project-based quotation direction.
          </p>
        </div>
      </div>
    </div>

    <!-- Right: Form panel -->
    <div class="bg-white flex items-center justify-center p-8 md:p-14">
      <div class="w-full max-w-md">
        <h2 class="font-heading font-bold text-2xl text-charcoal mb-2">Start the conversation</h2>
        <p class="text-sm text-slate mb-8">No full drawing required for the first message.</p>

        <form class="space-y-4" method="POST" action="/thank-you/">

          <!-- Name + Email row -->
          <div class="grid grid-cols-2 gap-3">
            <div>
              <label class="block text-xs font-heading font-bold text-charcoal mb-1.5">Full Name <span class="text-red-400">*</span></label>
              <input
                name="name"
                required
                placeholder="Your name"
                class="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm text-charcoal placeholder-slate/40 focus:outline-none focus:border-deep-green focus:ring-1 focus:ring-deep-green transition-colors"
              />
            </div>
            <div>
              <label class="block text-xs font-heading font-bold text-charcoal mb-1.5">Email <span class="text-red-400">*</span></label>
              <input
                name="email"
                type="email"
                required
                placeholder="you@company.com"
                class="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm text-charcoal placeholder-slate/40 focus:outline-none focus:border-deep-green focus:ring-1 focus:ring-deep-green transition-colors"
              />
            </div>
          </div>

          <!-- Company -->
          <div>
            <label class="block text-xs font-heading font-bold text-charcoal mb-1.5">Company / Organization <span class="text-slate/40 font-normal">(optional)</span></label>
            <input
              name="company"
              placeholder="Your company name"
              class="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm text-charcoal placeholder-slate/40 focus:outline-none focus:border-deep-green focus:ring-1 focus:ring-deep-green transition-colors"
            />
          </div>

          <!-- Country -->
          <div>
            <label class="block text-xs font-heading font-bold text-charcoal mb-1.5">Project Country / Delivery Region <span class="text-slate/40 font-normal">(optional)</span></label>
            <input
              name="country"
              placeholder="e.g. United States, Germany, Australia"
              class="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm text-charcoal placeholder-slate/40 focus:outline-none focus:border-deep-green focus:ring-1 focus:ring-deep-green transition-colors"
            />
          </div>

          <!-- Buyer Type + Product Interest row -->
          <div class="grid grid-cols-2 gap-3">
            <div>
              <label class="block text-xs font-heading font-bold text-charcoal mb-1.5">Buyer Type <span class="text-slate/40 font-normal">(optional)</span></label>
              <select name="buyerType" class="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm text-charcoal focus:outline-none focus:border-deep-green focus:ring-1 focus:ring-deep-green transition-colors bg-white">
                <option value="">Select...</option>
                <option value="distributor">Distributor / Importer</option>
                <option value="installer">Solar Installer</option>
                <option value="contractor">Roofing Contractor</option>
                <option value="developer">Developer</option>
                <option value="homeowner">Project Owner</option>
                <option value="other">Other</option>
              </select>
            </div>
            <div>
              <label class="block text-xs font-heading font-bold text-charcoal mb-1.5">Product Interest <span class="text-slate/40 font-normal">(optional)</span></label>
              <select name="productInterest" class="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm text-charcoal focus:outline-none focus:border-deep-green focus:ring-1 focus:ring-deep-green transition-colors bg-white">
                <option value="">Select...</option>
                <option value="lumina-slate">Lumina Slate</option>
                <option value="storm-guard">Storm Guard</option>
                <option value="not-sure">Not sure yet</option>
              </select>
            </div>
          </div>

          <!-- Message -->
          <div>
            <label class="block text-xs font-heading font-bold text-charcoal mb-1.5">Message <span class="text-red-400">*</span></label>
            <textarea
              name="message"
              required
              placeholder="Tell us what you know today: rough roof area, project type, target country, question, or drawing/photo link if available"
              class="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm text-charcoal placeholder-slate/40 focus:outline-none focus:border-deep-green focus:ring-1 focus:ring-deep-green transition-colors h-32 resize-none"
            ></textarea>
          </div>

          <!-- Submit -->
          <button
            type="submit"
            class="w-full bg-deep-green text-white font-heading font-bold py-3.5 rounded-full hover:bg-deep-green/90 transition-colors text-sm"
          >
            Start Factory Pricing Conversation
          </button>

          <!-- Useful info note -->
          <div class="bg-soft-green rounded-xl p-4">
            <p class="text-xs font-heading font-bold text-charcoal mb-2">Useful to include, not mandatory</p>
            <ul class="text-xs text-slate space-y-1">
              <li>· Project country or delivery destination</li>
              <li>· Estimated roof area or building type</li>
              <li>· Preferred product line: Lumina Slate or Storm Guard</li>
              <li>· Photos, sketches or roof drawings if available</li>
            </ul>
          </div>

        </form>
      </div>
    </div>

  </div>

</Layout>
