---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Downloads & Technical Documents — Sunlit Solar Roof" description="Product datasheets and certification documents for B2B solar roof evaluation. Lumina Slate and Storm Guard technical specifications.">

  <!-- Hero -->
  <section class="bg-white border-b border-gray-100 pt-16 pb-12">
    <div class="max-w-4xl mx-auto px-6 text-center">
      <p class="text-xs font-heading font-bold uppercase tracking-widest text-deep-green mb-4">Downloads</p>
      <h1 class="font-heading font-bold text-4xl md:text-5xl text-charcoal leading-tight mb-5">
        Downloads & Technical Documents
      </h1>
      <p class="text-lg text-slate leading-relaxed max-w-2xl mx-auto">
        Product datasheets and available certification documents for early B2B evaluation.
        Project-specific documents are provided according to project stage.
      </p>
    </div>
  </section>

  <!-- Product Datasheets -->
  <section class="py-16 bg-white">
    <div class="max-w-4xl mx-auto px-6">
      <h2 class="font-heading font-bold text-2xl text-charcoal mb-2">Product Datasheets</h2>
      <p class="text-slate mb-10">Technical specifications for both product lines. Download directly for offline review.</p>

      <div class="grid md:grid-cols-2 gap-6">

        <!-- Lumina Slate Datasheet -->
        <div class="border border-gray-200 rounded-2xl overflow-hidden hover:shadow-md transition-shadow">
          <div class="h-36 bg-gradient-to-br from-deep-green to-[#1a3a2a] relative overflow-hidden flex items-end p-6">
            <img
              src="/images/components/lumina-slate/active-solar-tile.webp"
              alt="Lumina Slate active solar tile"
              class="absolute inset-0 w-full h-full object-cover opacity-30"
            />
            <div class="relative">
              <span class="text-xs font-heading font-bold uppercase tracking-widest text-white/50 block mb-1">Glass Tile Line</span>
              <span class="font-heading font-bold text-white text-xl">Lumina Slate</span>
            </div>
          </div>
          <div class="p-6">
            <p class="text-sm text-slate leading-relaxed mb-1">Active solar tile · 70W · 1240 × 390 mm · Mono PERC · Double glass</p>
            <p class="text-xs text-slate/60 mb-5">Includes electrical specs, dimensions, installation overview and product images.</p>
            <div class="flex items-center gap-3">
              <a
                href="/downloads/lumina-slate-technical-datasheet.pdf"
                download="Lumina-Slate-Technical-Datasheet.pdf"
                class="inline-flex items-center gap-2 bg-deep-green text-white font-heading font-bold text-sm px-5 py-2.5 rounded-full hover:bg-deep-green/90 transition-colors"
              >
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
                </svg>
                Download PDF
              </a>
              <a
                href="/downloads/lumina-slate-technical-datasheet.pdf"
                target="_blank"
                rel="noopener"
                class="text-sm text-deep-green font-heading font-bold hover:underline"
              >
                View &#8594;
              </a>
            </div>
          </div>
        </div>

        <!-- Storm Guard Datasheet — Request -->
        <div class="border border-gray-200 rounded-2xl overflow-hidden hover:shadow-md transition-shadow">
          <div class="h-36 bg-gradient-to-br from-[#2a3a2a] to-[#1a2a1a] relative overflow-hidden flex items-end p-6">
            <img
              src="/images/components/storm-guard/active-solar-tile.webp"
              alt="Storm Guard active solar tile"
              class="absolute inset-0 w-full h-full object-cover opacity-30"
            />
            <div class="relative">
              <span class="text-xs font-heading font-bold uppercase tracking-widest text-white/50 block mb-1">Metal Sheet Line</span>
              <span class="font-heading font-bold text-white text-xl">Storm Guard</span>
            </div>
          </div>
          <div class="p-6">
            <p class="text-sm text-slate leading-relaxed mb-1">Active solar sheet · 135W · 1950 × 420 mm · Mono TOPCON · IP68</p>
            <p class="text-xs text-slate/60 mb-5">Full technical datasheet available on request. Typically provided with sample or quotation.</p>
            <div class="flex items-center gap-3">
              <a
                href="/contact/"
                class="inline-flex items-center gap-2 bg-deep-green text-white font-heading font-bold text-sm px-5 py-2.5 rounded-full hover:bg-deep-green/90 transition-colors"
              >
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
                Request Datasheet
              </a>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- Divider -->
  <div class="max-w-4xl mx-auto px-6"><hr class="border-gray-100" /></div>

  <!-- Certification Documents -->
  <section class="py-16 bg-white">
    <div class="max-w-4xl mx-auto px-6">
      <h2 class="font-heading font-bold text-2xl text-charcoal mb-2">Certification Documents</h2>
      <p class="text-slate mb-10">
        Our products are tested and certified to international standards.
        Specific certificate copies are available for active project evaluation.
      </p>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4 mb-8">
        <div class="flex items-start gap-3 p-4 bg-soft-green rounded-xl">
          <div class="w-8 h-8 rounded-full bg-deep-green/10 flex items-center justify-center shrink-0 mt-0.5">
            <svg class="w-4 h-4 text-deep-green" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>
          </div>
          <div>
            <p class="font-heading font-bold text-sm text-charcoal leading-snug">IEC 61215 / IEC 61730</p>
            <p class="text-xs text-slate mt-0.5">PV module performance and safety</p>
          </div>
        </div>
        <div class="flex items-start gap-3 p-4 bg-soft-green rounded-xl">
          <div class="w-8 h-8 rounded-full bg-deep-green/10 flex items-center justify-center shrink-0 mt-0.5">
            <svg class="w-4 h-4 text-deep-green" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>
          </div>
          <div>
            <p class="font-heading font-bold text-sm text-charcoal leading-snug">IP68 Waterproof Rating</p>
            <p class="text-xs text-slate mt-0.5">Tested to full waterproof immersion standard</p>
          </div>
        </div>
        <div class="flex items-start gap-3 p-4 bg-soft-green rounded-xl">
          <div class="w-8 h-8 rounded-full bg-deep-green/10 flex items-center justify-center shrink-0 mt-0.5">
            <svg class="w-4 h-4 text-deep-green" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>
          </div>
          <div>
            <p class="font-heading font-bold text-sm text-charcoal leading-snug">ISO 9001</p>
            <p class="text-xs text-slate mt-0.5">Quality management system certification</p>
          </div>
        </div>
        <div class="flex items-start gap-3 p-4 bg-soft-green rounded-xl">
          <div class="w-8 h-8 rounded-full bg-deep-green/10 flex items-center justify-center shrink-0 mt-0.5">
            <svg class="w-4 h-4 text-deep-green" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>
          </div>
          <div>
            <p class="font-heading font-bold text-sm text-charcoal leading-snug">CE Marking</p>
            <p class="text-xs text-slate mt-0.5">European conformity for electrical safety</p>
          </div>
        </div>
        <div class="flex items-start gap-3 p-4 bg-soft-green rounded-xl">
          <div class="w-8 h-8 rounded-full bg-deep-green/10 flex items-center justify-center shrink-0 mt-0.5">
            <svg class="w-4 h-4 text-deep-green" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>
          </div>
          <div>
            <p class="font-heading font-bold text-sm text-charcoal leading-snug">Fire Rating (Grade A)</p>
            <p class="text-xs text-slate mt-0.5">Roof fire resistance classification</p>
          </div>
        </div>
        <div class="flex items-start gap-3 p-4 bg-soft-green rounded-xl">
          <div class="w-8 h-8 rounded-full bg-deep-green/10 flex items-center justify-center shrink-0 mt-0.5">
            <svg class="w-4 h-4 text-deep-green" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>
          </div>
          <div>
            <p class="font-heading font-bold text-sm text-charcoal leading-snug">Hail Impact Test</p>
            <p class="text-xs text-slate mt-0.5">35mm hail resistance — IEC 61215 Annex D</p>
          </div>
        </div>
      </div>

      <div class="bg-gray-50 rounded-2xl p-5 flex items-start gap-4">
        <svg class="w-5 h-5 text-deep-green shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        <p class="text-sm text-slate leading-relaxed">
          <strong class="text-charcoal">Project-specific certificate review</strong> — If you need to verify specific certifications for a project or tender, send us an email at
          <a href="mailto:info@sunlitsolarroof.com" class="text-deep-green font-semibold hover:underline">info@sunlitsolarroof.com</a>.
          We can share relevant certificate copies directly.
        </p>
      </div>
    </div>
  </section>

  <!-- Divider -->
  <div class="max-w-4xl mx-auto px-6"><hr class="border-gray-100" /></div>

  <!-- Project Document Pack -->
  <section class="py-16 bg-white">
    <div class="max-w-4xl mx-auto px-6">
      <div class="grid md:grid-cols-2 gap-12 items-center">
        <div>
          <p class="text-xs font-heading font-bold uppercase tracking-widest text-deep-green mb-4">Project Documents</p>
          <h2 class="font-heading font-bold text-2xl md:text-3xl text-charcoal mb-5 leading-tight">
            Need a Project Document Pack?
          </h2>
          <p class="text-slate leading-relaxed mb-6">
            BOM, packing list, installation notes, warranty terms and quotation documents are not generic downloads —
            they are prepared according to your specific project scope, product selection and delivery destination.
          </p>
          <p class="text-slate leading-relaxed mb-8">
            Share your roof area, location and product line preference. We will prepare the relevant documents for your project stage.
          </p>
          <a href="/contact/" class="inline-flex items-center gap-2 bg-amber text-charcoal font-heading font-bold px-6 py-3 rounded-full hover:bg-amber/90 transition-colors">
            Request Project Document Pack
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
        </div>
        <div class="space-y-3">
          <div class="flex items-center justify-between py-3 border-b border-gray-100">
            <span class="font-heading font-bold text-sm text-charcoal">Bill of Materials (BOM)</span>
            <span class="text-xs text-slate bg-gray-100 px-3 py-1 rounded-full">Prepared per project scope</span>
          </div>
          <div class="flex items-center justify-between py-3 border-b border-gray-100">
            <span class="font-heading font-bold text-sm text-charcoal">Packing List</span>
            <span class="text-xs text-slate bg-gray-100 px-3 py-1 rounded-full">Prepared at production stage</span>
          </div>
          <div class="flex items-center justify-between py-3 border-b border-gray-100">
            <span class="font-heading font-bold text-sm text-charcoal">Installation Notes</span>
            <span class="text-xs text-slate bg-gray-100 px-3 py-1 rounded-full">Provided with confirmed order</span>
          </div>
          <div class="flex items-center justify-between py-3 border-b border-gray-100">
            <span class="font-heading font-bold text-sm text-charcoal">Warranty Terms</span>
            <span class="text-xs text-slate bg-gray-100 px-3 py-1 rounded-full">Provided with confirmed order</span>
          </div>
          <div class="flex items-center justify-between py-3 border-b border-gray-100">
            <span class="font-heading font-bold text-sm text-charcoal">Quotation Document</span>
            <span class="text-xs text-slate bg-gray-100 px-3 py-1 rounded-full">Prepared per project inquiry</span>
          </div>
          <div class="flex items-center justify-between py-3">
            <span class="font-heading font-bold text-sm text-charcoal">Export Documents</span>
            <span class="text-xs text-slate bg-gray-100 px-3 py-1 rounded-full">Commercial invoice, COO</span>
          </div>
        </div>
      </div>
    </div>
  </section>

</Layout>
