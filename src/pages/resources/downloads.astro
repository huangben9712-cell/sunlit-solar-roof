---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Downloads - Sunlit Solar Roof">
  <section class="bg-soft-green py-16 md:py-20">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 text-center max-w-4xl">
      <p class="sunlit-overline mb-4">Downloads</p>
      <h1 class="sunlit-section-title text-4xl md:text-5xl text-charcoal mb-6">
        Product Documents
      </h1>
      <p class="text-lg text-slate leading-relaxed max-w-3xl mx-auto">
        Datasheets, certificates, installation guides and other technical documents.
      </p>
    </div>
  </section>
  <section class="py-16 bg-white">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-xl text-slate">Downloads will be available here soon.</p>
    </div>
  </section>
</Layout>
