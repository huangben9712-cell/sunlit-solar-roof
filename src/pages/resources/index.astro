---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Resources - Sunlit Solar Roof">
  <section class="bg-soft-green py-16 md:py-20">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 text-center max-w-4xl">
      <p class="sunlit-overline mb-4">Resources</p>
      <h1 class="sunlit-section-title text-4xl md:text-5xl text-charcoal mb-6">
        Learn & Explore
      </h1>
      <p class="text-lg text-slate leading-relaxed max-w-3xl mx-auto mb-10">
        Technical guides, product documents and market insights for B2B buyers.
      </p>
    </div>
  </section>
  <section class="py-10 bg-white">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/resources/knowledge-base/" class="sunlit-btn-primary">Knowledge Base</a>
        <a href="/resources/downloads/" class="sunlit-btn-secondary">Downloads</a>
      </div>
    </div>
  </section>
</Layout>
