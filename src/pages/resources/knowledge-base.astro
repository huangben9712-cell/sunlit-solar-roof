---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Knowledge Base - Sunlit Solar Roof">
  <section class="bg-soft-green py-16 md:py-20">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 text-center max-w-4xl">
      <p class="sunlit-overline mb-4">Knowledge Base</p>
      <h1 class="sunlit-section-title text-4xl md:text-5xl text-charcoal mb-6">
        Articles & Guides
      </h1>
      <p class="text-lg text-slate leading-relaxed max-w-3xl mx-auto">
        Technical guides, market insights, and installation resources for B2B solar roof buyers.
      </p>
    </div>
  </section>
  <section class="py-16 bg-white">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-xl text-slate">Browse our <a href="/articles/" class="text-deep-green font-bold hover:text-amber">articles</a> for detailed guides and insights.</p>
    </div>
  </section>
</Layout>
