---
import Layout from '../../layouts/Layout.astro';
import { blogPosts } from '../../data/blog';

const publishedPosts = blogPosts.filter(p => p.priority === 'P0' || p.priority === 'P1');

const categories = [
  { key: 'Technical & Installation', label: 'Technical & Installation', desc: 'Installation guides, electrical system selection, and product specifications.' },
  { key: 'Products & Case Studies', label: 'Products & Case Studies', desc: 'Real project walkthroughs and deep dives into Lumina Slate and Storm Guard.' },
  { key: 'Importing & Sourcing', label: 'Importing & Sourcing', desc: 'How to source, evaluate and import solar roof systems from China.' },
  { key: 'Market Insights & ROI', label: 'Market Insights & ROI', desc: 'Market trends, ROI analysis and business model perspectives.' },
];

const postsByCategory = categories.map(cat => ({
  ...cat,
  posts: publishedPosts.filter(p => p.category === cat.key),
})).filter(cat => cat.posts.length > 0);

const featuredPost = publishedPosts.find(p => p.priority === 'P0');
---

<Layout title="Knowledge Base — Sunlit Solar Roof" description="Technical guides, market insights, and sourcing resources for B2B solar roof buyers. 13 articles covering installation, importing, ROI and product deep dives.">

  <!-- Hero -->
  <section class="bg-charcoal relative overflow-hidden py-20 md:py-28">
    <div class="absolute inset-0 opacity-10">
      <img src="/images/projects/large-scale-commercial-complex/storm-guard-large-scale-bipv-integration-aerial-scaled.webp" alt="" class="w-full h-full object-cover" />
    </div>
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 relative z-10 max-w-4xl">
      <p class="text-xs font-heading font-bold uppercase tracking-widest text-white/40 mb-4">Resources</p>
      <h1 class="font-heading font-bold text-4xl md:text-5xl text-white leading-tight mb-6">Knowledge Base</h1>
      <p class="text-lg text-white/60 leading-relaxed max-w-2xl mb-8">
        {publishedPosts.length} articles covering installation, sourcing, ROI and product deep dives — written for B2B buyers evaluating solar roof systems.
      </p>
      <div class="flex flex-wrap gap-2">
        {categories.map(cat => (
          <a
            href={`#${cat.key.toLowerCase().replace(/[^a-z0-9]+/g, '-')}`}
            class="inline-flex items-center px-3 py-1.5 rounded-full bg-white/10 hover:bg-white/20 transition-colors text-xs font-heading font-bold text-white/70 hover:text-white"
          >
            {cat.label}
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- New Explainer Pages Highlight -->
  <section class="bg-white py-12 border-b border-border">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-6xl">
      <p class="text-xs font-heading font-bold uppercase tracking-widest text-deep-green mb-6">Start Here</p>
      <div class="grid md:grid-cols-2 gap-6">
        <a href="/resources/knowledge-base/what-is-solar-roof/" class="group rounded-2xl border border-border hover:border-deep-green/40 hover:shadow-md transition-all overflow-hidden flex gap-0">
          <div class="w-32 flex-shrink-0 overflow-hidden">
            <img src="/images/projects/hangzhou-xianghu-arcadia-villa/sunlit-bipv-solar-roof-aerial-view-hangzhou-xianghu.webp" alt="What is a solar roof" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
          </div>
          <div class="p-5 flex-1">
            <p class="text-xs font-heading font-bold text-deep-green mb-2">Explainer Guide</p>
            <h3 class="font-heading font-bold text-charcoal group-hover:text-deep-green transition-colors mb-1">What Is a Solar Roof?</h3>
            <p class="text-sm text-slate leading-relaxed">How it works, what components it includes, and how it differs from conventional roofing.</p>
          </div>
        </a>
        <a href="/solar-roof-vs-solar-panels/" class="group rounded-2xl border border-border hover:border-deep-green/40 hover:shadow-md transition-all overflow-hidden flex gap-0">
          <div class="w-32 flex-shrink-0 overflow-hidden">
            <img src="/images/projects/xuzhou-luxury-villa-the-ultimate-bipv-vs-bapv-contrast/sunlit-bipv-vs-bapv-solar-roof-comparison.webp" alt="Solar roof vs solar panels" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
          </div>
          <div class="p-5 flex-1">
            <p class="text-xs font-heading font-bold text-deep-green mb-2">Comparison Guide</p>
            <h3 class="font-heading font-bold text-charcoal group-hover:text-deep-green transition-colors mb-1">Solar Roof vs Solar Panels</h3>
            <p class="text-sm text-slate leading-relaxed">Cost, efficiency, aesthetics, application range — full data comparison side by side.</p>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- Featured article -->
  {featuredPost && (
    <section class="bg-soft-green py-12 border-b border-border">
      <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-6xl">
        <p class="text-xs font-heading font-bold uppercase tracking-widest text-deep-green mb-6">Featured Article</p>
        <a href={`/articles/${featuredPost.slug}/`} class="group grid md:grid-cols-5 gap-8 items-center">
          <div class="md:col-span-3">
            <span class="inline-block text-xs font-heading font-bold text-deep-green bg-deep-green/10 px-3 py-1 rounded-full mb-4">
              {featuredPost.category}
            </span>
            <h2 class="font-heading font-bold text-2xl md:text-3xl text-charcoal leading-tight mb-4 group-hover:text-deep-green transition-colors">
              {featuredPost.title}
            </h2>
            <p class="text-slate leading-relaxed mb-6 max-w-xl">{featuredPost.summary}</p>
            <span class="inline-flex items-center gap-2 font-heading font-bold text-deep-green group-hover:text-amber transition-colors">
              Read Article
              <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </span>
          </div>
          <div class="md:col-span-2 rounded-2xl overflow-hidden bg-charcoal aspect-video">
            <img
              src="/images/projects/pioneer-residential-retrofit/retrofitted-solar-roof-urban-villa.webp"
              alt={featuredPost.title}
              class="w-full h-full object-cover opacity-80 group-hover:opacity-100 group-hover:scale-105 transition-all duration-500"
            />
          </div>
        </a>
      </div>
    </section>
  )}

  <!-- Articles by category -->
  <section class="py-16 md:py-20 bg-white">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-6xl">
      <div class="space-y-16">
        {postsByCategory.map((cat) => (
          <div id={cat.key.toLowerCase().replace(/[^a-z0-9]+/g, '-')}>
            <div class="flex items-end justify-between mb-8 pb-4 border-b border-border">
              <div>
                <p class="text-xs font-heading font-bold uppercase tracking-widest text-deep-green mb-1">{cat.posts.length} {cat.posts.length === 1 ? 'article' : 'articles'}</p>
                <h2 class="font-heading font-bold text-2xl text-charcoal">{cat.label}</h2>
                <p class="text-sm text-slate mt-1">{cat.desc}</p>
              </div>
            </div>
            <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-5">
              {cat.posts.map((post) => (
                <a
                  href={`/articles/${post.slug}/`}
                  class="group block rounded-2xl border border-border hover:border-deep-green/30 hover:shadow-md transition-all duration-200 overflow-hidden"
                >
                  <div class="h-1.5 bg-deep-green/20 group-hover:bg-deep-green transition-colors duration-200"></div>
                  <div class="p-6">
                    <p class="text-xs font-heading font-bold text-deep-green mb-3">{post.category}</p>
                    <h3 class="font-heading font-bold text-lg text-charcoal leading-snug mb-3 group-hover:text-deep-green transition-colors">
                      {post.title}
                    </h3>
                    <p class="text-sm text-slate leading-relaxed mb-5 line-clamp-3">{post.summary}</p>
                    <span class="inline-flex items-center gap-1.5 text-sm font-heading font-bold text-deep-green group-hover:text-amber transition-colors">
                      Read Article
                      <svg class="w-3.5 h-3.5 group-hover:translate-x-0.5 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7" />
                      </svg>
                    </span>
                  </div>
                </a>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Bottom CTA -->
  <section class="bg-charcoal py-16">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-3xl text-center">
      <p class="text-xs font-heading font-bold uppercase tracking-widest text-white/30 mb-4">Ready to evaluate?</p>
      <h2 class="font-heading font-bold text-3xl text-white mb-4">Have a specific project in mind?</h2>
      <p class="text-white/60 mb-8 leading-relaxed">
        Share your roof area, country and project type. We will recommend the right product line and prepare the relevant documents.
      </p>
      <div class="flex flex-wrap gap-3 justify-center">
        <a href="/contact/" class="inline-flex items-center gap-2 bg-amber text-charcoal font-heading font-bold px-6 py-3 rounded-full hover:bg-amber/90 transition-colors">
          Get Factory Pricing
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
        <a href="/resources/downloads/" class="inline-flex items-center gap-2 border border-white/20 text-white font-heading font-bold px-6 py-3 rounded-full hover:bg-white/10 transition-colors">
          Download Datasheets
        </a>
      </div>
    </div>
  </section>

</Layout>
