---
import Layout from '../../layouts/Layout.astro';
import { resources, getResourceBySlug } from '../../data/resources.ts';

export function getStaticPaths() {
  return resources.map((resource) => ({
    params: { slug: resource.slug },
    props: { resource },
  }));
}

interface Props {
  resource: typeof resources[0];
}

const { resource } = Astro.props;

if (!resource) {
  return Astro.redirect('/resources/');
}

const relatedResources = resources
  .filter((r) => r.category === resource.category && r.id !== resource.id)
  .slice(0, 3);
---

<Layout title={resource.title}>
  <!-- Breadcrumb -->
  <section class="border-b border-gray-200">
    <div class="container mx-auto px-4 py-4">
      <div class="flex items-center gap-2 text-sm text-gray-600">
        <a href="/" class="hover:text-gray-900">Home</a>
        <span>/</span>
        <a href="/resources/" class="hover:text-gray-900">Resources</a>
        <span>/</span>
        <span class="text-gray-900 font-medium">{resource.title}</span>
      </div>
    </div>
  </section>

  <!-- Hero -->
  <section class="py-12 md:py-16 bg-gradient-to-br from-green-50 to-transparent">
    <div class="container mx-auto px-4">
      <div class="max-w-3xl">
        <h1 class="text-4xl md:text-5xl font-bold mb-6 text-gray-900 leading-tight">
          {resource.title}
        </h1>
        <div class="flex gap-4 flex-wrap">
          <span class="inline-block bg-blue-100 text-blue-700 text-sm font-semibold px-4 py-2 rounded-full">
            {resource.type}
          </span>
          <span class="inline-block bg-green-100 text-green-700 text-sm font-semibold px-4 py-2 rounded-full">
            {resource.category}
          </span>
          {resource.relatedSystem && (
            <span class="inline-block bg-amber-100 text-amber-700 text-sm font-semibold px-4 py-2 rounded-full">
              {resource.relatedSystem}
            </span>
          )}
        </div>
      </div>
    </div>
  </section>

  <!-- Resource Details -->
  <section class="py-16 md:py-24 bg-white">
    <div class="container mx-auto px-4 max-w-4xl">
      <div class="grid md:grid-cols-3 gap-8">
        <!-- Main Content -->
        <div class="md:col-span-2">
          <div class="mb-8">
            <h2 class="text-2xl font-bold text-gray-900 mb-4">Overview</h2>
            <p class="text-gray-600 leading-relaxed text-lg">{resource.summary}</p>
          </div>

          {resource.content && (
            <div class="mb-8">
              <h2 class="text-2xl font-bold text-gray-900 mb-4">Details</h2>
              <p class="text-gray-600 leading-relaxed">{resource.content}</p>
            </div>
          )}

          <div class="bg-blue-50 border-l-4 border-blue-500 p-6 rounded">
            <p class="text-blue-900">
              <strong>Note:</strong> This resource is available upon request. Contact us to receive the full document or for more information.
            </p>
          </div>
        </div>

        <!-- Sidebar -->
        <div>
          <div class="bg-gray-50 rounded-lg p-6 sticky top-4">
            <h3 class="font-bold text-gray-900 mb-4">Resource Details</h3>
            
            <div class="mb-4 pb-4 border-b border-gray-200">
              <p class="text-sm text-gray-600 mb-1">Type</p>
              <p class="font-semibold text-gray-900 capitalize">{resource.type.replace("-", " ")}</p>
            </div>

            <div class="mb-4 pb-4 border-b border-gray-200">
              <p class="text-sm text-gray-600 mb-1">Category</p>
              <p class="font-semibold text-gray-900">{resource.category}</p>
            </div>

            {resource.relatedSystem && (
              <div class="mb-4 pb-4 border-b border-gray-200">
                <p class="text-sm text-gray-600 mb-1">Related System</p>
                <p class="font-semibold text-gray-900">{resource.relatedSystem}</p>
              </div>
            )}

            <div class="mb-4">
              <p class="text-sm text-gray-600 mb-1">Access</p>
              <p class="font-semibold text-gray-900">{resource.gated ? "Gated" : "Public"}</p>
            </div>

            {resource.downloadUrl ? (
              <a href={resource.downloadUrl} class="w-full block text-center bg-green-700 hover:bg-green-800 text-white font-semibold py-3 rounded-lg transition mt-6">
                Download Document →
              </a>
            ) : (
              <a href="/contact/" class="w-full block text-center bg-green-700 hover:bg-green-800 text-white font-semibold py-3 rounded-lg transition mt-6">
                Request Document →
              </a>
            )}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Related Resources -->
  {relatedResources.length > 0 && (
    <section class="py-16 md:py-24 bg-gray-50">
      <div class="container mx-auto px-4">
        <h2 class="text-3xl font-bold text-gray-900 mb-12 text-center">Related Resources</h2>
        <div class="grid md:grid-cols-3 gap-6">
          {relatedResources.map((relatedResource) => (
            <a href={`/resources/${relatedResource.slug}/`} class="bg-white border border-gray-200 rounded-lg overflow-hidden hover:shadow-lg transition p-6">
              <div class="text-3xl mb-3">📄</div>
              <h3 class="font-bold text-gray-900 mb-2 line-clamp-2 hover:text-green-700">{relatedResource.title}</h3>
              <p class="text-sm text-gray-600 mb-4">{relatedResource.summary}</p>
              <div class="flex gap-2 flex-wrap">
                <span class="inline-block bg-blue-100 text-blue-700 text-xs font-semibold px-3 py-1 rounded-full capitalize">
                  {relatedResource.type.replace("-", " ")}
                </span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- CTA -->
  <section class="py-16 md:py-20 bg-green-700 text-white">
    <div class="container mx-auto px-4 text-center">
      <h2 class="text-3xl md:text-4xl font-bold mb-4">Need More Information?</h2>
      <p class="text-lg mb-8 text-green-100 max-w-2xl mx-auto">
        Contact us for additional resources, technical support, or project-specific documentation.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/contact/" class="px-8 py-3 bg-white text-green-700 font-semibold rounded-lg hover:bg-gray-100 transition">
          Contact Us →
        </a>
        <a href="/resources/" class="px-8 py-3 border-2 border-white text-white font-semibold rounded-lg hover:bg-white/10 transition">
          View All Resources
        </a>
      </div>
    </div>
  </section>
</Layout>
