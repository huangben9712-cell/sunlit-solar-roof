---
import Layout from '../../layouts/Layout.astro';
import { blogPosts } from '../../data/blog.ts';

export function getStaticPaths() {
  return blogPosts.map((post) => ({ params: { slug: post.slug }, props: { post } }));
}

const { post } = Astro.props;

const rawContent = post.content || '';

// Extract H2 headings for TOC
const tocItems: { id: string; text: string }[] = [];
const h2Regex = /^## (.+)$/gm;
let tocMatch;
while ((tocMatch = h2Regex.exec(rawContent)) !== null) {
  const rawText = tocMatch[1].trim();
  // Strip markdown bold/italic markers from TOC display text
  const text = rawText.replace(/\*\*(.+?)\*\*/g, '$1').replace(/\*(.+?)\*/g, '$1').replace(/`(.+?)`/g, '$1');
  const id = text.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '');
  tocItems.push({ id, text });
}

// Parse inline markdown
function parseInline(text: string): string {
  return text
    .replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')
    .replace(/\*(.+?)\*/g, '<em>$1</em>')
    .replace(/`(.+?)`/g, '<code class="bg-soft-green text-deep-green px-1.5 py-0.5 rounded text-sm font-mono">$1</code>')
    .replace(/\[(.+?)\]\((.+?)\)/g, '<a href="$2" class="text-deep-green font-semibold underline decoration-deep-green/40 hover:decoration-deep-green transition-all" target="_blank" rel="noopener">$1</a>');
}

interface ContentBlock {
  type: 'lead' | 'h2' | 'h3' | 'h4' | 'paragraph' | 'list_ul' | 'list_ol' | 'blockquote' | 'divider';
  html?: string;
  id?: string;
  items?: string[];
}

const blocks: ContentBlock[] = [];
const lines = rawContent.split('\n');
let i = 0;
let isFirstParagraph = true;

while (i < lines.length) {
  const line = lines[i];
  if (line.trim() === '') { i++; continue; }

  if (line.startsWith('## ')) {
    const text = line.slice(3).trim();
    const id = text.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '');
    blocks.push({ type: 'h2', html: parseInline(text), id });
    i++; continue;
  }
  if (line.startsWith('### ')) {
    blocks.push({ type: 'h3', html: parseInline(line.slice(4).trim()) });
    i++; continue;
  }
  if (line.startsWith('#### ')) {
    blocks.push({ type: 'h4', html: parseInline(line.slice(5).trim()) });
    i++; continue;
  }
  if (line.startsWith('> ')) {
    blocks.push({ type: 'blockquote', html: parseInline(line.slice(2).trim()) });
    i++; continue;
  }
  if (line.trim() === '---') {
    blocks.push({ type: 'divider' });
    i++; continue;
  }
  if (line.startsWith('- ') || line.startsWith('* ')) {
    const items: string[] = [];
    while (i < lines.length && (lines[i].startsWith('- ') || lines[i].startsWith('* '))) {
      items.push(parseInline(lines[i].slice(2).trim()));
      i++;
    }
    blocks.push({ type: 'list_ul', items });
    continue;
  }
  if (/^\d+\.\s/.test(line)) {
    const items: string[] = [];
    while (i < lines.length && /^\d+\.\s/.test(lines[i])) {
      items.push(parseInline(lines[i].replace(/^\d+\.\s/, '').trim()));
      i++;
    }
    blocks.push({ type: 'list_ol', items });
    continue;
  }
  // Paragraph
  const paraLines: string[] = [];
  while (
    i < lines.length &&
    lines[i].trim() !== '' &&
    !lines[i].startsWith('#') &&
    !lines[i].startsWith('> ') &&
    !lines[i].startsWith('- ') &&
    !lines[i].startsWith('* ') &&
    !/^\d+\.\s/.test(lines[i]) &&
    lines[i].trim() !== '---'
  ) {
    paraLines.push(lines[i].trim());
    i++;
  }
  if (paraLines.length > 0) {
    const html = parseInline(paraLines.join(' '));
    if (isFirstParagraph) {
      blocks.push({ type: 'lead', html });
      isFirstParagraph = false;
    } else {
      blocks.push({ type: 'paragraph', html });
    }
  }
}

const relatedPosts = blogPosts.filter((p) => p.category === post.category && p.id !== post.id).slice(0, 3);
const dateObj = new Date(post.date);
const formattedDate = dateObj.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
const wordCount = rawContent.split(/\s+/).length;
const readingTime = Math.max(1, Math.ceil(wordCount / 200));
---

<Layout title={`${post.title} — Sunlit Solar Roof`} description={post.summary}>

  <!-- Reading progress bar -->
  <div id="reading-progress" class="fixed top-0 left-0 h-[3px] bg-deep-green w-0 z-50 transition-none"></div>

  <!-- Breadcrumb -->
  <div class="border-b border-gray-100 bg-white">
    <div class="max-w-[860px] mx-auto px-6 py-3 text-sm text-slate flex items-center gap-2 flex-wrap">
      <a href="/" class="hover:text-deep-green transition-colors">Home</a>
      <span class="text-gray-300">/</span>
      <a href="/articles/" class="hover:text-deep-green transition-colors">Articles</a>
      <span class="text-gray-300">/</span>
      <span class="text-charcoal">{post.title}</span>
    </div>
  </div>

  <!-- Article Header -->
  <header class="bg-white pt-12 pb-0">
    <div class="max-w-[860px] mx-auto px-6">
      <!-- Category + date -->
      <div class="flex items-center gap-3 mb-5 text-sm text-slate">
        <span class="text-deep-green font-semibold">{post.category}</span>
        <span class="text-gray-300">·</span>
        <span>{formattedDate}</span>
        <span class="text-gray-300">·</span>
        <span>{readingTime} min read</span>
      </div>

      <!-- Title -->
      <h1 class="font-heading font-bold text-[2.6rem] md:text-[3.2rem] text-charcoal leading-[1.1] mb-6 tracking-tight">
        {post.title}
      </h1>

      <!-- Cover image -->
      <div class="w-full aspect-[16/7] overflow-hidden bg-gradient-to-br from-deep-green to-[#1a3a2a] flex items-center justify-center mt-8">
        {post.coverImage ? (
          <img src={post.coverImage} alt={post.title} class="w-full h-full object-cover" />
        ) : (
          <div class="text-center text-white/20">
            <svg class="w-16 h-16 mx-auto mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
            <p class="text-xs font-heading font-bold uppercase tracking-widest">Cover Image</p>
          </div>
        )}
      </div>
    </div>
  </header>

  <!-- Article Body -->
  <main class="bg-white py-14">
    <div class="max-w-[860px] mx-auto px-6">

      <!-- TOC: arrow list like roofit -->
      {tocItems.length >= 3 && (
        <nav class="mb-12 pb-10 border-b border-gray-100">
          <p class="text-sm text-slate mb-5">By the end of this article, you will have learned about:</p>
          <ol class="space-y-3">
            {tocItems.map((item) => (
              <li>
                <a href={`#${item.id}`} class="flex items-center gap-3 text-[16px] text-charcoal hover:text-deep-green transition-colors group">
                  <svg class="w-4 h-4 text-deep-green shrink-0 group-hover:translate-x-0.5 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                  </svg>
                  <span>{item.text}</span>
                </a>
              </li>
            ))}
          </ol>
        </nav>
      )}

      <!-- Content blocks -->
      <div class="article-content">
        {blocks.map((block) => (
          <>
            {block.type === 'lead' && (
              <p class="text-[1.25rem] md:text-[1.35rem] font-bold text-charcoal leading-[1.65] mb-10" set:html={block.html} />
            )}

            {block.type === 'h2' && (
              <div class="mt-16 mb-0 scroll-mt-24" id={block.id}>
                <h2 class="font-heading font-bold text-[2rem] md:text-[2.5rem] text-charcoal leading-tight tracking-tight" set:html={block.html} />
              </div>
            )}

            {block.type === 'h3' && (
              <h3 class="font-heading font-bold text-[1.25rem] text-charcoal mt-8 mb-3 leading-snug" set:html={block.html} />
            )}

            {block.type === 'h4' && (
              <h4 class="font-heading font-bold text-[1rem] text-charcoal mt-6 mb-2 uppercase tracking-wide" set:html={block.html} />
            )}

            {block.type === 'paragraph' && (
              <p class="text-[17px] text-[#333] leading-[1.85] mb-6 mt-5" set:html={block.html} />
            )}

            {block.type === 'list_ul' && (
              <ul class="mb-6 mt-4 space-y-3 pl-0">
                {block.items?.map((item) => (
                  <li class="flex items-start gap-3 text-[17px] text-[#333] leading-relaxed">
                    <svg class="w-4 h-4 text-deep-green shrink-0 mt-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                    </svg>
                    <span set:html={item} />
                  </li>
                ))}
              </ul>
            )}

            {block.type === 'list_ol' && (
              <ol class="mb-6 mt-4 space-y-4 pl-0">
                {block.items?.map((item, idx) => (
                  <li class="flex items-start gap-4 text-[17px] text-[#333] leading-relaxed">
                    <span class="shrink-0 font-heading font-bold text-[15px] text-deep-green w-8 pt-0.5">
                      {String(idx + 1).padStart(2, '0')}.
                    </span>
                    <span set:html={item} />
                  </li>
                ))}
              </ol>
            )}

            {block.type === 'blockquote' && (
              <blockquote class="my-10 pl-6 border-l-[3px] border-deep-green">
                <p class="text-[1.1rem] text-charcoal italic leading-relaxed font-medium" set:html={block.html} />
              </blockquote>
            )}

            {block.type === 'divider' && (
              <hr class="my-12 border-gray-100" />
            )}
          </>
        ))}
      </div>

      <!-- Article footer -->
      <div class="mt-16 pt-8 border-t border-gray-100 flex flex-wrap items-center justify-between gap-4">
        <div>
          <p class="text-xs text-slate/50 mb-1">Original source</p>
          <a href={post.sourceUrl} target="_blank" rel="noopener" class="text-sm text-deep-green hover:underline break-all">{post.sourceUrl}</a>
        </div>
        <a href="/articles/" class="sunlit-btn-secondary text-sm">← Back to Articles</a>
      </div>
    </div>
  </main>

  <!-- Related articles -->
  {relatedPosts.length > 0 && (
    <section class="py-16 bg-soft-green">
      <div class="max-w-[860px] mx-auto px-6">
        <div class="flex items-center justify-between mb-8">
          <h2 class="font-heading font-bold text-2xl md:text-3xl text-charcoal">More in {post.category}</h2>
          <a href="/articles/" class="text-sm text-deep-green font-heading font-bold hover:underline">View all →</a>
        </div>
        <div class="grid md:grid-cols-3 gap-5">
          {relatedPosts.map((rp) => (
            <a href={`/articles/${rp.slug}/`} class="sunlit-card p-6 block group hover:shadow-md transition-shadow bg-white">
              <div class="w-full h-28 bg-gradient-to-br from-deep-green/10 to-deep-green/5 rounded-xl mb-4 flex items-center justify-center">
                <svg class="w-7 h-7 text-deep-green/30" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                </svg>
              </div>
              <p class="text-xs font-heading font-bold text-deep-green uppercase tracking-wide mb-2">{rp.category}</p>
              <h3 class="font-heading font-bold text-charcoal group-hover:text-deep-green transition-colors leading-snug mb-2">{rp.title}</h3>
              <p class="text-sm text-slate leading-relaxed line-clamp-2">{rp.summary}</p>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- CTA Banner -->
  <section class="py-16 dark-green-gradient text-white">
    <div class="max-w-[860px] mx-auto px-6 text-center">
      <p class="text-xs font-heading font-bold uppercase tracking-widest text-white/40 mb-4">Sunlit Solar Roof</p>
      <h2 class="font-heading font-bold text-3xl md:text-4xl mb-4 leading-tight">Ready to Move from Reading to a Real Project?</h2>
      <p class="text-white/70 text-lg mb-8 max-w-xl mx-auto">Share your roof area and location. We'll tell you which system fits and what to expect.</p>
      <div class="flex flex-wrap gap-4 justify-center">
        <a href="/contact/" class="sunlit-btn-amber">Get a Free Consultation →</a>
        <a href="/system-overview/" class="sunlit-btn-outline-white">Explore Supply Scope</a>
      </div>
    </div>
  </section>

  <script is:inline>
    // Reading progress bar
    const bar = document.getElementById('reading-progress');
    if (bar) {
      window.addEventListener('scroll', () => {
        const doc = document.documentElement;
        const scrolled = doc.scrollTop;
        const total = doc.scrollHeight - doc.clientHeight;
        bar.style.width = total > 0 ? (scrolled / total * 100) + '%' : '0%';
      }, { passive: true });
    }
  </script>

</Layout>
