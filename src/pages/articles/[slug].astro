---
import Layout from '../../layouts/Layout.astro';
import { blogPosts } from '../../data/blog.ts';

export function getStaticPaths() {
  return blogPosts.map((post) => ({ params: { slug: post.slug }, props: { post } }));
}

const { post } = Astro.props;
---

<Layout title={post.title}>
  <section class="py-16 bg-white">
    <div class="container mx-auto px-4 max-w-4xl">
      <p class="sunlit-overline mb-4">{post.category}</p>
      <h1 class="sunlit-section-title text-4xl md:text-6xl mb-6">{post.title}</h1>
      <p class="text-lg text-[var(--slate)] mb-8">{post.summary}</p>
      <div class="sunlit-card p-8">
        <p class="text-[var(--slate)] leading-relaxed whitespace-pre-line">{post.content}</p>
      </div>
    </div>
  </section>
</Layout>
