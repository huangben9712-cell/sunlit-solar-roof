---
import Layout from '../../layouts/Layout.astro';
import { blogPosts } from '../../data/blog.ts';

export function getStaticPaths() {
  return blogPosts.map((post) => ({ params: { slug: post.slug }, props: { post } }));
}

const { post } = Astro.props;
const paragraphs = post.content.split('\n\n');
const relatedPosts = blogPosts.filter((p) => p.category === post.category && p.id !== post.id).slice(0, 3);
---

<Layout title={post.title}>
  <section class="border-b border-[var(--border)] bg-white">
    <div class="container mx-auto px-4 py-4 text-sm text-[var(--slate)]">
      <a href="/" class="hover:text-[var(--deep-green)]">Home</a>
      <span class="mx-2">/</span>
      <a href="/articles/" class="hover:text-[var(--deep-green)]">Articles</a>
      <span class="mx-2">/</span>
      <span class="font-bold text-[var(--charcoal)]">{post.title}</span>
    </div>
  </section>

  <section class="bg-[#f8faf8] py-14 md:py-20">
    <div class="container mx-auto px-4 max-w-4xl">
      <p class="sunlit-overline mb-4">{post.category}</p>
      <h1 class="sunlit-section-title text-4xl md:text-6xl mb-6">{post.title}</h1>
      <p class="text-lg md:text-xl text-[var(--slate)] leading-relaxed mb-6">{post.summary}</p>
      <div class="flex gap-3 flex-wrap">
        <span class="inline-block bg-white text-[var(--deep-green)] text-sm font-extrabold px-4 py-2 rounded-full border border-[var(--border)]">{post.priority}</span>
        <span class="inline-block bg-white text-[var(--slate)] text-sm font-extrabold px-4 py-2 rounded-full border border-[var(--border)]">{post.date}</span>
      </div>
    </div>
  </section>

  <section class="py-16 md:py-24 bg-white">
    <div class="container mx-auto px-4">
      <div class="grid lg:grid-cols-3 gap-10 items-start">
        <article class="lg:col-span-2 sunlit-card p-8 md:p-10">
          <div class="space-y-5">
            {paragraphs.map((paragraph) => (
              paragraph.startsWith('## ') ? (
                <h2 class="text-2xl font-extrabold text-[var(--charcoal)] pt-4">{paragraph.replace('## ', '')}</h2>
              ) : paragraph.startsWith('### ') ? (
                <h3 class="text-xl font-extrabold text-[var(--charcoal)] pt-3">{paragraph.replace('### ', '')}</h3>
              ) : (
                <p class="text-[var(--slate)] leading-relaxed text-lg whitespace-pre-line">{paragraph}</p>
              )
            ))}
          </div>
          <div class="mt-10 pt-8 border-t border-[var(--border)]">
            <p class="text-sm text-[var(--slate)] mb-3">Legacy source:</p>
            <a href={post.sourceUrl} class="text-[var(--deep-green)] font-extrabold break-all">{post.sourceUrl}</a>
          </div>
        </article>

        <aside>
          <div class="sunlit-card p-6 sticky top-24">
            <h3 class="font-extrabold text-[var(--charcoal)] mb-5">Article Details</h3>
            <div class="space-y-4">
              <div class="pb-4 border-b border-[var(--border)]"><p class="text-sm text-[var(--slate)] mb-1">Category</p><p class="font-extrabold text-[var(--charcoal)]">{post.category}</p></div>
              <div class="pb-4 border-b border-[var(--border)]"><p class="text-sm text-[var(--slate)] mb-1">Migration Priority</p><p class="font-extrabold text-[var(--charcoal)]">{post.priority}</p></div>
              <div><p class="text-sm text-[var(--slate)] mb-1">Date</p><p class="font-extrabold text-[var(--charcoal)]">{post.date}</p></div>
            </div>
            <a href="/contact/" class="sunlit-btn-primary w-full mt-6">Discuss a Project</a>
          </div>
        </aside>
      </div>
    </div>
  </section>

  {relatedPosts.length > 0 && (
    <section class="py-16 md:py-24 bg-[#f8faf8]">
      <div class="container mx-auto px-4">
        <h2 class="sunlit-section-title text-3xl md:text-5xl mb-10 text-center">Related Articles</h2>
        <div class="grid md:grid-cols-3 gap-6">
          {relatedPosts.map((relatedPost) => (
            <a href={`/articles/${relatedPost.slug}/`} class="sunlit-card p-6 block">
              <p class="text-sm font-extrabold text-[var(--deep-green)] mb-3">{relatedPost.category}</p>
              <h3 class="font-extrabold text-[var(--charcoal)] mb-2">{relatedPost.title}</h3>
              <p class="text-sm text-[var(--slate)] leading-relaxed">{relatedPost.summary}</p>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}
</Layout>
