---
import Layout from '../layouts/Layout.astro';

const productLines = [
  {
    name: 'Lumina Slate Glass Solar Roof Tiles',
    badge: 'Premium Glass Tile Line',
    href: '/lumina-slate/',
    summary: 'A slate-look glass solar roof tile line for villas, premium residential projects and architecture-driven roofs where appearance is part of the value.',
    points: ['AG-etched glass PV roof tiles', 'Matching inactive glass roof tiles', 'Premium architectural appearance', 'Best for villas and high-end residential projects'],
  },
  {
    name: 'Storm Guard Metal Solar Roof Sheets',
    badge: 'Modern Metal Sheet Line',
    href: '/storm-guard/',
    summary: 'A metal solar roof sheet line for modern residential, commercial, public and large-area roofs where practical cost position and clean roof integration matter.',
    points: ['Metal solar roof sheets', 'Matching inactive metal roof elements', 'Modern standing-seam appearance', 'Best for larger and cost-sensitive projects'],
  },
];

const comparison = [
  ['Product Type', 'Glass solar roof tiles', 'Metal solar roof sheets'],
  ['Appearance', 'Premium slate-look glass roof', 'Modern metal roof profile'],
  ['Inactive Match', 'Matching glass inactive tiles', 'Matching inactive metal sheets'],
  ['Best Fit', 'Villas, premium residential, architectural roofs', 'Residential, commercial, public, large-area roofs'],
  ['Cost Position', 'Higher-end', 'More practical'],
  ['Buyer Value', 'Aesthetics + solar integration', 'Project efficiency + broader application'],
];

const sharedScope = ['Active PV elements', 'Matching inactive roof elements', 'Flashing and waterproofing details', 'Ridge, hip and edge pieces', 'Fixings and accessories', 'Project documents and packing information'];
---

<Layout title="Solar Roof Product Lines - Sunlit Solar Roof" description="Compare Lumina Slate glass solar roof tiles and Storm Guard metal solar roof sheets from Sunlit Solar Roof.">
  <section class="bg-soft-green py-16 md:py-24">
    <div class="container mx-auto px-4 max-w-4xl text-center">
      <p class="sunlit-overline mb-4">Solar Roof Product Lines</p>
      <h1 class="sunlit-section-title text-4xl md:text-6xl mb-6">Two Solar Roof Product Lines from One China Manufacturer</h1>
      <p class="text-lg text-slate leading-relaxed mb-8">Sunlit supplies both premium glass solar roof tiles and modern metal solar roof sheets for overseas B2B projects. Choose the product line based on roof appearance, project type, budget position and local installation conditions.</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="#compare" class="sunlit-btn-primary">Compare Product Lines</a>
        <a href="/system-overview/" class="sunlit-btn-secondary">View Supply Scope</a>
        <a href="/contact/" class="sunlit-btn-secondary">Get Factory Pricing</a>
      </div>
    </div>
  </section>

  <section class="py-16 md:py-24 bg-white">
    <div class="container mx-auto px-4">
      <div class="grid lg:grid-cols-2 gap-8">
        {productLines.map((line) => (
          <article class="sunlit-card p-8">
            <p class="sunlit-overline mb-3">{line.badge}</p>
            <h2 class="font-heading font-bold text-3xl text-charcoal mb-4">{line.name}</h2>
            <p class="text-slate leading-relaxed mb-6">{line.summary}</p>
            <ul class="space-y-3 mb-8 text-slate">
              {line.points.map((point) => <li>✓ {point}</li>)}
            </ul>
            <a href={line.href} class="sunlit-btn-secondary">Explore {line.name.split(' ')[0]} {line.name.split(' ')[1]}</a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section id="compare" class="py-16 md:py-24 bg-light-gray border-y border-border">
    <div class="container mx-auto px-4">
      <div class="max-w-3xl mb-10">
        <p class="sunlit-overline mb-3">Product Line Comparison</p>
        <h2 class="sunlit-section-title text-3xl md:text-5xl mb-4">Which Product Line Should You Review First?</h2>
        <p class="text-slate">This is a decision-level comparison, not a full technical specification table. Detailed specs should be reviewed on each product page.</p>
      </div>
      <div class="sunlit-card overflow-hidden">
        <div class="grid grid-cols-3 bg-deep-green text-white font-heading font-bold">
          <div class="p-4">Decision Point</div>
          <div class="p-4">Lumina Slate</div>
          <div class="p-4">Storm Guard</div>
        </div>
        {comparison.map((row) => (
          <div class="grid grid-cols-3 border-b border-border last:border-b-0">
            <div class="p-4 font-heading font-bold text-charcoal">{row[0]}</div>
            <div class="p-4 text-slate">{row[1]}</div>
            <div class="p-4 text-slate">{row[2]}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16 md:py-24 bg-white">
    <div class="container mx-auto px-4">
      <div class="grid lg:grid-cols-2 gap-8">
        <div class="sunlit-card p-8">
          <h2 class="font-heading font-bold text-3xl mb-5">Choose Lumina Slate if...</h2>
          <ul class="space-y-3 text-slate leading-relaxed">
            <li>✓ The client cares strongly about premium roof appearance.</li>
            <li>✓ The project is a villa, estate, resort or architectural residence.</li>
            <li>✓ The roof should look closer to slate than standard PV panels.</li>
            <li>✓ The budget can support a higher-end glass roof product.</li>
          </ul>
        </div>
        <div class="sunlit-card p-8">
          <h2 class="font-heading font-bold text-3xl mb-5">Choose Storm Guard if...</h2>
          <ul class="space-y-3 text-slate leading-relaxed">
            <li>✓ The project needs modern metal roof aesthetics.</li>
            <li>✓ The roof area is larger or more cost-sensitive.</li>
            <li>✓ The buyer wants a practical solar roof sheet system.</li>
            <li>✓ The project is residential, commercial, public or utility-related.</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 md:py-20 dark-green-gradient text-white">
    <div class="container mx-auto px-4 text-center max-w-4xl">
      <p class="uppercase tracking-[0.16em] text-white/70 font-bold text-xs mb-4">Both Product Lines Can Include</p>
      <h2 class="font-heading text-3xl md:text-5xl font-bold mb-6">Active + Inactive + Accessories</h2>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4 mb-8">
        {sharedScope.map((item) => <div class="bg-white/10 border border-white/20 rounded-2xl p-4">{item}</div>)}
      </div>
      <a href="/system-overview/" class="sunlit-btn-primary">View Factory Supply Scope</a>
    </div>
  </section>
</Layout>
