---
import Layout from '../layouts/Layout.astro';
import { getPublicGuides, getRequestDocuments } from '../data/resources';

const publicGuides = getPublicGuides();
const requestDocs = getRequestDocuments();
---

<Layout title="Resources & Documentation">
  <!-- Breadcrumb -->
  <section class="border-b border-gray-200">
    <div class="container mx-auto px-4 py-4">
      <div class="flex items-center gap-2 text-sm text-gray-600">
        <a href="/" class="hover:text-gray-900">Home</a>
        <span>/</span>
        <span class="text-gray-900 font-medium">Resources</span>
      </div>
    </div>
  </section>

  <!-- Hero -->
  <section class="py-12 md:py-16 bg-gradient-to-br from-green-50 to-transparent">
    <div class="container mx-auto px-4 text-center">
      <h1 class="text-4xl md:text-5xl font-bold mb-6 text-gray-900 leading-tight">
        Resources & Documentation
      </h1>
      <p class="text-lg text-gray-600 mb-8 leading-relaxed max-w-2xl mx-auto">
        Technical documentation, buyer guides, and resources for evaluating and implementing solar roof systems.
      </p>
    </div>
  </section>

  <!-- Public Buyer Guides -->
  <section class="py-16 md:py-24 bg-white">
    <div class="container mx-auto px-4">
      <h2 class="text-3xl font-bold mb-12 text-gray-900">Buyer Guides</h2>
      <p class="text-gray-600 mb-12 max-w-3xl">
        Free guides to help you understand solar roof systems, compare options, and prepare for implementation.
      </p>
      <div class="grid md:grid-cols-2 gap-8 max-w-4xl">
        {publicGuides.map((guide) => (
          <a href={`/resources/${guide.slug}/`} class="bg-white border-2 border-gray-200 rounded-lg p-8 hover:border-green-700 hover:shadow-lg transition">
            <div class="text-4xl mb-4">📚</div>
            <h3 class="text-xl font-bold text-gray-900 mb-3 hover:text-green-700">{guide.title}</h3>
            <p class="text-gray-600 leading-relaxed">{guide.summary}</p>
            <div class="mt-6 text-green-700 font-semibold">
              Read Guide →
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Request-Based Documents -->
  <section class="py-16 md:py-24 bg-gray-50">
    <div class="container mx-auto px-4">
      <h2 class="text-3xl font-bold mb-12 text-gray-900">Technical Documents</h2>
      <p class="text-gray-600 mb-12 max-w-3xl">
        Detailed technical specifications, datasheets, and documentation available upon request.
      </p>
      <div class="grid md:grid-cols-2 gap-6 max-w-4xl">
        {requestDocs.map((doc) => (
          <div class="bg-white rounded-lg p-6 border border-gray-200">
            <div class="text-3xl mb-3">📄</div>
            <h3 class="font-bold text-gray-900 mb-2">{doc.title}</h3>
            <p class="text-sm text-gray-600 mb-4">{doc.summary}</p>
            <a href="/contact/" class="text-green-700 hover:text-green-800 font-semibold text-sm">
              Request Document →
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 md:py-20 bg-green-700 text-white">
    <div class="container mx-auto px-4 text-center">
      <h2 class="text-3xl md:text-4xl font-bold mb-4">Need Additional Information?</h2>
      <p class="text-lg mb-8 text-green-100 max-w-2xl mx-auto">
        Contact us to request technical documents, discuss your project, or get personalized support.
      </p>
      <a href="/contact/" class="inline-block px-8 py-3 bg-white text-green-700 font-semibold rounded-lg hover:bg-gray-100 transition">
        Contact Us →
      </a>
    </div>
  </section>
</Layout>
