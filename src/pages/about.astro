---
import Layout from '../layouts/Layout.astro';
---

<Layout title="About Sunlit Solar Roof">
  <!-- Breadcrumb -->
  <section class="border-b border-gray-200">
    <div class="container mx-auto px-4 py-4">
      <div class="flex items-center gap-2 text-sm text-gray-600">
        <a href="/" class="hover:text-gray-900">Home</a>
        <span>/</span>
        <span class="text-gray-900 font-medium">About Us</span>
      </div>
    </div>
  </section>

  <!-- Hero -->
  <section class="py-12 md:py-16 bg-gradient-to-br from-green-50 to-transparent">
    <div class="container mx-auto px-4 text-center">
      <h1 class="text-4xl md:text-5xl font-bold mb-6 text-gray-900 leading-tight">
        About Sunlit Solar Roof
      </h1>
      <p class="text-lg text-gray-600 mb-8 leading-relaxed max-w-2xl mx-auto">
        We design and manufacture complete Building Integrated Photovoltaic (BIPV) systems for buyers worldwide.
      </p>
    </div>
  </section>

  <!-- Who We Are -->
  <section class="py-16 md:py-24 bg-white">
    <div class="container mx-auto px-4 max-w-3xl">
      <h2 class="text-3xl font-bold mb-6 text-gray-900">Who We Are</h2>
      <p class="text-gray-600 leading-relaxed mb-6">
        Sunlit Solar Roof is a manufacturer of complete Building Integrated Photovoltaic (BIPV) systems. We design and produce two complete solar roof systems: Lumina Slate (premium glass system) and Storm Guard (cost-effective metal system).
      </p>
      <p class="text-gray-600 leading-relaxed">
        Our systems integrate photovoltaic technology directly into roof materials, combining structural function with power generation. We serve residential, commercial, industrial, and infrastructure projects worldwide.
      </p>
    </div>
  </section>

  <!-- What We Provide -->
  <section class="py-16 md:py-24 bg-gray-50">
    <div class="container mx-auto px-4 max-w-3xl">
      <h2 class="text-3xl font-bold mb-12 text-gray-900">What We Provide</h2>
      <div class="space-y-8">
        <div>
          <h3 class="text-xl font-bold text-gray-900 mb-3">Complete System Solutions</h3>
          <p class="text-gray-600 leading-relaxed">
            We provide complete BIPV systems, not individual components. Each system includes roof base layer, active PV elements, matching inactive elements, ridge and edge components, and electrical generation system.
          </p>
        </div>
        <div>
          <h3 class="text-xl font-bold text-gray-900 mb-3">Two System Options</h3>
          <p class="text-gray-600 leading-relaxed mb-3">
            <strong>Lumina Slate:</strong> Premium glass solar roof system designed for high-end residential, commercial, and architectural projects where aesthetics are paramount.
          </p>
          <p class="text-gray-600 leading-relaxed">
            <strong>Storm Guard:</strong> Metal solar roof system designed for commercial, industrial, hospitality, and infrastructure projects with emphasis on durability and cost-effectiveness.
          </p>
        </div>
        <div>
          <h3 class="text-xl font-bold text-gray-900 mb-3">Technical Documentation</h3>
          <p class="text-gray-600 leading-relaxed">
            Comprehensive technical specifications, installation guidelines, warranty documents, and certifications for each system.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- How We Support Overseas Buyers -->
  <section class="py-16 md:py-24 bg-white">
    <div class="container mx-auto px-4 max-w-3xl">
      <h2 class="text-3xl font-bold mb-12 text-gray-900">How We Support Overseas Buyers</h2>
      <div class="space-y-8">
        <div class="bg-blue-50 border-l-4 border-blue-700 p-6 rounded">
          <h3 class="font-bold text-gray-900 mb-2">Project Evaluation</h3>
          <p class="text-gray-600 leading-relaxed">
            We evaluate your roof drawing and project requirements to recommend the right system and provide accurate quotations.
          </p>
        </div>
        <div class="bg-blue-50 border-l-4 border-blue-700 p-6 rounded">
          <h3 class="font-bold text-gray-900 mb-2">Technical Support</h3>
          <p class="text-gray-600 leading-relaxed">
            Our team provides technical guidance throughout the project lifecycle, from initial design to installation support.
          </p>
        </div>
        <div class="bg-blue-50 border-l-4 border-blue-700 p-6 rounded">
          <h3 class="font-bold text-gray-900 mb-2">Documentation & Resources</h3>
          <p class="text-gray-600 leading-relaxed">
            We provide detailed technical documentation, installation notes, warranty information, and buyer guides to support your decision-making.
          </p>
        </div>
        <div class="bg-blue-50 border-l-4 border-blue-700 p-6 rounded">
          <h3 class="font-bold text-gray-900 mb-2">Clear Communication</h3>
          <p class="text-gray-600 leading-relaxed">
            We communicate clearly about system capabilities, specifications, and requirements. We avoid unverified claims and provide information you can rely on.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- How We Work -->
  <section class="py-16 md:py-24 bg-gray-50">
    <div class="container mx-auto px-4 max-w-3xl">
      <h2 class="text-3xl font-bold mb-12 text-gray-900">How We Work</h2>
      <div class="space-y-6">
        <div class="flex gap-6">
          <div class="flex-shrink-0">
            <div class="flex items-center justify-center h-12 w-12 rounded-md bg-green-700 text-white font-bold">1</div>
          </div>
          <div>
            <h3 class="font-bold text-gray-900 mb-2">Project Inquiry</h3>
            <p class="text-gray-600">You submit your roof drawing and project information through our contact form.</p>
          </div>
        </div>
        <div class="flex gap-6">
          <div class="flex-shrink-0">
            <div class="flex items-center justify-center h-12 w-12 rounded-md bg-green-700 text-white font-bold">2</div>
          </div>
          <div>
            <h3 class="font-bold text-gray-900 mb-2">System Evaluation</h3>
            <p class="text-gray-600">Our team evaluates your project and recommends the appropriate system (Lumina Slate or Storm Guard).</p>
          </div>
        </div>
        <div class="flex gap-6">
          <div class="flex-shrink-0">
            <div class="flex items-center justify-center h-12 w-12 rounded-md bg-green-700 text-white font-bold">3</div>
          </div>
          <div>
            <h3 class="font-bold text-gray-900 mb-2">Quotation & Documentation</h3>
            <p class="text-gray-600">We provide a detailed quotation and technical documentation for your review.</p>
          </div>
        </div>
        <div class="flex gap-6">
          <div class="flex-shrink-0">
            <div class="flex items-center justify-center h-12 w-12 rounded-md bg-green-700 text-white font-bold">4</div>
          </div>
          <div>
            <h3 class="font-bold text-gray-900 mb-2">Technical Support</h3>
            <p class="text-gray-600">Throughout the project, we provide installation guidance and technical support.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Why Buyers Work With Sunlit -->
  <section class="py-16 md:py-24 bg-green-50">
    <div class="container mx-auto px-4 max-w-3xl">
      <h2 class="text-3xl font-bold mb-12 text-gray-900">Why Buyers Work With Sunlit</h2>
      <div class="space-y-4">
        <div class="flex gap-4">
          <span class="text-green-700 font-bold text-xl">✓</span>
          <p class="text-gray-600"><strong>Complete Systems:</strong> We provide complete BIPV systems, not components. Everything you need is integrated.</p>
        </div>
        <div class="flex gap-4">
          <span class="text-green-700 font-bold text-xl">✓</span>
          <p class="text-gray-600"><strong>Two Options:</strong> Choose between Lumina Slate (premium glass) or Storm Guard (cost-effective metal) based on your project needs.</p>
        </div>
        <div class="flex gap-4">
          <span class="text-green-700 font-bold text-xl">✓</span>
          <p class="text-gray-600"><strong>Transparent Communication:</strong> We provide clear information about capabilities and requirements without unverified claims.</p>
        </div>
        <div class="flex gap-4">
          <span class="text-green-700 font-bold text-xl">✓</span>
          <p class="text-gray-600"><strong>Technical Support:</strong> Our team supports you from project evaluation through installation.</p>
        </div>
        <div class="flex gap-4">
          <span class="text-green-700 font-bold text-xl">✓</span>
          <p class="text-gray-600"><strong>Comprehensive Documentation:</strong> Technical specifications, installation notes, and buyer guides to support your decisions.</p>
        </div>
        <div class="flex gap-4">
          <span class="text-green-700 font-bold text-xl">✓</span>
          <p class="text-gray-600"><strong>Global Experience:</strong> We serve projects worldwide and understand international buyer requirements.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 md:py-20 bg-green-700 text-white">
    <div class="container mx-auto px-4 text-center">
      <h2 class="text-3xl md:text-4xl font-bold mb-4">Ready to Partner with Sunlit?</h2>
      <p class="text-lg mb-8 text-green-100 max-w-2xl mx-auto">
        Let's discuss how we can support your solar roof projects.
      </p>
      <a href="/contact/" class="inline-block px-8 py-3 bg-white text-green-700 font-semibold rounded-lg hover:bg-gray-100 transition">
        Get in Touch →
      </a>
    </div>
  </section>
</Layout>
