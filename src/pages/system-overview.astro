---
import Layout from '../layouts/Layout.astro';

const trustItems = [
  { title: 'China Manufacturer', desc: 'Factory-side supply for overseas B2B projects.' },
  { title: 'Active + Inactive Scope', desc: 'Solar elements and matching non-PV roof coverage.' },
  { title: 'Project-Based Quote', desc: 'Quotation based on roof layout and product scope.' },
  { title: 'Samples Available', desc: 'Product samples and documents before commitment.' },
  { title: 'Export Support', desc: 'Packaging, shipping documents and communication.' },
];

const comparison = [
  ['Product Type', 'Glass solar roof tiles', 'Metal solar roof sheets'],
  ['Appearance', 'Premium slate-look glass roof', 'Modern metal roof profile'],
  ['Inactive Match', 'Matching glass inactive tiles', 'Matching inactive metal sheets'],
  ['Best Fit', 'Villas, premium residential, architectural roofs', 'Residential, commercial, public, large-area roofs'],
  ['Cost Position', 'Higher-end', 'More practical'],
  ['Buyer Value', 'Aesthetics + solar integration', 'Project efficiency + broader application'],
];

const included = [
  { title: 'Active PV Tiles / Sheets', desc: 'Solar-generating glass tiles or metal roof sheets supplied according to the selected product line.' },
  { title: 'Matching Inactive Roof Elements', desc: 'Non-PV roof elements for edges, shaded areas, non-generating zones and visual consistency.' },
  { title: 'Flashing', desc: 'Roof transition and waterproofing accessories for valleys, edges, walls and junctions.' },
  { title: 'Ridge and Edge Pieces', desc: 'Ridge, hip, eave and edge components used to complete the roof package.' },
  { title: 'Fixings', desc: 'Fasteners and supporting components for roof-side installation planning.' },
  { title: 'Project Documents', desc: 'Datasheets, installation notes, BOM, packing list and quotation documents.' },
];

const luminaComponents = [
  { title: 'Active Glass PV Tile', desc: 'The solar-generating glass roof tile used on suitable roof areas.', details: ['Used for active power generation', 'Slate-look glass appearance', 'Selected by roof layout and system design'] },
  { title: 'Matching Inactive Glass Tile', desc: 'A non-generating glass roof tile used where PV is not required or not suitable.', details: ['Used for edges, shaded areas and visual continuity', 'Matches the appearance of active tiles', 'Helps avoid a patchwork roof surface'] },
  { title: 'Ridge / Hip / Edge Pieces', desc: 'Roof finishing components used to close and detail the roof package.', details: ['Used at ridges, hips, eaves and edges', 'Supports a cleaner complete roof appearance', 'Defined according to roof shape'] },
  { title: 'Flashing and Waterproofing Details', desc: 'Project-specific roof transition components for junctions and water management.', details: ['Used around walls, valleys, skylights and penetrations', 'Needs local roof detailing review', 'Quoted according to roof layout'] },
  { title: 'Fixings and Accessories', desc: 'Supporting components used for roof-side installation planning.', details: ['Selected according to roof build-up', 'Reviewed with project drawings', 'Local installation remains the local team responsibility'] },
  { title: 'Project Documents', desc: 'Documents that support product evaluation, quotation and installation communication.', details: ['Datasheet', 'Installation notes', 'BOM / packing list', 'Warranty document'] },
];

const stormComponents = [
  { title: 'Active Metal Solar Roof Sheet', desc: 'The solar-generating metal roof sheet used on suitable roof areas.', details: ['Combines metal roof appearance and PV generation', 'Suitable for modern and larger roof surfaces', 'Selected by layout and project conditions'] },
  { title: 'Matching Inactive Metal Roof Sheet', desc: 'A non-generating metal roof sheet used to complete the non-PV roof areas.', details: ['Used where PV is not needed or not suitable', 'Maintains a consistent metal roof appearance', 'Useful for large-area roof coverage'] },
  { title: 'Metal Ridge / Edge / Trim Accessories', desc: 'Metal roof finishing components used for roof edges and transitions.', details: ['Used at ridge, hip, edge and eave areas', 'Helps complete the roof-side supply package', 'Defined by roof shape and local detailing needs'] },
  { title: 'Flashing and Drainage Details', desc: 'Metal roof transition details for waterproofing and roof junctions.', details: ['Used around wall junctions and penetrations', 'Requires project-specific review', 'Coordinated with local roof installation practice'] },
  { title: 'Clips / Fixings / Mounting-Related Parts', desc: 'Supporting parts used for metal roof installation planning.', details: ['Selected based on roof build-up and local method', 'Supports roof-side assembly', 'Reviewed by project scope'] },
  { title: 'Project Documents', desc: 'Documents that support product review, quotation and local installation communication.', details: ['Datasheet', 'Installation notes', 'BOM / packing list', 'Warranty document'] },
];

const process = [
  { step: '1', title: 'Share Project Basics', desc: 'Send country, project type, estimated roof area, product interest or basic questions. A roof drawing helps but is not required for the first conversation.' },
  { step: '2', title: 'Choose Product Direction', desc: 'Compare Lumina Slate and Storm Guard based on appearance, budget position and project use.' },
  { step: '3', title: 'Define Active + Inactive Coverage', desc: 'The roof is reviewed as active PV coverage, matching inactive roof elements and accessory areas.' },
  { step: '4', title: 'Receive Project-Based Quotation', desc: 'You receive quotation direction with product scope, estimated quantities, documents, packing and export terms.' },
];

const factorySupply = ['Active PV tiles or metal solar roof sheets', 'Matching inactive roof elements', 'Flashing, ridge pieces and edge trims', 'Fixings and accessory components', 'Project documents and packing information', 'Export packaging and shipping document support'];
const localScope = ['Roof structure and installation labor', 'Electrical connection and wiring', 'Local permits and code compliance', 'Grid connection and utility approval', 'Scaffolding, safety and site protection', 'Import taxes, local fees and final installation responsibility'];

const faqs = ['Can I ask for pricing without a roof drawing?', 'Do you supply inactive roof elements and accessories together?', 'Can you provide samples and documents first?', 'Who handles local installation?', 'Can you support OEM or distributor cooperation?', 'What information helps you quote faster?'];
---

<Layout title="Factory Supply Scope - Sunlit Solar Roof" description="Understand what Sunlit supplies from the factory for solar roof projects, including active PV tiles or sheets, inactive roof elements, accessories, documents and export support.">
  <section class="bg-soft-green py-16 md:py-24">
    <div class="container mx-auto px-4 grid lg:grid-cols-2 gap-10 items-center">
      <div>
        <p class="sunlit-overline mb-4">Factory Supply Scope</p>
        <h1 class="sunlit-section-title text-4xl md:text-6xl mb-6">What We Supply for a Solar Roof Project</h1>
        <p class="text-lg text-slate leading-relaxed mb-5">Sunlit supplies the factory-side roof product package: active solar roof tiles or sheets, matching inactive roof elements, flashing, fixings, roof accessories and project documents.</p>
        <p class="text-slate leading-relaxed mb-8">This page also helps you compare Lumina Slate and Storm Guard before entering each product page. Local roofing installation, electrical connection, permits and grid approval are usually handled by qualified local teams.</p>
        <div class="flex flex-col sm:flex-row gap-4">
          <a href="/contact/" class="sunlit-btn-primary">Get Factory Pricing</a>
          <a href="#compare" class="sunlit-btn-secondary">Compare Product Lines</a>
          <a href="#components" class="sunlit-btn-secondary">View Components</a>
        </div>
      </div>
      <div class="sunlit-card p-8">
        <p class="sunlit-overline mb-4">Scope Boundary</p>
        <div class="grid sm:grid-cols-2 gap-4">
          {trustItems.map((item) => (
            <div class="rounded-2xl bg-light-gray border border-border p-4">
              <h3 class="font-heading font-bold text-charcoal mb-2">{item.title}</h3>
              <p class="text-sm text-slate leading-relaxed">{item.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section id="compare" class="py-16 md:py-24 bg-white">
    <div class="container mx-auto px-4">
      <div class="max-w-3xl mb-10">
        <p class="sunlit-overline mb-3">Product Line Comparison</p>
        <h2 class="sunlit-section-title text-3xl md:text-5xl mb-4">Lumina Slate or Storm Guard?</h2>
        <p class="text-slate leading-relaxed">This is a decision-level comparison inside the supply scope page. Detailed specifications, images and project examples should be reviewed on each product line page.</p>
      </div>
      <div class="sunlit-card overflow-hidden mb-8">
        <div class="grid grid-cols-3 bg-deep-green text-white font-heading font-bold">
          <div class="p-4">Decision Point</div>
          <div class="p-4">Lumina Slate</div>
          <div class="p-4">Storm Guard</div>
        </div>
        {comparison.map((row) => (
          <div class="grid grid-cols-3 border-b border-border last:border-b-0">
            <div class="p-4 font-heading font-bold text-charcoal">{row[0]}</div>
            <div class="p-4 text-slate">{row[1]}</div>
            <div class="p-4 text-slate">{row[2]}</div>
          </div>
        ))}
      </div>
      <div class="grid lg:grid-cols-2 gap-6">
        <div class="sunlit-card p-6">
          <p class="sunlit-overline mb-3">Choose Lumina Slate if...</p>
          <ul class="space-y-3 text-slate leading-relaxed">
            <li>✓ The client cares strongly about premium roof appearance.</li>
            <li>✓ The project is a villa, estate, resort or architectural residence.</li>
            <li>✓ The roof should look closer to slate than standard PV panels.</li>
            <li>✓ The budget can support a higher-end glass roof product.</li>
          </ul>
          <a href="/lumina-slate/" class="sunlit-btn-secondary mt-6">Explore Lumina Slate</a>
        </div>
        <div class="sunlit-card p-6">
          <p class="sunlit-overline mb-3">Choose Storm Guard if...</p>
          <ul class="space-y-3 text-slate leading-relaxed">
            <li>✓ The project needs modern metal roof aesthetics.</li>
            <li>✓ The roof area is larger or more cost-sensitive.</li>
            <li>✓ The buyer wants a practical solar roof sheet system.</li>
            <li>✓ The project is residential, commercial, public or utility-related.</li>
          </ul>
          <a href="/storm-guard/" class="sunlit-btn-secondary mt-6">Explore Storm Guard</a>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 md:py-24 bg-light-gray border-y border-border">
    <div class="container mx-auto px-4">
      <div class="text-center max-w-3xl mx-auto mb-12">
        <p class="sunlit-overline mb-4">Factory Supply Package</p>
        <h2 class="sunlit-section-title text-3xl md:text-5xl mb-5">What Is Included in Factory Supply</h2>
        <p class="text-slate leading-relaxed">This is the common supply framework. The actual components differ between Lumina Slate and Storm Guard, but the quotation logic is similar.</p>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {included.map((item) => (
          <div class="sunlit-card p-6">
            <h3 class="font-heading font-bold text-xl text-charcoal mb-3">{item.title}</h3>
            <p class="text-slate leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section id="components" class="py-16 md:py-24 bg-white">
    <div class="container mx-auto px-4">
      <div class="max-w-3xl mb-10">
        <p class="sunlit-overline mb-4">Component Library by Product Line</p>
        <h2 class="sunlit-section-title text-3xl md:text-5xl mb-5">Review the Roof Package Structure by System</h2>
        <p class="text-slate leading-relaxed">A solar roof project is not only active PV tiles or sheets. Choose a product line to review the active elements, matching inactive elements and roof accessories that should be reviewed together.</p>
      </div>

      <div class="grid lg:grid-cols-2 gap-8">
        <section class="sunlit-card p-6">
          <div class="mb-6">
            <p class="sunlit-overline mb-2">Lumina Slate Components</p>
            <h3 class="font-heading font-bold text-3xl text-charcoal mb-3">Glass Solar Roof Tile Package</h3>
            <p class="text-slate leading-relaxed">Lumina Slate is built around active glass PV tiles, matching inactive glass tiles and roof detailing accessories.</p>
          </div>
          <div class="space-y-4">
            {luminaComponents.map((component) => (
              <details class="rounded-2xl border border-border bg-light-gray p-5">
                <summary class="font-heading font-bold text-charcoal cursor-pointer">{component.title}</summary>
                <p class="text-slate mt-3 mb-3 leading-relaxed">{component.desc}</p>
                <ul class="space-y-2 text-sm text-slate">
                  {component.details.map((detail) => <li>• {detail}</li>)}
                </ul>
              </details>
            ))}
          </div>
        </section>

        <section class="sunlit-card p-6">
          <div class="mb-6">
            <p class="sunlit-overline mb-2">Storm Guard Components</p>
            <h3 class="font-heading font-bold text-3xl text-charcoal mb-3">Metal Solar Roof Sheet Package</h3>
            <p class="text-slate leading-relaxed">Storm Guard is built around active metal solar sheets, matching inactive metal roof sheets and metal roof accessories.</p>
          </div>
          <div class="space-y-4">
            {stormComponents.map((component) => (
              <details class="rounded-2xl border border-border bg-light-gray p-5">
                <summary class="font-heading font-bold text-charcoal cursor-pointer">{component.title}</summary>
                <p class="text-slate mt-3 mb-3 leading-relaxed">{component.desc}</p>
                <ul class="space-y-2 text-sm text-slate">
                  {component.details.map((detail) => <li>• {detail}</li>)}
                </ul>
              </details>
            ))}
          </div>
        </section>
      </div>
    </div>
  </section>

  <section class="py-16 md:py-24 bg-light-gray border-y border-border">
    <div class="container mx-auto px-4">
      <div class="text-center max-w-3xl mx-auto mb-12">
        <p class="sunlit-overline mb-4">Quotation Workflow</p>
        <h2 class="sunlit-section-title text-3xl md:text-5xl">How the Supply Scope Is Defined</h2>
      </div>
      <div class="grid md:grid-cols-4 gap-5">
        {process.map((item) => (
          <div class="sunlit-card p-6">
            <div class="w-10 h-10 rounded-full bg-deep-green text-white flex items-center justify-center font-heading font-bold mb-5">{item.step}</div>
            <h3 class="font-heading font-bold text-charcoal mb-3">{item.title}</h3>
            <p class="text-sm text-slate leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16 md:py-24 bg-white">
    <div class="container mx-auto px-4 grid lg:grid-cols-2 gap-8">
      <div class="sunlit-card p-8">
        <h2 class="font-heading font-bold text-3xl mb-6">What We Usually Supply</h2>
        <ul class="space-y-3 text-slate">
          {factorySupply.map((item) => <li>✓ {item}</li>)}
        </ul>
      </div>
      <div class="sunlit-card p-8">
        <h2 class="font-heading font-bold text-3xl mb-6">What Is Usually Handled Locally</h2>
        <ul class="space-y-3 text-slate">
          {localScope.map((item) => <li>• {item}</li>)}
        </ul>
      </div>
    </div>
  </section>

  <section class="py-16 md:py-24 bg-soft-green">
    <div class="container mx-auto px-4">
      <div class="text-center max-w-3xl mx-auto mb-12">
        <p class="sunlit-overline mb-4">Next Step</p>
        <h2 class="sunlit-section-title text-3xl md:text-5xl">Enter the Product Line Page That Fits Your Project</h2>
      </div>
      <div class="grid lg:grid-cols-2 gap-8">
        <a href="/lumina-slate/" class="sunlit-card p-8 block">
          <p class="sunlit-overline mb-3">Premium Glass Tile Line</p>
          <h3 class="font-heading font-bold text-3xl text-charcoal mb-3">Lumina Slate Glass Solar Roof Tiles</h3>
          <p class="text-slate mb-6">Premium glass tile line for villas and architectural projects.</p>
          <span class="font-heading font-bold text-deep-green">Explore Lumina Slate →</span>
        </a>
        <a href="/storm-guard/" class="sunlit-card p-8 block">
          <p class="sunlit-overline mb-3">Modern Metal Sheet Line</p>
          <h3 class="font-heading font-bold text-3xl text-charcoal mb-3">Storm Guard Metal Solar Roof Sheets</h3>
          <p class="text-slate mb-6">Modern metal sheet line for residential, commercial and large-area roofs.</p>
          <span class="font-heading font-bold text-deep-green">Explore Storm Guard →</span>
        </a>
      </div>
    </div>
  </section>

  <section class="py-16 md:py-24 bg-white">
    <div class="container mx-auto px-4 max-w-5xl">
      <div class="text-center mb-10">
        <p class="sunlit-overline mb-4">FAQ</p>
        <h2 class="sunlit-section-title text-3xl md:text-5xl">Questions Buyers Usually Ask</h2>
      </div>
      <div class="grid md:grid-cols-2 gap-4">
        {faqs.map((question) => (
          <details class="sunlit-card p-5">
            <summary class="font-heading font-bold cursor-pointer">{question}</summary>
            <p class="text-slate mt-3 leading-relaxed">Send us what you have today. We can start with rough information and clarify the next step before a detailed quotation.</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16 md:py-20 dark-green-gradient text-white">
    <div class="container mx-auto px-4 max-w-4xl text-center">
      <p class="uppercase tracking-[0.16em] text-white/70 font-bold text-xs mb-4">Start with a conversation</p>
      <h2 class="font-heading text-3xl md:text-5xl font-bold mb-5">Tell Us What You’re Planning — We’ll Help Define the Right Supply Scope</h2>
      <p class="text-white/75 leading-relaxed mb-8">Share your country, roof type, estimated roof area, photos, drawings or product interest. We will help you understand which product line and factory supply scope fits the project.</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/contact/" class="sunlit-btn-primary">Get Factory Pricing</a>
        <a href="/contact/" class="border border-white/50 text-white rounded-full px-6 py-3 font-bold hover:bg-white/10 transition-colors">Ask a Product Question</a>
      </div>
    </div>
  </section>
</Layout>
