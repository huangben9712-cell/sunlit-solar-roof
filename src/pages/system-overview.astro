---

<Layout title="Factory Supply Scope — Sunlit Solar Roof" description="Understand what Sunlit supplies from the factory for solar roof projects: active PV tiles or sheets, inactive roof elements, accessories, documents and export support.">

  <!-- ===== HERO ===== -->
  <section class="bg-soft-green pt-16 pb-0 overflow-hidden">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-[1fr_380px] gap-10 items-start pb-16">
        <!-- Left: headline + CTAs -->
        <div>
          <p class="sunlit-overline mb-4">Factory Supply Scope</p>
          <h1 class="sunlit-section-title text-4xl md:text-5xl lg:text-[3.25rem] text-charcoal mb-5 leading-[1.08]">
            Understand the<br>Roof Package Before<br>Asking for a Tile Price
          </h1>
          <p class="text-slate leading-relaxed mb-3 max-w-xl">
            A solar roof project is more than active solar tiles or sheets. Sunlit supplies a complete roof package from the factory — including active PV elements, matching inactive roof elements, flashing, fixings, accessories, documents, and export support — so your roof performs, installs cleanly, and passes local requirements.
          </p>
          <div class="flex flex-wrap gap-3 mt-7">
            <a href="/contact/" class="sunlit-btn-primary">Ask What Fits My Project →</a>
            <a href="#scope-model" class="sunlit-btn-secondary">See the Supply Model →</a>
            <a href="#compare" class="sunlit-btn-secondary">Compare Product Lines →</a>
          </div>
        </div>

        <!-- Right: Quick Trust Check card -->
        <div class="sunlit-card p-6 self-start">
          <p class="sunlit-overline mb-5">Quick Trust Check</p>
          <div class="space-y-4">
            {trustItems.map((item) => (
              <div class="flex gap-3 items-start">
                <div class="flex-shrink-0 w-9 h-9 rounded-xl bg-soft-green text-deep-green flex items-center justify-center border border-border">
                  <Fragment set:html={item.icon} />
                </div>
                <div>
                  <p class="font-heading font-bold text-charcoal text-sm">{item.title}</p>
                  <p class="text-xs text-slate leading-relaxed mt-0.5">{item.desc}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== A ROOF PACKAGE IN 4 PARTS ===== -->
  <section id="scope-model" class="py-16 md:py-20 bg-white">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <p class="sunlit-overline mb-3">Simple Mental Model</p>
        <h2 class="sunlit-section-title text-3xl md:text-4xl text-charcoal">A Roof Package in 4 Parts</h2>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5">
        {mentalModel.map((item) => (
          <div class="sunlit-card overflow-hidden flex flex-col">
            <div class="p-6 flex-1">
              <div class="w-9 h-9 rounded-full bg-deep-green text-white flex items-center justify-center font-heading font-bold text-sm mb-4">
                {item.num}
              </div>
              <div class="w-px h-5 bg-border mx-0 mb-4"></div>
              <h3 class="font-heading font-bold text-charcoal text-lg mb-1">{item.title}</h3>
              <p class="text-xs font-heading font-semibold text-deep-green mb-3">{item.label}</p>
              <p class="text-sm text-slate leading-relaxed">{item.desc}</p>
            </div>
            <div class="h-36 overflow-hidden">
              <img
                src={item.img}
                alt={item.title}
                class="w-full h-full object-cover"
                loading="lazy"
              />
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== COMPARE TWO PRODUCT FAMILIES ===== -->
  <section id="compare" class="py-16 md:py-20 bg-light-gray border-y border-border">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="mb-10">
        <p class="sunlit-overline mb-3">Factory Supply Scope</p>
        <h2 class="sunlit-section-title text-3xl md:text-4xl text-charcoal mb-3">Compare the Two Product Families</h2>
        <p class="text-slate max-w-2xl leading-relaxed">
          Sunlit Solar Roof offers two distinct product families. <strong class="text-charcoal">Lumina Slate</strong> features premium glass tiles with slate-like aesthetics for high-end architecture. <strong class="text-charcoal">Storm Guard</strong> uses durable metal sheets with matched inactive elements for efficient, large-area installations.
        </p>
      </div>
      <div class="grid lg:grid-cols-2 gap-6">
        <!-- Lumina Slate -->
        <div class="sunlit-card overflow-hidden">
          <div class="h-52 overflow-hidden relative">
            <img
              src="/images/projects/beijing-new-world-lizun/sunlit-solar-slate-installed-texture-close-up.webp"
              alt="Lumina Slate"
              class="w-full h-full object-cover"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-black/40 to-transparent"></div>
          </div>
          <div class="p-7">
            <h3 class="font-heading font-bold text-2xl text-charcoal mb-1">Lumina Slate</h3>
            <p class="text-sm text-slate mb-5">Premium glass solar roof tiles</p>
            <p class="text-slate text-sm leading-relaxed mb-6">
              Slate-like appearance with matching inactive glass elements. Designed for villas and high-end architecture that value timeless elegance.
            </p>
            <div class="space-y-2.5 mb-6">
              {luminaFeatures.map((f) => (
                <div class="flex items-center gap-2.5 text-sm">
                  <span class="text-deep-green flex-shrink-0"><Fragment set:html={f.icon} /></span>
                  <span class="text-charcoal font-heading font-semibold">{f.label}:</span>
