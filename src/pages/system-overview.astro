---
import Layout from '../layouts/Layout.astro';

const trustItems = [
  { title: 'China Manufacturer', desc: 'Factory-side supply for overseas B2B buyers.' },
  { title: 'Complete Roof Package', desc: 'Active, inactive and accessory scope reviewed together.' },
  { title: 'Project-Based Quote', desc: 'Quantities and scope are discussed by roof conditions.' },
  { title: 'No Drawing Required First', desc: 'Start with country, roof area, photos or questions.' },
];

const mentalModel = [
  { title: '1. Generate Power', label: 'Active PV Tiles / Sheets', desc: 'The solar-generating roof areas are selected by product line and project layout.' },
  { title: '2. Complete the Roof', label: 'Matching Inactive Elements', desc: 'Non-generating areas still need matching roof elements for a clean finished surface.' },
  { title: '3. Close the Details', label: 'Flashing, Ridge, Edge, Fixings', desc: 'Roof junctions, edges and finishing parts are reviewed as part of the supply package.' },
  { title: '4. Support the Project', label: 'Documents + Export Support', desc: 'Datasheets, notes, packing information and export communication support the buying process.' },
];

const comparison = [
  ['Main Product', 'Glass solar roof tiles', 'Metal solar roof sheets'],
  ['Visual Direction', 'Premium slate-look glass roof', 'Modern metal roof profile'],
  ['Inactive Match', 'Matching inactive glass tiles', 'Matching inactive metal sheets'],
  ['Best Fit', 'Villas, premium residential, architectural roofs', 'Residential, commercial, public, larger roofs'],
  ['Cost Position', 'Higher-end', 'More practical'],
  ['Buyer Value', 'Architectural appearance + solar integration', 'Project efficiency + broader application'],
];

const included = [
  { title: 'Active PV Tiles / Sheets', desc: 'Solar-generating glass tiles or metal roof sheets supplied according to the selected product line.' },
  { title: 'Matching Inactive Roof Elements', desc: 'Non-PV roof elements for edges, shaded areas, non-generating zones and visual consistency.' },
  { title: 'Flashing', desc: 'Roof transition and waterproofing accessories for valleys, edges, walls and junctions.' },
  { title: 'Ridge and Edge Pieces', desc: 'Ridge, hip, eave and edge components used to complete the roof package.' },
  { title: 'Fixings', desc: 'Fasteners and supporting components for roof-side installation planning.' },
  { title: 'Project Documents', desc: 'Datasheets, installation notes, BOM, packing list and quotation documents.' },
];

const luminaComponents = [
  { title: 'Active Glass PV Tile', desc: 'The solar-generating glass roof tile used on suitable roof areas.', details: ['Used for active power generation', 'Slate-look glass appearance', 'Selected by roof layout and system design'] },
  { title: 'Matching Inactive Glass Tile', desc: 'A non-generating glass roof tile used where PV is not required or not suitable.', details: ['Used for edges, shaded areas and visual continuity', 'Matches the appearance of active tiles', 'Helps avoid a patchwork roof surface'] },
  { title: 'Ridge / Hip / Edge Pieces', desc: 'Roof finishing components used to close and detail the roof package.', details: ['Used at ridges, hips, eaves and edges', 'Supports a cleaner complete roof appearance', 'Defined according to roof shape'] },
  { title: 'Flashing and Waterproofing Details', desc: 'Project-specific roof transition components for junctions and water management.', details: ['Used around walls, valleys, skylights and penetrations', 'Needs local roof detailing review', 'Quoted according to roof layout'] },
  { title: 'Fixings and Accessories', desc: 'Supporting components used for roof-side installation planning.', details: ['Selected according to roof build-up', 'Reviewed with project drawings', 'Local installation remains the local team responsibility'] },
  { title: 'Project Documents', desc: 'Documents that support product evaluation, quotation and installation communication.', details: ['Datasheet', 'Installation notes', 'BOM / packing list', 'Warranty document'] },
];

const stormComponents = [
  { title: 'Active Metal Solar Roof Sheet', desc: 'The solar-generating metal roof sheet used on suitable roof areas.', details: ['Combines metal roof appearance and PV generation', 'Suitable for modern and larger roof surfaces', 'Selected by layout and project conditions'] },
  { title: 'Matching Inactive Metal Roof Sheet', desc: 'A non-generating metal roof sheet used to complete the non-PV roof areas.', details: ['Used where PV is not needed or not suitable', 'Maintains a consistent metal roof appearance', 'Useful for large-area roof coverage'] },
  { title: 'Metal Ridge / Edge / Trim Accessories', desc: 'Metal roof finishing components used for roof edges and transitions.', details: ['Used at ridge, hip, edge and eave areas', 'Helps complete the roof-side supply package', 'Defined by roof shape and local detailing needs'] },
  { title: 'Flashing and Drainage Details', desc: 'Metal roof transition details for waterproofing and roof junctions.', details: ['Used around wall junctions and penetrations', 'Requires project-specific review', 'Coordinated with local roof installation practice'] },
  { title: 'Clips / Fixings / Mounting-Related Parts', desc: 'Supporting parts used for metal roof installation planning.', details: ['Selected based on roof build-up and local method', 'Supports roof-side assembly', 'Reviewed by project scope'] },
  { title: 'Project Documents', desc: 'Documents that support product review, quotation and local installation communication.', details: ['Datasheet', 'Installation notes', 'BOM / packing list', 'Warranty document'] },
];

const factorySupply = [
  'Active PV tiles or metal solar roof sheets',
  'Matching inactive roof elements',
  'Flashing, ridge pieces and edge trims',
  'Fixings and accessory components',
  'Project documents and packing information',
  'Export packaging and shipping document support',
];

const localScope = [
  'Roof structure and installation labor',
  'Electrical connection and wiring',
  'Local permits and code compliance',
  'Grid connection and utility approval',
  'Scaffolding, safety and site protection',
  'Import taxes, local fees and final installation responsibility',
];

const process = [
  { step: '01', title: 'Send What You Have', desc: 'Country, estimated roof area, project type, photos, product interest or a simple question is enough for the first conversation.' },
  { step: '02', title: 'Choose a Product Direction', desc: 'We help you compare Lumina Slate and Storm Guard based on appearance, budget position and project use.' },
  { step: '03', title: 'Define the Roof Package', desc: 'Active areas, inactive areas and accessories are reviewed together so the quotation scope is easier to understand.' },
  { step: '04', title: 'Move Toward Quotation', desc: 'When the project is clearer, we can discuss quantities, documents, packing, samples and export terms.' },
];

const faqs = [
  'Can I ask for pricing without a roof drawing?',
  'Do you supply inactive roof elements and accessories together?',
  'Can you provide samples and documents first?',
  'Who handles local installation?',
  'Can you support OEM or distributor cooperation?',
  'What information helps you quote faster?',
];
---

<Layout title="Factory Supply Scope - Sunlit Solar Roof" description="Understand what Sunlit supplies from the factory for solar roof projects, including active PV tiles or sheets, inactive roof elements, accessories, documents and export support.">
  <section class="bg-soft-green py-16 md:py-24">
    <div class="container mx-auto px-4 grid lg:grid-cols-[1.1fr_0.9fr] gap-10 items-center">
      <div>
        <p class="sunlit-overline mb-4">Factory Supply Scope</p>
        <h1 class="sunlit-section-title text-4xl md:text-6xl mb-6">Understand the Roof Package Before Asking for a Tile Price</h1>
        <p class="text-lg text-slate leading-relaxed mb-5">A solar roof project is not only active solar tiles or sheets. Sunlit supplies the factory-side product package: active PV elements, matching inactive roof elements, flashing, fixings, roof accessories, documents and export support.</p>
        <p class="text-slate leading-relaxed mb-8">This page is built to help you make one clear decision first: what should be included in the factory quotation, and whether Lumina Slate or Storm Guard is the better product direction.</p>
        <div class="flex flex-col sm:flex-row gap-4">
          <a href="/contact/" class="sunlit-btn-primary">Ask What Fits My Project</a>
          <a href="#model" class="sunlit-btn-secondary">See the Supply Model</a>
          <a href="#compare" class="sunlit-btn-secondary">Compare Product Lines</a>
        </div>
      </div>
      <div class="sunlit-card p-6 md:p-8">
        <p class="sunlit-overline mb-5">Quick Trust Check</p>
        <div class="space-y-4">
          {trustItems.map((item) => (
            <div class="border-b border-border last:border-b-0 pb-4 last:pb-0">
              <h3 class="font-heading font-bold text-charcoal mb-1">{item.title}</h3>
              <p class="text-sm text-slate leading-relaxed">{item.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section id="model" class="py-16 md:py-24 bg-white">
    <div class="container mx-auto px-4">
      <div class="max-w-3xl mb-10">
        <p class="sunlit-overline mb-4">Simple Mental Model</p>
        <h2 class="sunlit-section-title text-3xl md:text-5xl mb-5">Think in Four Parts, Not One Product</h2>
        <p class="text-slate leading-relaxed">Most buyers first ask for active tiles. The real project question is broader: which areas generate power, which areas need matching roof coverage, which accessories close the roof, and which documents support local work.</p>
      </div>
      <div class="grid md:grid-cols-4 gap-5">
        {mentalModel.map((item) => (
          <div class="sunlit-card p-6">
            <p class="text-xs font-heading font-bold text-deep-green mb-3">{item.title}</p>
            <h3 class="font-heading font-bold text-xl text-charcoal mb-3">{item.label}</h3>
            <p class="text-sm text-slate leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>
      <div class="mt-8 rounded-3xl bg-light-gray border border-border p-6 md:p-8">
        <p class="text-slate leading-relaxed"><strong class="text-charcoal">Human-friendly rule:</strong> start with the roof result you want, not a single part number. We can then help you define the right product line, active/inactive coverage and accessory scope.</p>
      </div>
    </div>
  </section>

  <section id="compare" class="py-16 md:py-24 bg-light-gray border-y border-border">
    <div class="container mx-auto px-4">
      <div class="max-w-3xl mb-10">
        <p class="sunlit-overline mb-3">Product Direction</p>
        <h2 class="sunlit-section-title text-3xl md:text-5xl mb-4">Choose the Product Family Before Reviewing Every Component</h2>
        <p class="text-slate leading-relaxed">This is a decision-level comparison. It helps buyers avoid getting buried in parts too early. Once the product direction is clear, the component library becomes easier to understand.</p>
      </div>
      <div class="grid lg:grid-cols-2 gap-6 mb-8">
        <div class="sunlit-card p-7">
          <p class="sunlit-overline mb-3">Lumina Slate</p>
          <h3 class="font-heading font-bold text-3xl text-charcoal mb-4">Premium Glass Solar Roof Tiles</h3>
          <p class="text-slate leading-relaxed mb-5">Best when appearance is a major part of the project value: villas, premium residential, resorts and architectural roofs.</p>
          <a href="/lumina-slate/" class="sunlit-btn-secondary">Explore Lumina Slate</a>
        </div>
        <div class="sunlit-card p-7">
          <p class="sunlit-overline mb-3">Storm Guard</p>
          <h3 class="font-heading font-bold text-3xl text-charcoal mb-4">Modern Metal Solar Roof Sheets</h3>
          <p class="text-slate leading-relaxed mb-5">Best when the project needs a practical metal roof profile, broader application and better cost position.</p>
          <a href="/storm-guard/" class="sunlit-btn-secondary">Explore Storm Guard</a>
        </div>
      </div>
      <div class="sunlit-card overflow-hidden">
        <div class="grid grid-cols-3 bg-deep-green text-white font-heading font-bold">
          <div class="p-4">Decision Point</div>
          <div class="p-4">Lumina Slate</div>
          <div class="p-4">Storm Guard</div>
        </div>
        {comparison.map((row) => (
          <div class="grid grid-cols-3 border-b border-border last:border-b-0">
            <div class="p-4 font-heading font-bold text-charcoal">{row[0]}</div>
            <div class="p-4 text-slate">{row[1]}</div>
            <div class="p-4 text-slate">{row[2]}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16 md:py-24 bg-white">
    <div class="container mx-auto px-4">
      <div class="text-center max-w-3xl mx-auto mb-12">
        <p class="sunlit-overline mb-4">Factory Supply Package</p>
        <h2 class="sunlit-section-title text-3xl md:text-5xl mb-5">The Six Common Categories We Review</h2>
        <p class="text-slate leading-relaxed">The specific parts differ by product line. The buying logic is the same: active elements, inactive coverage, roof details, fixings, documents and export preparation should be reviewed as one package.</p>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {included.map((item) => (
          <div class="sunlit-card p-6">
            <h3 class="font-heading font-bold text-xl text-charcoal mb-3">{item.title}</h3>
            <p class="text-slate leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section id="components" class="py-16 md:py-24 bg-light-gray border-y border-border">
    <div class="container mx-auto px-4">
      <div class="max-w-3xl mb-10">
        <p class="sunlit-overline mb-4">For Detail-Minded Buyers</p>
        <h2 class="sunlit-section-title text-3xl md:text-5xl mb-5">Component Library by Product Line</h2>
        <p class="text-slate leading-relaxed">This section is intentionally deeper. It is for buyers who want to click into active elements, inactive elements and roof accessories before asking questions.</p>
      </div>

      <div class="grid lg:grid-cols-2 gap-8">
        <section class="sunlit-card p-6">
          <div class="mb-6">
            <p class="sunlit-overline mb-2">Lumina Slate Components</p>
            <h3 class="font-heading font-bold text-3xl text-charcoal mb-3">Glass Solar Roof Tile Package</h3>
            <p class="text-slate leading-relaxed">Active glass PV tiles, matching inactive glass tiles and roof detailing accessories.</p>
          </div>
          <div class="space-y-4">
            {luminaComponents.map((component) => (
              <details class="rounded-2xl border border-border bg-white p-5">
                <summary class="font-heading font-bold text-charcoal cursor-pointer">{component.title}</summary>
                <p class="text-slate mt-3 mb-3 leading-relaxed">{component.desc}</p>
                <ul class="space-y-2 text-sm text-slate mb-4">
                  {component.details.map((detail) => <li>• {detail}</li>)}
                </ul>
                <a href="/contact/" class="font-heading font-bold text-deep-green">Ask about this component →</a>
              </details>
            ))}
          </div>
        </section>

        <section class="sunlit-card p-6">
          <div class="mb-6">
            <p class="sunlit-overline mb-2">Storm Guard Components</p>
            <h3 class="font-heading font-bold text-3xl text-charcoal mb-3">Metal Solar Roof Sheet Package</h3>
            <p class="text-slate leading-relaxed">Active metal solar sheets, matching inactive metal roof sheets and metal roof accessories.</p>
          </div>
          <div class="space-y-4">
            {stormComponents.map((component) => (
              <details class="rounded-2xl border border-border bg-white p-5">
                <summary class="font-heading font-bold text-charcoal cursor-pointer">{component.title}</summary>
                <p class="text-slate mt-3 mb-3 leading-relaxed">{component.desc}</p>
                <ul class="space-y-2 text-sm text-slate mb-4">
                  {component.details.map((detail) => <li>• {detail}</li>)}
                </ul>
                <a href="/contact/" class="font-heading font-bold text-deep-green">Ask about this component →</a>
              </details>
            ))}
          </div>
        </section>
      </div>
    </div>
  </section>

  <section class="py-16 md:py-24 bg-white">
    <div class="container mx-auto px-4 grid lg:grid-cols-[0.8fr_1.2fr] gap-10 items-start">
      <div>
        <p class="sunlit-overline mb-4">Risk Reduction</p>
        <h2 class="sunlit-section-title text-3xl md:text-5xl mb-5">Clear Boundary Means Fewer Misunderstandings</h2>
        <p class="text-slate leading-relaxed">We should not pretend to be the local roofer, electrician or permitting consultant. A good B2B page should say clearly what the factory supplies and what local teams usually handle.</p>
      </div>
      <div class="grid md:grid-cols-2 gap-6">
        <div class="sunlit-card p-7">
          <h3 class="font-heading font-bold text-2xl mb-5">What We Usually Supply</h3>
          <ul class="space-y-3 text-slate">
            {factorySupply.map((item) => <li>✓ {item}</li>)}
          </ul>
        </div>
        <div class="sunlit-card p-7">
          <h3 class="font-heading font-bold text-2xl mb-5">What Is Usually Handled Locally</h3>
          <ul class="space-y-3 text-slate">
            {localScope.map((item) => <li>• {item}</li>)}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 md:py-24 bg-soft-green">
    <div class="container mx-auto px-4">
      <div class="text-center max-w-3xl mx-auto mb-12">
        <p class="sunlit-overline mb-4">How to Start</p>
        <h2 class="sunlit-section-title text-3xl md:text-5xl">Start Light, Then Add Detail</h2>
        <p class="text-slate leading-relaxed mt-4">The first message does not need to be perfect. A real buyer may only have a country, a rough roof size, photos, a product question or a price range.</p>
      </div>
      <div class="grid md:grid-cols-4 gap-5">
        {process.map((item) => (
          <div class="sunlit-card p-6">
            <div class="text-sm font-heading font-bold text-deep-green mb-4">{item.step}</div>
            <h3 class="font-heading font-bold text-charcoal mb-3">{item.title}</h3>
            <p class="text-sm text-slate leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16 md:py-24 bg-white">
    <div class="container mx-auto px-4">
      <div class="text-center max-w-3xl mx-auto mb-12">
        <p class="sunlit-overline mb-4">Next Step</p>
        <h2 class="sunlit-section-title text-3xl md:text-5xl">Go Deeper into the Product Line That Fits</h2>
        <p class="text-slate leading-relaxed mt-4">Supply Scope helps buyers understand the package. Product pages explain each system in detail.</p>
      </div>
      <div class="grid lg:grid-cols-2 gap-8">
        <a href="/lumina-slate/" class="sunlit-card p-8 block">
          <p class="sunlit-overline mb-3">Premium Glass Tile Line</p>
          <h3 class="font-heading font-bold text-3xl text-charcoal mb-3">Lumina Slate Glass Solar Roof Tiles</h3>
          <p class="text-slate mb-6">Premium glass tile line for villas and architectural projects.</p>
          <span class="font-heading font-bold text-deep-green">Explore Lumina Slate →</span>
        </a>
        <a href="/storm-guard/" class="sunlit-card p-8 block">
          <p class="sunlit-overline mb-3">Modern Metal Sheet Line</p>
          <h3 class="font-heading font-bold text-3xl text-charcoal mb-3">Storm Guard Metal Solar Roof Sheets</h3>
          <p class="text-slate mb-6">Modern metal sheet line for residential, commercial and large-area roofs.</p>
          <span class="font-heading font-bold text-deep-green">Explore Storm Guard →</span>
        </a>
      </div>
    </div>
  </section>

  <section class="py-16 md:py-24 bg-light-gray border-y border-border">
    <div class="container mx-auto px-4 max-w-5xl">
      <div class="text-center mb-10">
        <p class="sunlit-overline mb-4">FAQ</p>
        <h2 class="sunlit-section-title text-3xl md:text-5xl">Questions Buyers Usually Ask</h2>
      </div>
      <div class="grid md:grid-cols-2 gap-4">
        {faqs.map((question) => (
          <details class="sunlit-card p-5">
            <summary class="font-heading font-bold cursor-pointer">{question}</summary>
            <p class="text-slate mt-3 leading-relaxed">Send us what you have today. We can start with rough information and clarify the next step before a detailed quotation.</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16 md:py-20 dark-green-gradient text-white">
    <div class="container mx-auto px-4 max-w-4xl text-center">
      <p class="uppercase tracking-[0.16em] text-white/70 font-bold text-xs mb-4">Low-pressure first step</p>
      <h2 class="font-heading text-3xl md:text-5xl font-bold mb-5">Ask What Should Be Included in Your Roof Package</h2>
      <p class="text-white/75 leading-relaxed mb-8">Share your country, roof type, estimated roof area, photos, drawings or product interest. We will help you understand which product line and factory supply scope fits the project.</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/contact/" class="sunlit-btn-primary">Ask a Product Question</a>
        <a href="/contact/" class="border border-white/50 text-white rounded-full px-6 py-3 font-bold hover:bg-white/10 transition-colors">Get Factory Pricing</a>
      </div>
    </div>
  </section>
</Layout>
