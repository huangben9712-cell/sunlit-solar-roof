              <img
                src={item.img}
                alt={item.label}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                loading="lazy"
              />
            </div>
            <div class="p-4 flex items-center justify-between">
              <span class="font-heading font-bold text-charcoal group-hover:text-deep-green transition-colors">{item.label}</span>
              <svg class="text-amber group-hover:translate-x-1 transition-transform flex-shrink-0" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== FAQ ===== -->
  <section class="py-16 md:py-20 bg-white">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-[280px_1fr] gap-12 items-start">
        <div>
          <p class="sunlit-overline mb-3">Common Questions</p>
          <h2 class="sunlit-section-title text-3xl text-charcoal">Frequently Asked Questions</h2>
        </div>
        <div class="divide-y divide-border">
          {faqs.map((faq) => (
            <details class="group py-4">
              <summary class="flex items-center justify-between cursor-pointer font-heading font-bold text-charcoal list-none">
                <span>{faq.q}</span>
                <span class="ml-4 flex-shrink-0 w-6 h-6 rounded-full border border-border flex items-center justify-center text-slate group-open:rotate-45 transition-transform">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                </span>
              </summary>
              <p class="text-slate text-sm leading-relaxed mt-3 pr-10">{faq.a}</p>
            </details>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ===== CTA BANNER ===== -->
  <section class="dark-green-gradient py-16 md:py-20 relative overflow-hidden">
    <div class="absolute inset-0 opacity-10 pointer-events-none">
      <img
        src="/images/projects/beijing-new-world-lizun/sunlit-bipv-roof-villa-construction-site.webp"
        alt=""
        class="w-full h-full object-cover"
        loading="lazy"
      />
    </div>
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <div class="grid lg:grid-cols-[1fr_auto] gap-8 items-center">
        <div>
          <p class="text-white/60 text-xs font-heading font-bold tracking-widest uppercase mb-3">Ready When You Are</p>
          <h2 class="font-heading font-bold text-white text-3xl md:text-4xl leading-tight mb-3">
            Start the Conversation,<br>Then We Define the Right Scope
          </h2>
          <p class="text-white/70 leading-relaxed max-w-lg">
            You can start with simple information today. We will guide you step by step and review drawings later if available.
          </p>
        </div>
        <div class="flex flex-col gap-3 min-w-[220px]">
          <a href="/contact/" class="sunlit-btn-primary justify-center">Ask About My Project →</a>
          <a href="/contact/" class="sunlit-btn-primary justify-center" style="background: var(--amber);">Get Factory Pricing →</a>
        </div>
      </div>

      <!-- Trust Bar -->
      <div class="mt-12 pt-8 border-t border-white/15 grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {trustBar.map((item) => (
          <div class="flex items-start gap-3">
            <div class="text-white/70 flex-shrink-0 mt-0.5">
              <Fragment set:html={item.icon} />
            </div>
            <div>
              <p class="font-heading font-bold text-white text-sm">{item.title}</p>
              <p class="text-white/60 text-xs leading-relaxed mt-0.5">{item.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

</Layout>
