---
import Layout from '../layouts/Layout.astro';
import { activeTileSpecs, sharedActiveTilePerformance } from '../data/productSpecs';
import { luminaSlateComponents, stormGuardComponents, sharedComponents } from '../data/componentAssets';
import { projects } from '../data/projects';

const luminaSpec = activeTileSpecs.luminaSlate;
const stormSpec = activeTileSpecs.stormGuard;

const luminaProjects = projects.filter((p: any) => p.system === 'Lumina Slate').slice(0, 2);
const stormProjects = projects.filter((p: any) => p.system === 'Storm Guard').slice(0, 2);

const luminaCore = luminaSlateComponents.filter((c: any) => c.group === 'core');
const stormCore = stormGuardComponents.filter((c: any) => c.group === 'core');
const luminaTrim = luminaSlateComponents.filter((c: any) => c.group === 'trim-flashing');
const stormTrim = stormGuardComponents.filter((c: any) => c.group === 'trim-flashing');
---
<Layout title="Supply Scope — Complete Solar Roof Package | Sunlit Solar Roof" description="Understand exactly what Sunlit supplies for a complete solar roof project: active PV tiles or sheets, matching inactive elements, trim, flashing, fixings and project documents. Factory direct from China.">

  <!-- HERO -->
  <section class="relative h-[70vh] min-h-[500px] overflow-hidden">
    <img
      src="/images/projects/hangzhou-xianghu-arcadia-villa/sunlit-bipv-roof-scenic-harmony-xianghu-mountains.webp"
      alt="Complete solar roof package installed on villa"
      class="absolute inset-0 w-full h-full object-cover"
    />
    <div class="absolute inset-0 bg-gradient-to-r from-black/80 via-black/50 to-transparent"></div>
    <div class="relative z-10 h-full flex items-end pb-16 md:pb-24">
      <div class="max-w-7xl mx-auto px-6 w-full">
        <div class="max-w-2xl">
          <p class="text-amber text-sm font-semibold tracking-widest uppercase mb-4">Supply Scope</p>
          <h1 class="text-white text-5xl md:text-6xl font-bold leading-tight mb-5">What Sunlit Supplies</h1>
          <p class="text-white/75 text-xl leading-relaxed mb-8">A complete solar roof package — not just the panels. Active PV elements, matching inactive coverage, trim, flashing, fixings and project documents. Factory direct, B2B.</p>
          <div class="flex flex-wrap gap-4">
            <a href="#package-model" class="inline-flex items-center gap-2 bg-amber hover:bg-amber-dark text-gray-900 font-semibold px-7 py-3.5 rounded-lg transition-colors">
              See the Package
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
            </a>
            <a href="/contact/" class="inline-flex items-center gap-2 border border-white/40 hover:border-white text-white font-medium px-7 py-3.5 rounded-lg transition-colors">Request a Quote</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- PACKAGE MODEL -->
  <section id="package-model" class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-6">
      <div class="text-center mb-14">
        <p class="text-[#2d5a27] text-sm font-semibold tracking-widest uppercase mb-3">The Complete Package</p>
        <h2 class="text-4xl font-bold text-gray-900 mb-4">Four Layers of a Solar Roof Supply</h2>
        <p class="text-gray-500 max-w-2xl mx-auto">Every Sunlit supply package covers all four layers. One factory, one quote, one shipment — no sourcing gaps on site.</p>
      </div>
      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
        {[
          { num: '01', title: 'Active PV Elements', label: 'Generate Power', desc: 'Solar-generating glass tiles (Lumina Slate) or metal roof sheets (Storm Guard). The power-producing core of the roof.', img: '/images/components/lumina-slate/active-solar-tile.webp', badge: 'bg-[#2d5a27]' },
          { num: '02', title: 'Matching Inactive Elements', label: 'Complete the Roof Surface', desc: 'Non-generating tiles or sheets with the same appearance as the active elements. Used on shaded areas, edges and non-solar sections.', img: '/images/components/lumina-slate/inactive-half-tile-cuttable.webp', badge: 'bg-[#4a7c4e]' },
          { num: '03', title: 'Trim, Flashing & Fixings', label: 'Weatherproof the Edges', desc: 'Ridge pieces, gable panels, eave starters, valley flashing, fasteners and sealant tape. Every edge and transition point covered.', img: '/images/components/lumina-slate/ridge-tile.webp', badge: 'bg-amber' },
          { num: '04', title: 'Project Documents', label: 'Support the Project', desc: 'Datasheet, installation guide, BOM, packing list, test reports and export documentation. Everything needed to move the project forward.', img: '/images/projects/beijing-new-world-lizun/sunlit-bipv-roof-villa-construction-site.webp', badge: 'bg-gray-600' },
        ].map(item => (
          <div class="rounded-2xl overflow-hidden border border-gray-100 shadow-sm bg-white">
            <div class="h-48 overflow-hidden relative">
              <img src={item.img} alt={item.title} class="w-full h-full object-cover" />
              <div class="absolute top-4 left-4">
                <span class={`${item.badge} text-white text-xs font-bold px-3 py-1 rounded-full`}>{item.label}</span>
              </div>
            </div>
            <div class="p-6">
              <div class="text-gray-300 text-xs font-bold tracking-widest mb-2">{item.num}</div>
              <h3 class="text-gray-900 font-bold text-lg mb-2">{item.title}</h3>
              <p class="text-gray-500 text-sm leading-relaxed">{item.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- LUMINA vs STORM VISUAL COMPARISON -->
  <section class="py-20 bg-gray-50">
    <div class="max-w-7xl mx-auto px-6">
      <div class="text-center mb-14">
        <p class="text-[#2d5a27] text-sm font-semibold tracking-widest uppercase mb-3">Two Product Lines</p>
        <h2 class="text-4xl font-bold text-gray-900 mb-4">Lumina Slate vs Storm Guard</h2>
        <p class="text-gray-500 max-w-2xl mx-auto">Both lines are factory-supplied as complete packages. The choice depends on project type, aesthetic requirement and budget position.</p>
      </div>
      <div class="grid lg:grid-cols-2 gap-8 mb-10">
        <!-- Lumina Slate -->
        <div class="rounded-2xl overflow-hidden bg-white border border-gray-100 shadow-sm">
          <div class="relative h-64 overflow-hidden">
            <img src={luminaProjects[0]?.images[0] ?? '/images/projects/hangzhou-xianghu-arcadia-villa/sunlit-bipv-roof-scenic-harmony-xianghu-mountains.webp'} alt="Lumina Slate" class="w-full h-full object-cover" />
            <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent"></div>
            <div class="absolute bottom-4 left-5"><span class="bg-white text-[#2d5a27] text-xs font-bold px-3 py-1 rounded-full">Premium Glass Tile Line</span></div>
          </div>
          <div class="p-8">
            <h3 class="text-gray-900 text-2xl font-bold mb-2">Lumina Slate</h3>
            <p class="text-gray-500 text-sm leading-relaxed mb-5">Glass solar roof tiles with a slate-like premium finish. Designed for villas, high-end homes and architecture-led projects where appearance is part of the value proposition.</p>
            <div class="grid grid-cols-2 gap-3 mb-5">
              <div class="bg-gray-50 rounded-xl p-3"><div class="text-gray-400 text-xs mb-1">Power per Tile</div><div class="text-gray-900 font-bold">{luminaSpec.powerPmax}</div></div>
              <div class="bg-gray-50 rounded-xl p-3"><div class="text-gray-400 text-xs mb-1">Tile Size</div><div class="text-gray-900 font-bold text-xs">{luminaSpec.size}</div></div>
              <div class="bg-gray-50 rounded-xl p-3"><div class="text-gray-400 text-xs mb-1">Cell Type</div><div class="text-gray-900 font-bold text-xs">{luminaSpec.cellType}</div></div>
              <div class="bg-gray-50 rounded-xl p-3"><div class="text-gray-400 text-xs mb-1">Encapsulation</div><div class="text-gray-900 font-bold text-xs">{luminaSpec.encapsulation}</div></div>
            </div>
            <a href="/lumina-slate/" class="inline-flex items-center gap-2 bg-[#2d5a27] hover:bg-[#1a4d16] text-white font-semibold px-6 py-3 rounded-lg transition-colors text-sm">Explore Lumina Slate →</a>
          </div>
        </div>
        <!-- Storm Guard -->
        <div class="rounded-2xl overflow-hidden bg-white border border-gray-100 shadow-sm">
          <div class="relative h-64 overflow-hidden">
            <img src="/images/projects/large-scale-commercial-complex/storm-guard-large-scale-bipv-integration-aerial-scaled.webp" alt="Storm Guard" class="w-full h-full object-cover" />
            <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent"></div>
            <div class="absolute bottom-4 left-5"><span class="bg-amber text-gray-900 text-xs font-bold px-3 py-1 rounded-full">Modern Metal Sheet Line</span></div>
          </div>
          <div class="p-8">
            <h3 class="text-gray-900 text-2xl font-bold mb-2">Storm Guard</h3>
            <p class="text-gray-500 text-sm leading-relaxed mb-5">Standing-seam Al-Mg-Mn metal solar roof sheets engineered for large-scale, practical and typhoon-rated projects where durability and cost efficiency must coexist.</p>
            <div class="grid grid-cols-2 gap-3 mb-5">
              <div class="bg-gray-50 rounded-xl p-3"><div class="text-gray-400 text-xs mb-1">Power per Sheet</div><div class="text-gray-900 font-bold">{stormSpec.powerPmax}</div></div>
              <div class="bg-gray-50 rounded-xl p-3"><div class="text-gray-400 text-xs mb-1">Sheet Size</div><div class="text-gray-900 font-bold text-xs">{stormSpec.size}</div></div>
              <div class="bg-gray-50 rounded-xl p-3"><div class="text-gray-400 text-xs mb-1">Cell Type</div><div class="text-gray-900 font-bold text-xs">{stormSpec.cellType}</div></div>
              <div class="bg-gray-50 rounded-xl p-3"><div class="text-gray-400 text-xs mb-1">IP Rating</div><div class="text-gray-900 font-bold">IP68</div></div>
            </div>
            <a href="/storm-guard/" class="inline-flex items-center gap-2 bg-amber hover:bg-amber-dark text-gray-900 font-semibold px-6 py-3 rounded-lg transition-colors text-sm">Explore Storm Guard →</a>
          </div>
        </div>
      </div>
      <!-- Comparison table -->
      <div class="rounded-2xl overflow-hidden border border-gray-100 shadow-sm">
        <div class="grid grid-cols-3 bg-[#1a2e1a] text-white text-sm font-semibold">
          <div class="p-4 text-gray-400">Specification</div>
          <div class="p-4 text-center">Lumina Slate</div>
          <div class="p-4 text-center">Storm Guard</div>
        </div>
        {[
          { label: 'Active Element', lumina: 'Glass PV Tile', storm: 'Metal Solar Sheet' },
          { label: 'Power per Unit', lumina: luminaSpec.powerPmax, storm: stormSpec.powerPmax },
          { label: 'Unit Size', lumina: '1240 × 390 mm', storm: '1950 × 420 mm' },
          { label: 'Cell Technology', lumina: 'Mono PERC', storm: 'Mono TOPCON' },
          { label: 'Module Efficiency', lumina: luminaSpec.moduleEfficiency, storm: stormSpec.moduleEfficiency },
          { label: 'Encapsulation', lumina: 'Double glass', storm: 'Single glass' },
          { label: 'Best Application', lumina: 'Villas, premium residential', storm: 'Commercial, large residential' },
          { label: 'Roof Style', lumina: 'Steep pitch, tile look', storm: 'Low slope, metal seam look' },
          { label: 'Price Positioning', lumina: 'Premium', storm: 'Competitive' },
        ].map((row, i) => (
          <div class={`grid grid-cols-3 text-sm ${i % 2 === 0 ? 'bg-white' : 'bg-gray-50'} border-b border-gray-100 last:border-b-0`}>
            <div class="p-4 font-semibold text-gray-700">{row.label}</div>
            <div class="p-4 text-center text-gray-600">{row.lumina}</div>
            <div class="p-4 text-center text-gray-600">{row.storm}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- COMPONENT LIBRARY -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-6">
      <div class="text-center mb-14">
        <p class="text-[#2d5a27] text-sm font-semibold tracking-widest uppercase mb-3">Factory Supply Scope</p>
        <h2 class="text-4xl font-bold text-gray-900 mb-4">Every Component, Factory-Supplied</h2>
        <p class="text-gray-500 max-w-2xl mx-auto">Both product lines are supplied as complete packages. Every component shown below is factory-produced and included in the project quotation.</p>
      </div>
      <!-- Lumina Slate components -->
      <div class="mb-12">
        <div class="flex items-center gap-4 mb-5">
          <div class="h-px flex-1 bg-gray-200"></div>
          <div class="flex items-center gap-2"><span class="w-3 h-3 rounded-full bg-[#2d5a27]"></span><span class="text-xs font-bold text-gray-700 tracking-widest uppercase">Lumina Slate Components</span></div>
          <div class="h-px flex-1 bg-gray-200"></div>
        </div>
        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-4">
          {luminaCore.concat(luminaTrim).slice(0, 10).map((comp: any) => (
            <div class="bg-gray-50 rounded-2xl overflow-hidden border border-gray-100">
              <div class="bg-white p-4 flex items-center justify-center h-32"><img src={comp.image} alt={comp.name} class="max-h-full max-w-full object-contain" /></div>
              <div class="p-3"><h4 class="text-gray-900 font-semibold text-xs mb-1">{comp.name}</h4><p class="text-gray-400 text-xs leading-relaxed line-clamp-2">{comp.shortDescription}</p></div>
            </div>
          ))}
        </div>
        <div class="mt-3 text-right"><a href="/lumina-slate/#component-library" class="text-[#2d5a27] text-sm font-medium hover:underline">Full Lumina Slate component list →</a></div>
      </div>
      <!-- Storm Guard components -->
      <div class="mb-12">
        <div class="flex items-center gap-4 mb-5">
          <div class="h-px flex-1 bg-gray-200"></div>
          <div class="flex items-center gap-2"><span class="w-3 h-3 rounded-full bg-amber"></span><span class="text-xs font-bold text-gray-700 tracking-widest uppercase">Storm Guard Components</span></div>
          <div class="h-px flex-1 bg-gray-200"></div>
        </div>
        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-4">
          {stormCore.concat(stormTrim).slice(0, 7).map((comp: any) => (
            <div class="bg-gray-50 rounded-2xl overflow-hidden border border-gray-100">
              <div class="bg-white p-4 flex items-center justify-center h-32"><img src={comp.image} alt={comp.name} class="max-h-full max-w-full object-contain" /></div>
              <div class="p-3"><h4 class="text-gray-900 font-semibold text-xs mb-1">{comp.name}</h4><p class="text-gray-400 text-xs leading-relaxed line-clamp-2">{comp.shortDescription}</p></div>
            </div>
          ))}
        </div>
        <div class="mt-3 text-right"><a href="/storm-guard/#component-library" class="text-amber text-sm font-medium hover:underline">Full Storm Guard component list →</a></div>
      </div>
      <!-- Shared base layer -->
      <div>
        <div class="flex items-center gap-4 mb-5">
          <div class="h-px flex-1 bg-gray-200"></div>
          <div class="flex items-center gap-2"><span class="w-3 h-3 rounded-full bg-gray-400"></span><span class="text-xs font-bold text-gray-700 tracking-widest uppercase">Shared Base Layer (Both Lines)</span></div>
          <div class="h-px flex-1 bg-gray-200"></div>
        </div>
        <div class="grid grid-cols-2 md:grid-cols-5 gap-4">
          {sharedComponents.slice(0, 5).map((comp: any) => (
            <div class="bg-gray-50 rounded-2xl overflow-hidden border border-gray-100">
              <div class="bg-white p-4 flex items-center justify-center h-28"><img src={comp.image} alt={comp.name} class="max-h-full max-w-full object-contain" /></div>
              <div class="p-3"><h4 class="text-gray-900 font-semibold text-xs mb-1">{comp.name}</h4><p class="text-gray-400 text-xs leading-relaxed line-clamp-2">{comp.shortDescription}</p></div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- SUNLIT SUPPLIES vs LOCAL TEAMS -->
  <section class="py-20 bg-[#1a2e1a]">
    <div class="max-w-7xl mx-auto px-6">
      <div class="text-center mb-14">
        <p class="text-amber text-sm font-semibold tracking-widest uppercase mb-3">Scope Clarity</p>
        <h2 class="text-white text-4xl font-bold mb-4">What Sunlit Supplies vs What Local Teams Handle</h2>
        <p class="text-white/50 max-w-2xl mx-auto">Understanding the boundary between factory supply and on-site work helps you plan the project correctly from day one.</p>
      </div>
      <div class="grid md:grid-cols-2 gap-8">
        <div class="bg-white/10 rounded-2xl p-8 border border-white/20">
          <div class="flex items-center gap-3 mb-6">
            <div class="w-10 h-10 bg-amber rounded-full flex items-center justify-center flex-shrink-0">
              <svg class="w-5 h-5 text-gray-900" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
            </div>
            <h3 class="text-white text-xl font-bold">Sunlit Factory Supplies</h3>
          </div>
          <ul class="space-y-3">
            {['Active PV tiles or sheets (by product line)', 'Matching inactive tiles or sheets', 'Ridge pieces, gable panels, eave starters', 'Valley flashing and transition pieces', 'Dedicated fasteners and fixings', 'Butyl sealant tape and waterproof membrane', 'MC4 connectors and junction boxes', 'Product datasheet and installation guide', 'BOM, packing list and test reports', 'Export documentation and logistics support'].map(item => (
              <li class="flex items-start gap-3">
                <div class="w-5 h-5 rounded-full bg-amber/20 flex items-center justify-center flex-shrink-0 mt-0.5">
                  <svg class="w-3 h-3 text-amber" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
                </div>
                <span class="text-white/80 text-sm">{item}</span>
              </li>
            ))}
          </ul>
        </div>
        <div class="bg-white/5 rounded-2xl p-8 border border-white/10">
          <div class="flex items-center gap-3 mb-6">
            <div class="w-10 h-10 bg-white/20 rounded-full flex items-center justify-center flex-shrink-0">
              <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
            </div>
            <h3 class="text-white text-xl font-bold">Local Installation Teams Handle</h3>
          </div>
          <ul class="space-y-3">
            {['Roof structure assessment and preparation', 'Underlayment and batten installation', 'Tile or sheet laying and seam locking', 'Electrical wiring and inverter connection', 'Grid connection and commissioning', 'Local permits and inspection', 'Ongoing maintenance and monitoring'].map(item => (
              <li class="flex items-start gap-3">
                <div class="w-5 h-5 rounded-full bg-white/10 flex items-center justify-center flex-shrink-0 mt-0.5"><div class="w-2 h-2 rounded-full bg-white/40"></div></div>
                <span class="text-white/60 text-sm">{item}</span>
              </li>
            ))}
          </ul>
          <div class="mt-6 p-4 bg-white/10 rounded-xl">
            <p class="text-white/60 text-xs leading-relaxed">Sunlit can provide installation guidance, technical drawings and on-site support documentation to help local teams work efficiently with our products.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- PROJECTS PROOF -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-6">
      <div class="text-center mb-14">
        <p class="text-[#2d5a27] text-sm font-semibold tracking-widest uppercase mb-3">Delivered Projects</p>
        <h2 class="text-4xl font-bold text-gray-900 mb-4">Both Lines, Deployed in the Field</h2>
        <p class="text-gray-500 max-w-2xl mx-auto">Factory supply packages delivered to real projects across China and internationally.</p>
      </div>
      <div class="grid md:grid-cols-2 gap-6 mb-6">
        {luminaProjects.map((proj: any) => (
          <a href={`/projects/${proj.slug}/`} class="rounded-2xl overflow-hidden group block">
            <div class="relative h-56 overflow-hidden">
              <img src={proj.images[0]} alt={proj.name} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" />
              <div class="absolute inset-0 bg-gradient-to-t from-black/70 to-transparent"></div>
              <div class="absolute bottom-4 left-5 right-5">
                <span class="text-white/60 text-xs font-bold tracking-widest uppercase">Lumina Slate</span>
                <h3 class="text-white font-bold text-lg mt-1">{proj.name}</h3>
                <div class="flex gap-3 mt-1">{proj.roofArea && <span class="text-white/70 text-xs">{proj.roofArea}</span>}{proj.capacity && <span class="text-white/70 text-xs">· {proj.capacity}</span>}</div>
              </div>
            </div>
          </a>
        ))}
      </div>
      <div class="grid md:grid-cols-2 gap-6 mb-10">
        {stormProjects.map((proj: any) => (
          <a href={`/projects/${proj.slug}/`} class="rounded-2xl overflow-hidden group block">
            <div class="relative h-56 overflow-hidden">
              <img src={proj.images[0]} alt={proj.name} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" />
              <div class="absolute inset-0 bg-gradient-to-t from-black/70 to-transparent"></div>
              <div class="absolute bottom-4 left-5 right-5">
                <span class="text-amber text-xs font-bold tracking-widest uppercase">Storm Guard</span>
                <h3 class="text-white font-bold text-lg mt-1">{proj.name}</h3>
                <div class="flex gap-3 mt-1">{proj.roofArea && <span class="text-white/70 text-xs">{proj.roofArea}</span>}{proj.capacity && <span class="text-white/70 text-xs">· {proj.capacity}</span>}</div>
              </div>
            </div>
          </a>
        ))}
      </div>
      <div class="text-center">
        <a href="/projects/" class="inline-flex items-center gap-2 border border-[#2d5a27] text-[#2d5a27] hover:bg-[#2d5a27] hover:text-white font-medium px-8 py-3.5 rounded-lg transition-colors">View All Projects →</a>
      </div>
    </div>
  </section>

  <!-- SHARED PERFORMANCE SPECS -->
  <section class="py-20 bg-gray-50">
    <div class="max-w-7xl mx-auto px-6">
      <div class="text-center mb-14">
        <p class="text-[#2d5a27] text-sm font-semibold tracking-widest uppercase mb-3">Shared Performance Standards</p>
        <h2 class="text-4xl font-bold text-gray-900 mb-4">Both Lines Meet the Same Performance Baseline</h2>
        <p class="text-gray-500 max-w-2xl mx-auto">Regardless of which product line you choose, the active elements share the same structural, weather and safety performance standards.</p>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 max-w-4xl mx-auto">
        {sharedActiveTilePerformance.map((item: any) => (
          <div class="bg-white rounded-2xl p-6 border border-gray-100 shadow-sm text-center">
            <div class="text-2xl font-bold text-[#2d5a27] mb-2">{item.value}</div>
            <div class="text-gray-500 text-sm">{item.label}</div>
          </div>
