        tabLumina.className = 'px-5 py-2.5 rounded-full font-heading font-bold text-sm bg-deep-green text-white transition-all';
        tabStorm.className = 'px-5 py-2.5 rounded-full font-heading font-bold text-sm bg-white border border-border text-slate hover:border-deep-green hover:text-deep-green transition-all';
