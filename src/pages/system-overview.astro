---
import Layout from '../layouts/Layout.astro';

const components = [
  { title: "Active PV Elements", desc: "Solar-generating glass roof tiles or metal roof sheets supplied according to the selected product line." },
  { title: "Matching Inactive Elements", desc: "Non-generating roof elements used for edges, shaded areas and sections where PV is not required." },
  { title: "Flashing and Drainage Details", desc: "Edge, transition and water-management parts selected according to roof layout and quotation scope." },
  { title: "Fixings and Accessories", desc: "Fasteners, ridge pieces, edge pieces and supporting roof integration components." },
  { title: "Project Documents", desc: "Datasheets, installation notes, packing information and quotation documents based on project stage." },
  { title: "Export Packaging", desc: "Factory packing and shipping coordination for overseas project delivery." }
];

const buyerBenefits = [
  { title: "Clear Factory Scope", desc: "The buyer can see what the China factory is supplying instead of comparing isolated PV tiles only." },
  { title: "Better Cost Control", desc: "Active, inactive and accessory scope can be quoted together before the buyer commits to the project." },
  { title: "Easier Local Planning", desc: "Local roof and electrical teams can review the supply package and documents before installation." },
  { title: "More Useful B2B Quotation", desc: "Roof drawing, product line, coverage ratio and export details are discussed as one sourcing package." }
];

const comparison = [
  ["Positioning", "Premium glass solar roof tile line", "Modern metal solar roof sheet line"],
  ["Active Element", "AG-etched glass PV roof tile", "Metal solar roof sheet"],
  ["Inactive Element", "Matching glass inactive tile", "Matching inactive metal element"],
  ["Appearance", "Premium slate-like glass roof", "Contemporary metal roof profile"],
  ["Best Fit", "Villas and architectural projects", "Residential, commercial and large roof projects"],
  ["Cost Position", "Premium", "More cost-effective"]
];
---

<Layout title="China Solar Roof Manufacturer Supply Scope" description="Compare Lumina Slate and Storm Guard BIPV systems. Understand the complete factory supply scope for your solar roof project.">
  <section class="bg-soft-green py-14 md:py-20">
    <div class="container mx-auto px-4 max-w-4xl">
      <p class="sunlit-overline mb-4">Manufacturer Supply Scope</p>
      <h1 class="sunlit-section-title text-4xl md:text-6xl mb-6">What We Supply as a China Solar Roof Manufacturer</h1>
      <p class="text-lg md:text-xl text-slate leading-relaxed">
        Sunlit is not positioning this page as a turnkey EPC service. This page explains the factory supply package: active solar roof elements, matching inactive roof elements, flashing, fixings, accessories, documents and export coordination for overseas B2B buyers.
      </p>
    </div>
  </section>

  <section class="py-16 md:py-24 bg-white">
    <div class="container mx-auto px-4">
      <div class="grid lg:grid-cols-3 gap-10 items-start">
        <div>
          <p class="sunlit-overline mb-3">Definition</p>
          <h2 class="sunlit-section-title text-3xl md:text-4xl mb-4">Complete Package Means Supply Scope</h2>
          <p class="text-slate leading-relaxed">
            When we say complete solar roof package, we mean the product scope a factory can supply for a roof project. It does not mean we replace local roofers, electricians, permit work or local engineering responsibility.
          </p>
        </div>
        <div class="lg:col-span-2 grid sm:grid-cols-2 gap-5">
          {components.map((item, index) => (
            <div class="sunlit-card p-6">
              <div class="text-xs font-heading font-bold text-deep-green mb-3">0{index + 1}</div>
              <h3 class="font-heading font-bold text-charcoal mb-2">{item.title}</h3>
              <p class="text-sm text-slate leading-relaxed">{item.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 md:py-24 bg-soft-green">
    <div class="container mx-auto px-4">
      <div class="text-center max-w-3xl mx-auto mb-12">
        <p class="sunlit-overline mb-3">B2B Sourcing Logic</p>
        <h2 class="sunlit-section-title text-3xl md:text-5xl mb-4">Why Supply Scope Matters</h2>
        <p class="text-slate">For distributors, installers, contractors and developers, the main question is not only wattage. They need to know what the factory can supply, what needs to be sourced locally and how the quotation boundary is defined.</p>
      </div>
      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-5">
        {buyerBenefits.map((item) => (
          <div class="sunlit-card p-6">
            <h3 class="font-heading font-bold text-charcoal mb-3">{item.title}</h3>
            <p class="text-sm text-slate leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16 md:py-24 bg-white">
    <div class="container mx-auto px-4">
      <div class="max-w-3xl mb-10">
        <p class="sunlit-overline mb-3">Product Line Comparison</p>
        <h2 class="sunlit-section-title text-3xl md:text-5xl mb-4">Lumina Slate or Storm Guard?</h2>
        <p class="text-slate">The right product line depends on roof appearance, buyer role, project size and budget position.</p>
      </div>
      <div class="sunlit-card overflow-hidden">
        <div class="grid grid-cols-3 bg-[var(--deep-green)] text-white font-heading font-bold">
          <div class="p-4">Decision Point</div>
          <div class="p-4">Lumina Slate</div>
          <div class="p-4">Storm Guard</div>
        </div>
        {comparison.map((row) => (
          <div class="grid grid-cols-3 border-b border-border last:border-b-0">
            <div class="p-4 font-heading font-bold text-charcoal">{row[0]}</div>
            <div class="p-4 text-slate">{row[1]}</div>
            <div class="p-4 text-slate">{row[2]}</div>
          </div>
        ))}
      </div>
      <div class="flex flex-col sm:flex-row gap-4 mt-8">
        <a href="/lumina-slate/" class="sunlit-btn-secondary">View Lumina Slate</a>
        <a href="/storm-guard/" class="sunlit-btn-secondary">View Storm Guard</a>
        <a href="/contact/" class="sunlit-btn-primary">Send Roof Drawing</a>
      </div>
    </div>
  </section>

  <section class="py-16 md:py-20 dark-green-gradient text-white">
    <div class="container mx-auto px-4 text-center">
      <h2 class="text-3xl md:text-5xl font-heading font-bold mb-5">Start with Your Roof Drawing</h2>
      <p class="text-lg text-white/75 max-w-2xl mx-auto mb-8">Send project country, roof area and drawings. We will help define the factory supply scope, product line and quotation direction.</p>
      <a href="/contact/" class="sunlit-btn-primary">Request Factory Quote</a>
    </div>
  </section>
</Layout>
