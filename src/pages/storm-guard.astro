---
import Layout from '../layouts/Layout.astro';
import { getComponentsBySystem } from '../data/systemComponents';
import { productFAQs, generalFAQs } from '../data/faqs';

const components = getComponentsBySystem('Storm Guard');
const faqs = [...productFAQs, ...generalFAQs].slice(0, 5);
const heroImage = "https://d2xsxph8kpxj0f.cloudfront.net/310519663705242844/mtvS4X69r9pvLdqcQTXPeQ/storm-guard-hero-Rv3C82SNHYaBM2TVgU4t7W.webp";

const specs = [
  ["Factory Role", "China manufacturer and export supplier"],
  ["Product Line", "Modern metal solar roof sheets"],
  ["Active Element", "Low-standing-seam Al-Mg-Mn metal solar roof sheets"],
  ["Inactive Element", "Matching inactive metal roof elements"],
  ["Main Buyer Value", "More practical cost position than premium glass systems"],
  ["Best Fit", "Modern residential, commercial, public and large roof projects"],
  ["Documents", "Datasheets and warranty documents available upon request"]
];

const applications = ["Modern homes", "Commercial buildings", "Public buildings", "Large roof projects"];
---

<Layout title="Storm Guard Metal Solar Roof Sheets - China Manufacturer" description="Storm Guard: low-standing-seam Al-Mg-Mn metal BIPV solar roof sheets. Cost-effective factory supply for large-area projects.">
  <section class="border-b border-border bg-white">
    <div class="container mx-auto px-4 py-4 text-sm text-slate">
      <a href="/" class="hover:text-deep-green">Home</a>
      <span class="mx-2">/</span>
      <a href="/system-overview/" class="hover:text-deep-green">Solar Roof Supply Scope</a>
      <span class="mx-2">/</span>
      <span class="font-bold text-charcoal">Storm Guard</span>
    </div>
  </section>

  <section class="bg-soft-green py-14 md:py-20">
    <div class="container mx-auto px-4">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div>
          <p class="sunlit-overline mb-4">China Manufacturer · Metal Solar Roof Sheets</p>
          <h1 class="sunlit-section-title text-4xl md:text-6xl mb-6">Storm Guard Metal Solar Roof Sheets for Overseas Projects</h1>
          <p class="text-lg md:text-xl text-slate leading-relaxed mb-8">
            Factory supply of low-standing-seam Al-Mg-Mn metal solar roof sheets, matching inactive metal roof elements, flashing, fixings and accessories for modern residential, commercial, public and large roof projects.
          </p>
          <div class="flex flex-col sm:flex-row gap-3 mb-8">
            <a href="/contact/" class="sunlit-btn-primary">Get Factory Quote</a>
            <a href="/resources/" class="sunlit-btn-secondary">Request Datasheet</a>
          </div>
          <div class="grid grid-cols-3 gap-3">
            <div class="stat-pill p-4"><div class="font-heading font-bold text-deep-green">China Factory</div><div class="text-xs text-slate">Export supply</div></div>
            <div class="stat-pill p-4"><div class="font-heading font-bold text-deep-green">Metal Roof</div><div class="text-xs text-slate">Modern profile</div></div>
            <div class="stat-pill p-4"><div class="font-heading font-bold text-deep-green">Project Based</div><div class="text-xs text-slate">Quoted by roof layout</div></div>
          </div>
        </div>
        <div class="sunlit-card overflow-hidden p-3">
          <img src={heroImage} alt="Storm Guard metal solar roof sheets from China manufacturer" class="w-full h-[420px] object-cover rounded-2xl" />
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 md:py-24 bg-white">
    <div class="container mx-auto px-4">
      <div class="grid lg:grid-cols-3 gap-10 items-start">
        <div>
          <p class="sunlit-overline mb-3">What We Supply</p>
          <h2 class="sunlit-section-title text-3xl md:text-4xl mb-4">Modern Metal Solar Roof Supply for Practical Projects</h2>
          <p class="text-slate leading-relaxed">
            Storm Guard is presented as a factory-supplied metal solar roof product line. Sunlit supplies active metal solar sheets, matching inactive roof elements and related accessories. Local roofing and electrical work should be handled by qualified local professionals.
          </p>
        </div>
        <div class="lg:col-span-2 grid sm:grid-cols-2 gap-5">
          <div class="sunlit-card p-6">
            <div class="h-32 image-placeholder rounded-2xl mb-5"></div>
            <h3 class="font-heading font-bold text-xl mb-2">Active Metal Solar Sheet</h3>
            <p class="text-slate leading-relaxed">The active roof sheet combines metal roofing appearance with photovoltaic power generation.</p>
          </div>
          <div class="sunlit-card p-6">
            <div class="h-32 image-placeholder rounded-2xl mb-5"></div>
            <h3 class="font-heading font-bold text-xl mb-2">Matching Inactive Element</h3>
            <p class="text-slate leading-relaxed">Inactive metal roof elements cover areas where solar generation is not required while keeping a consistent roof appearance.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 md:py-24 bg-soft-green">
    <div class="container mx-auto px-4">
      <div class="text-center max-w-3xl mx-auto mb-12">
        <p class="sunlit-overline mb-3">Factory Supply Package</p>
        <h2 class="sunlit-section-title text-3xl md:text-5xl mb-4">What the Storm Guard Package May Include</h2>
        <p class="text-slate">The exact bill of materials depends on roof layout. The package may include the following coordinated components from factory supply.</p>
      </div>
      <div class="grid md:grid-cols-2 lg:grid-cols-5 gap-5">
        {components.map((component, index) => (
          <div class="sunlit-card p-5">
            <div class="text-xs font-heading font-bold text-deep-green mb-3">0{index + 1}</div>
            <h3 class="font-heading font-bold text-charcoal mb-2">{component.name}</h3>
            <p class="text-sm text-slate leading-relaxed">{component.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16 md:py-24 bg-white">
    <div class="container mx-auto px-4">
      <div class="grid lg:grid-cols-2 gap-10">
        <div>
          <p class="sunlit-overline mb-3">Early Evaluation</p>
          <h2 class="sunlit-section-title text-3xl md:text-4xl mb-4">Key Information for Factory Quotation</h2>
          <p class="text-slate mb-6">Final specifications depend on roof layout, active and inactive coverage, selected components and destination. Detailed datasheets are available upon request.</p>
          <a href="/contact/" class="sunlit-btn-green">Send Roof Drawing</a>
        </div>
        <div class="sunlit-card overflow-hidden">
          {specs.map(([label, value]) => (
            <div class="grid grid-cols-3 gap-4 p-4 border-b border-border last:border-b-0">
              <div class="font-heading font-bold text-charcoal">{label}</div>
              <div class="col-span-2 text-slate">{value}</div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 bg-soft-green">
    <div class="container mx-auto px-4">
      <p class="sunlit-overline text-center mb-3">Suitable Projects</p>
      <div class="grid md:grid-cols-4 gap-4">
        {applications.map((app) => (
          <div class="sunlit-card-soft p-6 text-center font-heading font-bold text-charcoal">{app}</div>
        ))}
      </div>
    </div>
  </section>

  <section id="faq" class="py-16 md:py-24 bg-white">
    <div class="container mx-auto px-4 max-w-4xl">
      <h2 class="sunlit-section-title text-3xl md:text-5xl mb-10 text-center">Storm Guard FAQ</h2>
      <div class="space-y-4">
        {faqs.map((faq) => (
          <div class="border border-border rounded-2xl p-6">
            <h3 class="font-heading font-bold text-charcoal mb-2">{faq.question}</h3>
            <p class="text-slate leading-relaxed">{faq.answer}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16 md:py-20 dark-green-gradient text-white">
    <div class="container mx-auto px-4 text-center">
      <h2 class="text-3xl md:text-5xl font-heading font-bold mb-5">Evaluate Storm Guard for Your Project</h2>
      <p class="text-lg text-white/75 max-w-2xl mx-auto mb-8">Send your roof drawing, country and estimated roof area. We will help discuss active and inactive coverage, accessory scope and factory quotation direction.</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/contact/" class="sunlit-btn-primary">Get Storm Guard Factory Quote</a>
        <a href="/projects/" class="border border-white/60 text-white rounded-full px-6 py-3 font-heading font-bold hover:bg-white/10">View Projects</a>
      </div>
    </div>
  </section>
</Layout>
