---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Storm Guard Metal Solar Roof System">
  <section class="py-16 bg-white">
    <div class="container mx-auto px-4 max-w-4xl">
      <h1 class="text-4xl font-bold mb-6">Storm Guard Metal Solar Roof System</h1>
      <p class="text-lg text-gray-600 leading-relaxed mb-6">
        Storm Guard is a low-standing-seam Al-Mg-Mn metal solar roofing system with active solar roof sheets, matching inactive metal roof elements, flashing, fixings and accessories.
      </p>
      <p class="text-gray-600 leading-relaxed">
        It is designed for modern residential, commercial, public and large roof projects where buyers need a practical integrated solar roof system with a lower cost position than premium glass systems.
      </p>
    </div>
  </section>
</Layout>
