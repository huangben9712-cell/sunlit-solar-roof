---
import Layout from '../layouts/Layout.astro';
import { activeTileSpecs, sharedActiveTilePerformance } from '../data/productSpecs';
import { stormGuardComponents } from '../data/componentAssets';
import { projects } from '../data/projects';

const spec = activeTileSpecs.stormGuard;

// Storm Guard projects
const stormProjects = projects.filter((p: any) => p.system === 'Storm Guard');
const heroProject = stormProjects.find((p: any) => p.slug === 'large-scale-commercial-complex');
const urbanRetrofit = stormProjects.find((p: any) => p.slug === 'urban-compact-home-retrofit');
const lowSlope = stormProjects.find((p: any) => p.slug === 'urban-low-slope-extension');

// Component groups
const coreComponents = stormGuardComponents.filter((c: any) => c.group === 'core');
const trimComponents = stormGuardComponents.filter((c: any) => c.group === 'trim-flashing');
const accessoryComponents = stormGuardComponents.filter((c: any) => c.group === 'accessory');

// Installation videos
const installVideos = [
  {
    src: '/videos/installation/storm-guard/P135  安装1.mp4',
    poster: '/videos/installation/storm-guard/P135  安装1-poster.webp',
    label: 'Step 1 — Sheet Laying',
  },
  {
    src: '/videos/installation/storm-guard/P135  安装2.mp4',
    poster: '/videos/installation/storm-guard/P135  安装2-poster.webp',
    label: 'Step 2 — Seam Locking',
  },
  {
    src: '/videos/installation/storm-guard/P135  安装3.mp4',
    poster: '/videos/installation/storm-guard/P135  安装3-poster.webp',
    label: 'Step 3 — Ridge & Edge',
  },
  {
    src: '/videos/installation/storm-guard/完工效果.mp4',
    poster: '/videos/installation/storm-guard/完工效果-poster.webp',
    label: 'Completed Roof Result',
  },
];
---
<Layout title="Storm Guard — Metal Solar Roof Sheets | Sunlit Solar Roof" description="Storm Guard is a modern metal solar roof sheet line for large-scale, practical and cost-positioned BIPV projects. 135W per sheet, standing-seam Al-Mg-Mn alloy, typhoon-rated. Factory direct from China.">

  <!-- HERO -->
  <section class="relative h-[90vh] min-h-[600px] overflow-hidden">
    <img
      src="/images/projects/large-scale-commercial-complex/storm-guard-large-scale-bipv-integration-aerial-scaled.webp"
      alt="Storm Guard metal solar roof sheets installed on large-scale commercial complex"
      class="absolute inset-0 w-full h-full object-cover"
    />
    <div class="absolute inset-0 bg-gradient-to-r from-black/80 via-black/45 to-transparent"></div>
    <div class="relative z-10 h-full flex items-end pb-16 md:pb-24">
      <div class="max-w-7xl mx-auto px-6 w-full">
        <div class="max-w-2xl">
          <p class="text-amber text-sm font-semibold tracking-widest uppercase mb-4">Metal Solar Roof Sheet</p>
          <h1 class="text-white text-5xl md:text-6xl font-bold leading-tight mb-6">Storm Guard</h1>
          <p class="text-white/80 text-xl mb-8 leading-relaxed">
            A standing-seam Al-Mg-Mn metal solar roof sheet line engineered for large-scale, practical and typhoon-rated projects where durability and cost efficiency must coexist.
          </p>
          <div class="flex flex-wrap gap-6 mb-10">
            <div class="text-white">
              <div class="text-3xl font-bold text-amber">{spec.powerPmax}</div>
              <div class="text-sm text-white/60 mt-1">Per Active Sheet</div>
            </div>
            <div class="w-px bg-white/20 self-stretch"></div>
            <div class="text-white">
              <div class="text-3xl font-bold text-amber">IP68</div>
              <div class="text-sm text-white/60 mt-1">Waterproof Rating</div>
            </div>
            <div class="w-px bg-white/20 self-stretch"></div>
            <div class="text-white">
              <div class="text-3xl font-bold text-amber">Grade A</div>
              <div class="text-sm text-white/60 mt-1">Fire Rating</div>
            </div>
            <div class="w-px bg-white/20 self-stretch"></div>
            <div class="text-white">
              <div class="text-3xl font-bold text-amber">10+</div>
              <div class="text-sm text-white/60 mt-1">Completed Projects</div>
            </div>
          </div>
          <div class="flex flex-wrap gap-4">
            <a href="/contact/" class="inline-flex items-center gap-2 bg-amber hover:bg-amber-dark text-gray-900 font-semibold px-7 py-3.5 rounded-lg transition-colors">
              Request Sample or Quote
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
            </a>
            <a href="#component-library" class="inline-flex items-center gap-2 border border-white/40 hover:border-white text-white font-medium px-7 py-3.5 rounded-lg transition-colors">
              View Components
            </a>
          </div>
        </div>
      </div>
    </div>
    <div class="absolute bottom-4 right-6 text-white/40 text-xs">Large-Scale Commercial Complex · Storm Guard Installation</div>
  </section>

  <!-- TRUST BAR -->
  <section class="bg-[#1a2e1a] border-b border-white/10">
    <div class="max-w-7xl mx-auto px-6 py-5">
      <div class="grid grid-cols-2 md:grid-cols-5 gap-4 text-center">
        {[
          { icon: '⚡', label: '135W per sheet', sub: 'Monocrystalline TOPCON' },
          { icon: '💧', label: 'IP68 rated', sub: 'Structural waterproof' },
          { icon: '🔥', label: 'Grade A fire', sub: '≥5400Pa mechanical load' },
          { icon: '🌪️', label: '35mm hail', sub: 'Typhoon-level wind resist.' },
          { icon: '🏗️', label: '10+ projects', sub: 'Factory direct, B2B' },
        ].map(item => (
          <div class="flex flex-col items-center gap-1 py-2">
            <span class="text-xl">{item.icon}</span>
            <span class="text-white font-semibold text-sm">{item.label}</span>
            <span class="text-white/50 text-xs">{item.sub}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ACTIVE + INACTIVE SYSTEM -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-6">
      <div class="text-center mb-14">
        <p class="text-[#2d5a27] text-sm font-semibold tracking-widest uppercase mb-3">How the System Works</p>
        <h2 class="text-4xl font-bold text-gray-900 mb-4">Active Sheets + Matching Metal Sheets</h2>
        <p class="text-gray-500 max-w-2xl mx-auto">Every Storm Guard roof uses a mix of power-generating active sheets and matching non-generating metal sheets. The same Al-Mg-Mn alloy and fluorocarbon coating ensures a uniform roof surface across the entire installation.</p>
      </div>

      <div class="grid md:grid-cols-2 gap-8">
        <!-- Active Sheet -->
        <div class="rounded-2xl border border-gray-100 overflow-hidden bg-white shadow-sm">
          <div class="bg-gray-50 p-8 flex items-center justify-center h-64">
            <img
              src={coreComponents[0]?.image}
              alt="Storm Guard Active Solar Sheet"
              class="max-h-full max-w-full object-contain"
            />
          </div>
          <div class="p-8">
            <span class="inline-block bg-[#2d5a27] text-white text-xs font-bold tracking-widest uppercase px-3 py-1 rounded-full mb-4">Generates Power</span>
            <h3 class="text-gray-900 text-2xl font-bold mb-3">Active Solar Sheet</h3>
            <p class="text-gray-500 text-sm leading-relaxed mb-6">{spec.powerPmax} monocrystalline TOPCON metal solar roof sheet with Al-Mg-Mn alloy low-standing-seam base and fluorocarbon coating.</p>
            <div class="grid grid-cols-2 gap-3">
              <div class="bg-gray-50 rounded-xl p-4">
                <div class="text-gray-400 text-xs mb-1">Power</div>
                <div class="text-gray-900 font-semibold">{spec.powerPmax}</div>
              </div>
              <div class="bg-gray-50 rounded-xl p-4">
                <div class="text-gray-400 text-xs mb-1">Size</div>
                <div class="text-gray-900 font-semibold">{spec.size}</div>
              </div>
              <div class="bg-gray-50 rounded-xl p-4">
                <div class="text-gray-400 text-xs mb-1">Weight</div>
                <div class="text-gray-900 font-semibold">{spec.weight}</div>
              </div>
              <div class="bg-gray-50 rounded-xl p-4">
                <div class="text-gray-400 text-xs mb-1">Cell Type</div>
                <div class="text-gray-900 font-semibold">{spec.cellType}</div>
              </div>
              <div class="bg-gray-50 rounded-xl p-4 col-span-2">
                <div class="text-gray-400 text-xs mb-1">Encapsulation</div>
                <div class="text-gray-900 font-semibold">{spec.encapsulation}</div>
              </div>
              <div class="bg-gray-50 rounded-xl p-4 col-span-2">
                <div class="text-gray-400 text-xs mb-1">Module Efficiency</div>
                <div class="text-gray-900 font-semibold">{spec.moduleEfficiency}</div>
              </div>
            </div>
          </div>
        </div>

        <!-- Matching Metal Sheet -->
        <div class="rounded-2xl border border-gray-100 overflow-hidden bg-white shadow-sm">
          <div class="bg-gray-50 p-8 flex items-center justify-center h-64">
            <img
              src={coreComponents[1]?.image}
              alt="Storm Guard Matching Metal Sheet"
              class="max-h-full max-w-full object-contain"
            />
          </div>
          <div class="p-8">
            <span class="inline-block bg-gray-400 text-white text-xs font-bold tracking-widest uppercase px-3 py-1 rounded-full mb-4">Matching Appearance</span>
            <h3 class="text-gray-900 text-2xl font-bold mb-3">Matching Metal Sheet</h3>
            <p class="text-gray-500 text-sm leading-relaxed mb-6">Non-generating metal roof sheet with the same Al-Mg-Mn alloy and fluorocarbon coating as the active sheet. Used where PV is not required or not suitable — no visible difference from active sheets.</p>
            <div class="bg-gray-50 rounded-xl p-5 space-y-3">
              <div class="flex items-start gap-3">
                <div class="w-1.5 h-1.5 rounded-full bg-[#2d5a27] mt-2 flex-shrink-0"></div>
                <p class="text-gray-600 text-sm">Same Al-Mg-Mn alloy base and fluorocarbon coating as active sheet</p>
              </div>
              <div class="flex items-start gap-3">
                <div class="w-1.5 h-1.5 rounded-full bg-[#2d5a27] mt-2 flex-shrink-0"></div>
                <p class="text-gray-600 text-sm">Identical standing-seam profile for uniform roof surface</p>
              </div>
              <div class="flex items-start gap-3">
                <div class="w-1.5 h-1.5 rounded-full bg-[#2d5a27] mt-2 flex-shrink-0"></div>
                <p class="text-gray-600 text-sm">Used on non-solar areas, hips, valleys and complex roof sections</p>
              </div>
              <div class="flex items-start gap-3">
                <div class="w-1.5 h-1.5 rounded-full bg-[#2d5a27] mt-2 flex-shrink-0"></div>
                <p class="text-gray-600 text-sm">Supplied as part of the complete factory package</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- COMPONENT LIBRARY -->
  <section id="component-library" class="py-20 bg-gray-50">
    <div class="max-w-7xl mx-auto px-6">
      <div class="text-center mb-14">
        <p class="text-[#2d5a27] text-sm font-semibold tracking-widest uppercase mb-3">Complete System</p>
        <h2 class="text-4xl font-bold text-gray-900 mb-4">Component Library</h2>
        <p class="text-gray-500 max-w-2xl mx-auto">Every component in the Storm Guard system is factory-produced and supplied together. No sourcing gaps, no compatibility surprises on site.</p>
      </div>

      <!-- Core Sheets -->
      <h3 class="text-xs font-bold text-gray-400 tracking-widest uppercase mb-5 border-b border-gray-200 pb-3">Core Sheets</h3>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-10">
        {coreComponents.map((comp: any) => (
          <div class="bg-white rounded-2xl overflow-hidden border border-gray-100 shadow-sm">
            <div class="bg-gray-50 p-4 flex items-center justify-center h-36">
              <img src={comp.image} alt={comp.name} class="max-h-full max-w-full object-contain" />
            </div>
            <div class="p-4">
              <h4 class="text-gray-900 font-semibold text-sm mb-1">{comp.name}</h4>
              {comp.keySpecs && comp.keySpecs.length > 0 && (
                <div class="flex flex-wrap gap-1 mb-2">
                  {comp.keySpecs.map((s: any) => (
                    <span class="text-xs bg-[#2d5a27]/10 text-[#2d5a27] px-2 py-0.5 rounded-full font-medium">{s.label}: {s.value}</span>
                  ))}
                </div>
              )}
              <p class="text-gray-500 text-xs leading-relaxed">{comp.shortDescription}</p>
            </div>
          </div>
        ))}
      </div>

      <!-- Trim & Flashing -->
      <h3 class="text-xs font-bold text-gray-400 tracking-widest uppercase mb-5 border-b border-gray-200 pb-3">Trim & Flashing</h3>
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-4 mb-10">
        {trimComponents.map((comp: any) => (
          <div class="bg-white rounded-2xl overflow-hidden border border-gray-100 shadow-sm">
            <div class="bg-gray-50 p-3 flex items-center justify-center h-28">
              <img src={comp.image} alt={comp.name} class="max-h-full max-w-full object-contain" />
            </div>
            <div class="p-3">
              <h4 class="text-gray-900 font-semibold text-xs mb-1">{comp.name}</h4>
              <p class="text-gray-500 text-xs leading-relaxed">{comp.shortDescription}</p>
            </div>
          </div>
        ))}
      </div>

      <!-- Accessories -->
      {accessoryComponents.length > 0 && (
        <div>
          <h3 class="text-xs font-bold text-gray-400 tracking-widest uppercase mb-5 border-b border-gray-200 pb-3">Accessories & Fasteners</h3>
          <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
            {accessoryComponents.map((comp: any) => (
              <div class="bg-white rounded-2xl overflow-hidden border border-gray-100 shadow-sm">
                <div class="bg-gray-50 p-4 flex items-center justify-center h-28">
                  <img src={comp.image} alt={comp.name} class="max-h-full max-w-full object-contain" />
                </div>
                <div class="p-4">
                  <h4 class="text-gray-900 font-semibold text-sm mb-1">{comp.name}</h4>
                  <p class="text-gray-500 text-xs leading-relaxed">{comp.shortDescription}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      )}
    </div>
  </section>

  <!-- PROJECTS SECTION -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-6">
      <div class="text-center mb-14">
        <p class="text-[#2d5a27] text-sm font-semibold tracking-widest uppercase mb-3">Real Projects</p>
        <h2 class="text-4xl font-bold text-gray-900 mb-4">Storm Guard in the Field</h2>
        <p class="text-gray-500 max-w-2xl mx-auto">From large commercial complexes to urban residential retrofits — Storm Guard is deployed across diverse project types where weather resistance and practical installation matter most.</p>
      </div>

      {heroProject && (
        <div class="mb-8 rounded-2xl overflow-hidden group">
          <div class="grid md:grid-cols-3 h-[480px]">
            <div class="md:col-span-2 overflow-hidden">
              <img
                src={heroProject.images[0]}
                alt={heroProject.name}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
              />
            </div>
            <div class="bg-[#1a2e1a] p-10 flex flex-col justify-between">
              <div>
                <span class="text-amber text-xs font-bold tracking-widest uppercase">Storm Guard</span>
                <h3 class="text-white text-2xl font-bold mt-3 mb-4 leading-snug">{heroProject.name}</h3>
                <p class="text-white/60 text-sm leading-relaxed mb-6">{heroProject.overview}</p>
                <div class="grid grid-cols-2 gap-3">
                  {heroProject.roofArea && (
                    <div class="bg-white/10 rounded-lg p-3">
                      <div class="text-white/40 text-xs mb-1">Roof Area</div>
                      <div class="text-white font-semibold text-sm">{heroProject.roofArea}</div>
                    </div>
                  )}
                  {heroProject.capacity && (
                    <div class="bg-white/10 rounded-lg p-3">
                      <div class="text-white/40 text-xs mb-1">Capacity</div>
                      <div class="text-white font-semibold text-sm">{heroProject.capacity}</div>
                    </div>
                  )}
                </div>
              </div>
              <a href={`/projects/${heroProject.slug}/`} class="inline-flex items-center gap-2 text-amber hover:text-amber-dark font-medium text-sm transition-colors mt-6">
                View Full Project
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
              </a>
            </div>
          </div>
        </div>
      )}

      <div class="grid md:grid-cols-2 gap-8 mb-10">
        {[urbanRetrofit, lowSlope].filter(Boolean).map((proj: any) => proj && (
          <div class="rounded-2xl overflow-hidden bg-gray-50 group">
            <div class="h-64 overflow-hidden">
              <img src={proj.images[0]} alt={proj.name} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" />
            </div>
            <div class="p-7">
              <span class="text-[#2d5a27] text-xs font-bold tracking-widest uppercase">Storm Guard</span>
              <h3 class="text-gray-900 text-xl font-bold mt-2 mb-3">{proj.name}</h3>
              <p class="text-gray-500 text-sm leading-relaxed mb-5">{proj.overview}</p>
              <div class="flex gap-4 mb-5">
                {proj.roofArea && (
                  <div>
                    <div class="text-gray-400 text-xs">Roof Area</div>
                    <div class="font-semibold text-gray-800 text-sm">{proj.roofArea}</div>
                  </div>
                )}
                {proj.capacity && (
                  <div>
                    <div class="text-gray-400 text-xs">Capacity</div>
                    <div class="font-semibold text-gray-800 text-sm">{proj.capacity}</div>
                  </div>
                )}
              </div>
              <a href={`/projects/${proj.slug}/`} class="inline-flex items-center gap-2 text-amber hover:text-amber-dark font-medium text-sm transition-colors">View Full Project →</a>
            </div>
          </div>
        ))}
      </div>

      <div class="text-center">
        <a href="/projects/" class="inline-flex items-center gap-2 border border-[#2d5a27] text-[#2d5a27] hover:bg-[#2d5a27] hover:text-white font-medium px-8 py-3.5 rounded-lg transition-colors">
          View All Storm Guard Projects →
        </a>
      </div>
    </div>
  </section>

  <!-- INSTALLATION VIDEOS -->
  <section class="py-20 bg-[#0f1f0f]">
    <div class="max-w-7xl mx-auto px-6">
      <div class="text-center mb-14">
        <p class="text-amber text-sm font-semibold tracking-widest uppercase mb-3">Installation Evidence</p>
        <h2 class="text-white text-4xl font-bold mb-4">See How It Goes Up</h2>
        <p class="text-white/50 max-w-2xl mx-auto">Four installation clips from the factory team — sheet laying, seam locking, ridge and edge finishing, and the completed roof result.</p>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        {installVideos.map((vid) => (
          <div class="relative rounded-2xl overflow-hidden bg-black aspect-video cursor-pointer group sg-video-wrapper">
            <img src={vid.poster} alt={vid.label} class="w-full h-full object-cover" />
            <div class="sg-play-overlay absolute inset-0 flex flex-col items-center justify-center bg-black/40">
              <div class="w-14 h-14 bg-white/90 rounded-full flex items-center justify-center shadow-xl group-hover:scale-110 transition-transform mb-3">
                <svg class="w-6 h-6 text-[#2d5a27] ml-1" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
              </div>
              <span class="text-white text-xs font-semibold text-center px-2">{vid.label}</span>
            </div>
            <video controls class="sg-video absolute inset-0 w-full h-full hidden" poster={vid.poster}>
              <source src={vid.src} type="video/mp4" />
            </video>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- IMPACT RESISTANCE TEST -->
  <section class="py-20 bg-[#1a2e1a]">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid md:grid-cols-2 gap-12 items-center">
        <div>
          <p class="text-amber text-sm font-semibold tracking-widest uppercase mb-4">Quality Evidence</p>
          <h2 class="text-white text-4xl font-bold mb-6 leading-tight">Impact Resistance<br/>Tested on Camera</h2>
          <p class="text-white/60 text-lg mb-8 leading-relaxed">The Storm Guard active sheet is tested to resist 35mm hailstone impact. Watch the actual test footage — not a spec sheet claim.</p>
          <div class="grid grid-cols-2 gap-4 mb-8">
            {sharedActiveTilePerformance.map((item: any) => (
              <div class="bg-white/10 rounded-xl p-4">
                <div class="text-white/50 text-xs mb-1">{item.label}</div>
                <div class="text-white font-semibold">{item.value}</div>
              </div>
            ))}
          </div>
          <a href="/contact/" class="inline-flex items-center gap-2 bg-amber hover:bg-amber-dark text-gray-900 font-semibold px-7 py-3.5 rounded-lg transition-colors">Request Datasheet</a>
        </div>
        <div class="relative">
          <div class="rounded-2xl overflow-hidden bg-black aspect-video relative cursor-pointer group sg-video-wrapper">
            <img src="/videos/testing/Storm Guard 抗冲击-poster.webp" alt="Storm Guard impact resistance test" class="w-full h-full object-cover" />
            <div class="sg-play-overlay absolute inset-0 flex items-center justify-center">
              <div class="w-20 h-20 bg-white/90 rounded-full flex items-center justify-center shadow-xl group-hover:scale-110 transition-transform">
                <svg class="w-8 h-8 text-[#2d5a27] ml-1" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
              </div>
            </div>
            <video controls class="sg-video absolute inset-0 w-full h-full hidden" poster="/videos/testing/Storm Guard 抗冲击-poster.webp">
              <source src="/videos/testing/Storm Guard 抗冲击.mp4" type="video/mp4" />
            </video>
          </div>
          <div class="absolute -bottom-4 -right-4 bg-amber text-gray-900 text-xs font-bold px-4 py-2 rounded-lg shadow-lg">35mm Hail Test Passed</div>
        </div>
      </div>
    </div>
  </section>

  <!-- TECH SPECS TABLE -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-6">
      <div class="text-center mb-14">
        <p class="text-[#2d5a27] text-sm font-semibold tracking-widest uppercase mb-3">Technical Specifications</p>
        <h2 class="text-4xl font-bold text-gray-900 mb-4">Active Sheet Parameters</h2>
        <p class="text-gray-500 max-w-2xl mx-auto">Key electrical and physical parameters for the Storm Guard active solar sheet. For full datasheet including I-V curves and installation tolerances, contact us.</p>
      </div>
      <div class="max-w-3xl mx-auto">
        <div class="rounded-2xl overflow-hidden border border-gray-100 shadow-sm">
          {[
            { label: 'Product Line', value: spec.productLine },
            { label: 'Active Element', value: spec.displayName },
            { label: 'Power (Pmax)', value: spec.powerPmax },
            { label: 'Module Size', value: spec.size },
            { label: 'Effective Size', value: spec.effectiveSize },
            { label: 'Weight', value: spec.weight },
